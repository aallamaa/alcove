#!/bin/sh
# Alcove pre-commit gate — clang-format + clang-tidy on the lines you are
# COMMITTING, not the whole tree. The repo still carries a lot of pre-existing
# LLVM-style drift; checking only staged hunks means that backlog never blocks
# a commit while new code stays clean.
#
# Escape hatches:
#   git commit --no-verify     skip this hook entirely (one commit)
#   ALCOVE_SKIP_TIDY=1 git ...  keep the fast format check, skip the slow lint
#
# clang-tidy analyzes the full translation unit (~3 min on alcove.c) even to
# check a few changed lines, because the interpreter is one big TU. If that is
# too slow for your flow, set ALCOVE_SKIP_TIDY=1 (or move this block to a
# pre-push hook). The format check below is fast and always runs.

# Staged C/H files this commit touches (Added/Copied/Modified).
CFILES=$(git diff --cached --name-only --diff-filter=ACM -- '*.c' '*.h')
[ -z "$CFILES" ] && exit 0

status=0

# --- 1. clang-format: are the staged hunks formatted? (fast) ----------------
if command -v git-clang-format >/dev/null 2>&1; then
  fmt=$(git clang-format --staged --diff -q -- $CFILES 2>/dev/null)
  case "$fmt" in
    ""|"no modified files to format"|"clang-format did not modify any files")
      ;;
    *)
      echo "✗ clang-format: staged changes need reformatting."
      echo "  Run:  git clang-format --staged  &&  git add -u"
      echo "  (or 'make fmt' for the whole file). Offending diff:"
      echo "$fmt" | sed 's/^/    /' | head -60
      status=1
      ;;
  esac
else
  echo "• git-clang-format not found; skipping format check."
fi

# --- 2. clang-tidy: new diagnostics on the changed lines (slow) -------------
if [ "$ALCOVE_SKIP_TIDY" = "1" ]; then
  echo "• ALCOVE_SKIP_TIDY=1 — skipping clang-tidy."
elif command -v clang-tidy-diff >/dev/null 2>&1 || command -v clang-tidy-diff.py >/dev/null 2>&1; then
  TIDY_DIFF=$(command -v clang-tidy-diff || command -v clang-tidy-diff.py)
  CFLAGS="-std=gnu11 -DALCOVE_JIT=1 -DALCOVE_FFI=1 -DALCOVE_READLINE=1"
  CFLAGS="$CFLAGS $(pkg-config --cflags libffi 2>/dev/null) $(pkg-config --cflags readline 2>/dev/null)"
  echo "• clang-tidy on changed lines (analyzing the full TU, ~3 min)…"
  tidy=$(git diff --cached -U0 -- $CFILES | "$TIDY_DIFF" -p1 -quiet -- $CFLAGS 2>/dev/null)
  if printf '%s\n' "$tidy" | grep -qE 'warning:|error:'; then
    echo "✗ clang-tidy flagged your changed lines:"
    printf '%s\n' "$tidy" | grep -E 'warning:|error:' | sed 's/^/    /' | head -40
    echo "  Fix them, or commit with ALCOVE_SKIP_TIDY=1 to defer."
    status=1
  fi
else
  echo "• clang-tidy-diff not found; skipping lint."
fi

[ "$status" -eq 0 ] && echo "✓ pre-commit checks passed."
exit $status
