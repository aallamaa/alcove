# Build artifacts (the default `make` target produces ./alcove).
alcove

# Cross-compile / benchmark A-B comparison binaries (alcove.jemalloc,
# alcove.dbg, alcove.asan, alcove-prestep23, alcove.tip, …).
# Scoped to the repo root so docs/alcove-language.md and similar
# nested files aren't accidentally ignored by the alcove-* glob.
/alcove.*
/alcove-*
!/alcove.c
!/alcove.h

# Debug-symbol bundles produced by macOS dsymutil for any of the above.
*.dSYM/

# Editor / OS crud.
*.o
*.swp
.DS_Store
# macOS AppleDouble metadata (created when a Mac extracts a tarball
# or copies into a non-HFS+ filesystem).
._*
# Emacs lockfiles + autosaves (#name#, .#name).
\#*\#
.\#*

# Per-run persistence artifact (savedb writes ./db.dump in CWD).
db.dump
# Other ad-hoc REPL persistence + auto-loaded init scratch.
*.db
.init.alc

# FFI example .so (built from .c on demand).
ffi-examples/libmylib.so

# MLP demo: downloaded dataset + generated alcove artifacts.
examples/mlp/optdigits.tra
examples/mlp/optdigits.tes
examples/mlp/digits.bin
examples/mlp/digits.dump

# Mario demo: built shim + downloaded music track (not redistributed,
# see examples/mario/README.md > Legal notice).
examples/mario/libmariogfx.so
examples/mario/libmariogfx.dylib
examples/mario/theme.ogg

# Web (Emscripten) build artifacts — produced by `make web` at the
# repo root and `make web` in examples/mario/. Sources in web/ and
# examples/mario/web/ stay tracked; the .js/.wasm output and the
# copies of mario.alc / theme.ogg into web/ do not.
web/alcove-core.js
web/alcove-core.wasm
examples/mario/web/mario-core.js
examples/mario/web/mario-core.wasm
examples/mario/web/mario.alc
examples/mario/web/theme.ogg

# MPSC primitive standalone test binaries (Step 2.1).
mpsc_test
mpsc_test_tsan

# Built benchmark binaries (./benchmark/run.sh produces these).
benchmark/bin/

# Local prototype scratch (superseded by lfkv.{c,h}).
lockfree-bench/
benchmark/resp-bench-c
alcove_asan
