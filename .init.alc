;; Project-local Alcove startup.
;; Keep the REPL quiet: no "In [n]:" input prompt and no "Out[n]:" result label.
;; Continuation rows show only two spaces; the reader's actual input remains
;; exactly what the user types after that display prompt.
(= *prompt-in* (fn (n) ""))
(= *prompt-out* (fn (n) ""))
(= *prompt-cont* (fn (n) "  "))
