; Knuth's tak function — heavy recursion, integer-only.
; tak(18, 12, 6) produces ~63 million calls; canonical benchmark for
; function-call overhead.
(def tak (x y z)
  (if (no (< y x))
      z
      (tak (tak (- x 1) y z)
           (tak (- y 1) z x)
           (tak (- z 1) x y))))
(prn (tak 24 16 8))
