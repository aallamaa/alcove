def tco-let (n):
  if (is n 0):
    'ok
    let m (- n 1):
      tco-let m

def tco-lets (n):
  if (is n 0):
    'ok
    let* (m (- n 1)) (tco-lets m)

def tco-with (n):
  if (is n 0):
    'ok
    with (m (- n 1)):
      tco-with m

def tco-when (n):
  if (is n 0):
    'ok
    when t:
      tco-when (- n 1)

def tco-unless (n):
  unless (is n 0):
    tco-unless (- n 1)

assert "tco through let" (tco-let 1000000) 'ok

assert "tco through let*" (tco-lets 1000000) 'ok

assert "tco through with" (tco-with 1000000) 'ok

assert "tco through when" (tco-when 1000000) 'ok

assert "tco through unless" (tco-unless 1000000) nil

def tco-and (n a):
  if (< n 1):
    a
    and t (tco-and (- n 1) (+ a 1))

def tco-or (n a):
  if (< n 1):
    a
    or nil (tco-or (- n 1) (+ a 1))

def tco-cond (n a):
  cond (< n 1) a t (tco-cond (- n 1) (+ a 1))

def tco-case (n a):
  case n:
    0
    a
    tco-case (- n 1) (+ a 1)

assert "tco through and" (tco-and 1000000 0) 1000000

assert "tco through or" (tco-or 1000000 0) 1000000

assert "tco through cond" (tco-cond 1000000 0) 1000000

assert "tco through case" (tco-case 1000000 0) 1000000

def tco-builtin (n a):
  if (< n 1):
    a
    tco-builtin (- n 1) (max a 1)

def tco-let-builtin (n a):
  let b (abs a):
    if (< n 1):
      b
      tco-let-builtin (- n 1) (+ a 1)

assert "tco around builtin (max)" (tco-builtin 1000000 5) 5

assert "tco around let-builtin" (tco-let-builtin 1000000 0) 1000000

