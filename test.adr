  assert label (if _jit_on (jit? f) (no (jit? f))) t

def jc-const ():
  42

def jc-add (s):
  + s 7

def jc-mul (s):
  * s 7

def jc-lt (n):
  if (< n 1000):
    jc-lt (+ n 1)
    n

def jc-le (n):
  if (<= n 1000):
    jc-le (+ n 1)
    n

def jc-gt (n):
  if (> n 0):
    jc-gt (- n 1)
    n

def jc-ge (n):
  if (>= n 1):
    jc-ge (- n 1)
    n

def jc-eqcd (n):
  if (is n 0):
    n
    jc-eqcd (- n 1)

def jc-equp (n):
  if (is n 100):
    n
    jc-equp (+ n 5)

def jc-wide (n):
  if (< n 5000000):
    jc-wide (+ n 1)
    n

def jc-fact (n):
  if (< n 2):
    1
    * n (jc-fact (- n 1))

def jc-fib (n):
  if (< n 2):
    n
    + (jc-fib (- n 1)) (jc-fib (- n 2))

def jc-ack (m n):
  if (is m 0):
    + n 1
    if (is n 0):
      jc-ack (- m 1) 1
      jc-ack (- m 1) (jc-ack m (- n 1))

def jc-tak (x y z):
  if (no (< y x)):
    z
    jc-tak (jc-tak (- x 1) y z) (jc-tak (- y 1) z x) (jc-tak (- z 1) x y)

def jc-loopcall (k):
  if (> k 0):
    do:
      jc-fact 19
      jc-loopcall (- k 1)
    k

def jc-forsum (n):
  let s 0:
    for i 1 n:
      setf s (+ s 1)

def jc-build (i n acc):
  if (> i n):
    acc
    jc-build (+ i 1) n (cons i acc)

def jc-markfrom (step j n marks):
  if (> j n):
    nil
    do:
      vec-set! marks j nil
      jc-markfrom step (+ j step) n marks

def jc-countprimes (i n marks acc):
  if (> i n):
    acc
    jc-countprimes (+ i 1) n marks (if (vec-ref marks i) (+ acc 1) acc)

def jc-isprime (acc i):
  if (no acc):
    t
    if (is (mod i (car acc)) 0):
      nil
      jc-isprime (cdr acc) i

def jc-primes (i n acc):
  if (> i n):
    acc
    if (jc-isprime acc i):
      jc-primes (+ i 1) n (cons i acc)
      jc-primes (+ i 1) n acc

def jc-safe (c qs offset):
  if (no qs):
    t
    if (is c (car qs)):
      nil
      if (is (+ c offset) (car qs)):
        nil
        if (is (- c offset) (car qs)):
          nil
          jc-safe c (cdr qs) (+ offset 1)

def jc-divides (a b):
  is (mod a b) 0

def jc-facc-add (n acc):
  if (< n 100000):
    jc-facc-add (+ n 1) (+ acc 0.5)
    acc

def jc-facc-sub (n acc):
  if (< n 100000):
    jc-facc-sub (+ n 1) (- acc 0.5)
    acc

def jc-facc-mul (n acc):
  if (< n 40000):
    jc-facc-mul (+ n 1) (* acc 2.0)
    acc

