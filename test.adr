  call/cc (fn (found) (do (setf _i 1) (while (<= _i n) (do (setf _j 1) (while (<= _j n) (do (if (is (+ _i _j) target) (found (list _i _j))) (setf _j (+ _j 1)))) (setf _i (+ _i 1)))) nil))

