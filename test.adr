assert-true "now-ms is monotonic non-decreasing" (do (setf _t0 (now-ms)) (sleep-ms 2) (>= (now-ms) _t0))

assert "string-buf default space" (string-buf 4) "    "

assert "string-buf init char" (string-buf 3 #\*) "***"

assert "string-buf zero len" (string-buf 0) ""

assert "string-set! in place" (do (setf _s (string-buf 4)) (string-set! _s 0 #\H) (string-set! _s 1 #\i) _s):
  "Hi  "

