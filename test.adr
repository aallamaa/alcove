assert "cycle: churn 5 = 10" (churn 5) 10

def parity (n):
  do:
    def ev (k):
      if (is k 0):
        t
        od (- k 1)
    def od (k):
      if (is k 0):
        nil
        ev (- k 1)
    ev n

assert "cycle: local mutual even 10" (parity 10) t

refute "cycle: local mutual odd 7" (parity 7) t

