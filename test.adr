  t

assert "set literal: non-member" (set-has? (hash-set 1 2 3) 9) nil

assert "set literal: empty" (set? (hash-set)) t

assert "set literal: mixed" (set-has? (hash-set 1 "a" :k) :k) t

assert "vector literal: #[]" (vec? (vector 1 2 3)) t

