(def assert (txt a b) 
  (pr txt) 
  (if (iso a b) 
      (prn "\t: \x1B[92mPassed\x1B[39m") 
      (prn "\t: \x1B[91mFailed\x1B[39m")))

(assert "This will Pass" 1 1)
(assert "This will Fail" 1 0)
(assert "addition" 3 (+ 1 2))
(assert " (+) is 0" 0 (+ ))
(assert "cons test " 
        (cons 'f '(a b)) 
        '(f a b))
(= x '(a b))
(assert "(cons 'f x) -> (f a b)" 
        '(f a b) 
        (cons 'f x))
(assert "(cons 'a nil) -> (a)" 
        (cons 'a nil) 
        '(a))
(assert "(car '(a b c)) -> a" 
        (car '(a b c)) 
        'a)
(assert "(cdr '(a b c)) -> (b c)" 
        (cdr '(a b c)) 
        '(b c))
(assert "(list 'a 1 "foo" '(b))  -> (a 1 "foo" (b))" 
        (list 'a 1 "foo" '(b)) 
        '(a 1 "foo" (b)))
(assert "(cons 'a (cons 1 (cons "foo" (cons '(b) nil)))) -> (a 1 "foo" (b))" 
        (cons 'a 
              (cons 1 
                    (cons "foo" 
                          (cons 
                            '(b) nil)))) 
        '(a 1 "foo" (b)))
(= x '(a b))
(assert "(= (car x) 'z) -> z" (= (car x) 'z) 'z)
(assert "and x -> (z b)" x '(z b))
(def average (x y) 
  (/ (+ x y) 2)))
(assert "(average 2 4) -> 3" (average 2 4) 3)
(assert "((fn (x y) (/ (+ x y) 2)) 2 4) -> 3" ((fn (x y) (/ (+ x y) 2)) 2 4) 3)
(assert "(\"foo\" 0) -> #\\f" ("foo" 0) #\f)
(= s "foo")
(assert "(= (s 0) #\m) ->#\m " (= (s 0) #\m) #\m)
(assert " s -> moo" s "moo")
(assert "(let x 1 (+ x (* x 2))) -> 3" (let x 1 (+ x (* x 2))) 3)
(assert "(with (x 3 y 4)
       (sqrt (+ (expt x 2) (expt y 2)))) 
       -> 5" (with (x 3 y 4)
               (sqrt (+ (expt x 2) (expt y 2)))) 5.0)  

(assert "(if (odd 1) 'a 'b) -> a" (if (odd 1) 'a 'b) 'a)
(assert "(if (odd 2) 'a 'b) -> b" (if (odd 2) 'a 'b) 'b)
(def mylen (xs)
  (if (no xs)
      0
      (+ 1 (mylen (cdr xs)))))
(assert "mylen nil -> 0"  (mylen nil) 0 )
(assert "(mylen '(a b)) -> 2 "  (mylen '(a b)) 2)

(assert "(is 'a 'a) -> t" (is 'a 'a) t)

(assert "(is "foo" "foo") -> t" (is "foo" "foo") t)

(assert "(let x (list 'a) (is x x)) -> t" (let x (list 'a) (is x x)) t)
(assert "(is (list 'a) (list 'a)) -> nil" (is (list 'a) (list 'a)) nil)

(assert "(iso (list 'a) (list 'a)) ->t" (iso (list 'a) (list 'a)) t)

(assert "(let x 'a (in x 'a 'b 'c)) -> t" (let x 'a (in x 'a 'b 'c)) t)

; for-loop must not mutate source AST literals (regression pin)
; before the forcmd fix, the second call would see mutated start/end
; literals and return 0 instead of 5.
(def runforsum (n)
  (let s 0
    (for i 1 n (= s (+ s 1)))))
(assert "first  (runforsum 5) -> 5" (runforsum 5) 5)
(assert "second (runforsum 5) -> 5" (runforsum 5) 5)

; Bytecode VM regressions. These functions all compile (arith + if +
; user-call + self-tail). The tests exercise specific code paths.

; 1. Anonymous fn with self-recursion: self_name is NULL, so the
;    compiler cannot detect tail-self — the call becomes an OP_CALL,
;    not OP_TAIL_SELF. Verify correctness.
(assert "anon-fn arith"       ((fn (x y) (+ (* x 2) y)) 3 4) 10)

; 2. Cross-boundary call: dbl is compiled (arith), outer uses `let`
;    (not compiled, stays AST), calls compiled dbl.
(def dbl (x) (+ x x))
(assert "AST calls compiled"  (let x 7 (dbl x)) 14)

; 3. Compiled function calling AST function. Wrap dbl-call in a
;    compiled function that sums the result.
(def sumtwo (a b) (+ a b))
(assert "compiled call chain" (sumtwo (dbl 5) (dbl 6)) 22)

; 4. >6 params forces the inline-slot overflow → dict spill path in
;    both var2env and vm_invoke_values.
(def seven (a b c d e f g) (+ a (+ b (+ c (+ d (+ e (+ f g)))))))
(assert "7 params spill"      (seven 1 2 3 4 5 6 7) 28)

; 5. VM < returns t/nil singletons (not a freshly-allocated boolean).
(assert "vm < returns t"      (< 3 5) t)
(assert "vm < returns nil"    (< 5 3) nil)

; 6. VM error propagation: div-by-zero in a compiled body must return
;    an error (printed by the driver) and leave state clean so the
;    interpreter keeps going. The subsequent assert verifies that.
(def vmerr (x) (/ x 0))
(vmerr 5)
(assert "recovery after VM error" 42 42)

; 7. Phase-2 compiler — (= local val) on a param. Body should compile
;    (OP_STORE_SLOT). Verify (= ...) returns the new value AND mutates.
(def inc (n) (= n (+ n 1)))
(assert "(= param val) returns val"  (inc 5) 6)

; 8. Phase-2 compiler — `let`. Inner let should shadow outer binding.
(assert "let basic"                  (let x 3 (+ x 4))            7)
(assert "let uses caller scope"      ((fn (y) (let x 10 (+ x y))) 5) 15)
(assert "nested let shadows"         (let x 1 (let x 2 x))        2)

; 9. Phase-2 compiler — `with` (multi-binding).
(assert "with 2 bindings"            (with (a 3 b 4) (+ a b))     7)
(assert "with shadows"               (let a 1 (with (a 9) a))     9)

; 10. let + mutation: assign into let-bound slot, then read.
(assert "= into let slot"            (let c 10 (= c 20) c)        20)

; 11. for compiled: body returns last expr of last iter; empty range
;     returns nil; sum via (= s (+ s i)).
(def lastsq (n) (for i 1 n (* i i)))
(assert "for returns last body val"  (lastsq 5)                   25)
(def forempty (n) (for i 5 1 (* n n)))
(assert "for empty range nil"        (forempty 7)                 nil)
(def fsum (n) (let s 0 (for i 1 n (= s (+ s i)))))
(assert "compiled fsum 10 -> 55"     (fsum 10)                    55)
(assert "compiled fsum 100 -> 5050"  (fsum 100)                   5050)

; 12. Phase-3: cross-function tail calls trampoline in the VM.
;     Mutual recursion between compiled functions runs in O(1) C stack.
(def even? (n) (if (< n 1) t    (odd? (- n 1))))
(def odd?  (n) (if (< n 1) nil  (even? (- n 1))))
(assert "mutual even? 1000"          (even? 1000)                 t)
(assert "mutual odd? 1001"           (odd? 1001)                  t)
(assert "mutual deep 100k"           (even? 100000)               t)

; 13. Phase-4 — list ops in VM (cons/car/cdr/list).
(def consit (a b) (cons a b))
(assert "vm cons returns pair"       (iso (consit 1 (list 2 3))
                                          (list 1 2 3))           t)
(def carit (xs) (car xs))
(def cdrit (xs) (cdr xs))
(assert "vm car"                     (carit (list 10 20 30))      10)
(assert "vm cdr iso"                 (iso (cdrit (list 10 20 30))
                                          (list 20 30))           t)
(def listit (a b c) (list a b (* c 2)))
(assert "vm list 3"                  (iso (listit 1 2 5)
                                          (list 1 2 10))          t)
(def myrev (xs acc)
  (if (no xs) acc (myrev (cdr xs) (cons (car xs) acc))))
(assert "vm tail-recursive reverse"  (iso (myrev (list 1 2 3 4 5) (list))
                                          (list 5 4 3 2 1))       t)

; 14. Phase-6: JIT tag-check + deopt. addone is JIT-eligible
;     ((fn (n) (+ n K)) shape). Calling with a fixnum hits the native
;     fast path; calling with a non-fixnum must NOT corrupt and must
;     let the next fixnum call still work (proves deopt -> vm_run -> recovery).
(def addone (n) (+ n 1))
(assert "JIT addone fix"             (addone 41)                   42)
(addone 'sym)                        ; deopt path; result discarded
(assert "JIT addone after deopt"     (addone 100)                  101)
(def cdn (n) (if (> n 0) (cdn (- n 1)) n))
(assert "JIT loop fix to 0"          (cdn 1000)                    0)
(cdn 'sym)                           ; deopt at loop entry
(assert "JIT loop after deopt"       (cdn 500)                     0)

; 15. JIT generalized slot index — leaf op on the 2nd param (slot 1),
;     not just slot 0. Uses (+ b 1) so the body stays in the leaf-arith
;     shape but matches a non-zero slot.
(def addb (a b) (+ b 1))
(assert "JIT addb slot1 fix"         (addb 'ignored 41)            42)
(addb 0 'sym)                        ; deopt path on slot 1; result discarded
(assert "JIT addb slot1 after deopt" (addb 0 100)                  101)

; 16. JIT multiplication-by-constant leaf — (fn (n) (* n K)).
;     Tag arithmetic via (t-1)*K + 1; deopt on non-fixnum.
(def doublen (n) (* n 2))
(assert "JIT doublen fix"            (doublen 21)                  42)
(doublen 'sym)                       ; deopt; result discarded
(assert "JIT doublen after deopt"    (doublen 100)                 200)
(def triplen (n) (* n 3))
(assert "JIT triplen 0"              (triplen 0)                   0)
(assert "JIT triplen negative K"     ((fn (n) (* n -4)) 7)         -28)

; 17. JIT tail loop with one inner global call before the recurse.
;     New 26-byte shape (amd64 only for now): the (do (g K) (lp ...)) form
;     emits LOAD_FIX + CALL_GLOBAL + POP between the compare and the arith.
;     The inner fn is (+ x 1) rather than (x) x to dodge a pre-existing
;     alcove bug where (do (identity-fn ...) ...) returns nil.
(def addbump (x) (+ x 1))
(def lpcall (k) (if (> k 0) (do (addbump 99) (lpcall (- k 1))) k))
(assert "JIT loop+call to 0"         (lpcall 100)                  0)
(lpcall 'sym)                        ; deopt at loop entry; result discarded
(assert "JIT loop+call after deopt"  (lpcall 50)                   0)

; 18. JIT two-call non-tail recursion (the fib shape, amd64 only).
;     (def f (n) (if (cmp n K1) n (+ (g (op n K2)) (g (op n K3)))))
;     The new matcher generates ~190 bytes of native that does the base
;     case inline and only enters a frame for the recursive path.
;     Tag-checks each call return; non-fixnum bails through frame teardown.
(def jfib (n) (if (< n 2) n (+ (jfib (- n 1)) (jfib (- n 2)))))
(assert "JIT fib base 0"             (jfib 0)                      0)
(assert "JIT fib base 1"             (jfib 1)                      1)
(assert "JIT fib 10"                 (jfib 10)                     55)
(assert "JIT fib 20"                 (jfib 20)                     6765)
(assert "JIT fib 30"                 (jfib 30)                     832040)
(jfib 'sym)                          ; deopt at entry; result discarded
(assert "JIT fib after deopt"        (jfib 15)                     610)
