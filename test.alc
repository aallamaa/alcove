;; Pass/fail counters so `make test` can machine-check the run: the file
;; prints "TEST RESULT: N passed, M failed" at the end; M must be 0.
(= _test_pass 0)
(= _test_fail 0)
(def assert (txt a b)
  (pr txt)
  (if (iso a b)
      (do (= _test_pass (+ _test_pass 1)) (prn "\t: \x1B[92mPassed\x1B[39m"))
      (do (= _test_fail (+ _test_fail 1)) (prn "\t: \x1B[91mFailed\x1B[39m"))))
;; refute: passes when a and b are NOT equal (exercises assert's negative path).
(def refute (txt a b)
  (pr txt)
  (if (iso a b)
      (do (= _test_fail (+ _test_fail 1)) (prn "\t: \x1B[91mFailed\x1B[39m"))
      (do (= _test_pass (+ _test_pass 1)) (prn "\t: \x1B[92mPassed\x1B[39m"))))
;; assert-true / assert-false exercise the REAL truthiness path (the `if`
;; special form -> istrue) for a value, not iso equality. They close the
;; per-type coverage gap: a regression in how any value kind is judged
;; truthy/falsy (e.g. "empty vector becomes truthy", "lambda becomes falsy")
;; is caught here even though such a value is never compared with iso.
(def assert-true (txt x)
  (pr txt)
  (if x
      (do (= _test_pass (+ _test_pass 1)) (prn "\t: \x1B[92mPassed\x1B[39m"))
      (do (= _test_fail (+ _test_fail 1)) (prn "\t: \x1B[91mFailed\x1B[39m"))))
(def assert-false (txt x)
  (pr txt)
  (if x
      (do (= _test_fail (+ _test_fail 1)) (prn "\t: \x1B[91mFailed\x1B[39m"))
      (do (= _test_pass (+ _test_pass 1)) (prn "\t: \x1B[92mPassed\x1B[39m"))))

(assert "This will Pass" 1 1)
(refute "assert detects inequality" 1 0)
(assert "addition" 3 (+ 1 2))
(assert " (+) is 0" 0 (+ ))

; ============================================================================
; 0b. Numeric / comparison / logic edge cases — dense coverage of the opcode
;     paths reworked recently (arith, float specialization, is/iso, abs/max/min,
;     and/or/cond/case). Each line pins ONE behavior incl. edge cases.
; ============================================================================
; --- integer arithmetic (variadic, signs, truncating div, modulo) ---
(assert "int + variadic"        (+ 1 2 3 4)        10)
(assert "int - variadic"        (- 10 3 2)         5)
(assert "int * variadic"        (* 2 3 4)          24)
(assert "int * empty is 1"      (* )               1)
(assert "int / exact"           (/ 100 5 2)        10)
(assert "int / truncates"       (/ 7 2)            3)
(assert "int / neg truncates"   (/ -7 2)           -3)
(assert "int + negatives"       (+ -3 -4)          -7)
(assert "int * negative"        (* -2 3)           -6)
(assert "mod positive"          (mod 17 5)         2)
(assert "mod neg dividend"      (mod -7 3)         -1)
(assert "mod neg divisor"       (mod 7 -3)         1)
(assert "mod exact 0"           (mod 9 3)          0)
; --- float arithmetic + int/float mixing (exercises unref_float on operands) ---
(assert "float +"               (+ 1.5 2.5)        4.0)
(assert "float -"               (- 5.5 2.0)        3.5)
(assert "float *"               (* 1.5 2.0)        3.0)
(assert "float /"               (/ 7.0 2.0)        3.5)
(assert "float + chain"         (+ 0.5 0.5 0.5 0.5) 2.0)
(assert "mixed + -> float"      (+ 1 2.5)          3.5)
(assert "mixed * -> float"      (* 2 0.5)          1.0)
(assert "mixed - -> float"      (- 5 2.5)          2.5)
(assert "mixed / -> float"      (/ 7.0 2)          3.5)
(assert "float mod"             (mod 7.5 2.0)      1.5)
; --- comparisons: int / float / mixed / equal boundary (CMP_OP float path) ---
(assert "lt int true"           (< 1 2)            t)
(assert "lt int false"          (< 2 1)            nil)
(assert "gt int"                (> 3 2)            t)
(assert "le equal"              (<= 2 2)           t)
(assert "ge false"              (>= 2 3)           nil)
(assert "lt float"              (< 1.5 2.5)        t)
(assert "lt mixed int<float"    (< 1 1.5)          t)
(assert "lt mixed float<int"    (< 2.5 3)          t)
(assert "gt mixed float>int"    (> 2.5 2)          t)
(assert "le float equal"        (<= 2.0 2.0)       t)
; --- is (identity / type-strict) vs iso (structural) ---
(assert "is fixnum eq"          (is 5 5)           t)
(assert "is fixnum neq"         (is 5 6)           nil)
(assert "is fixnum vs float"    (is 5 5.0)         nil)
(assert "is char eq"            (is #\a #\a)       t)
(assert "is char neq"           (is #\a #\b)       nil)
(assert "is symbol eq"          (is 'a 'a)         t)
(assert "is nil"                (is nil nil)       t)
(assert "is t"                  (is t t)           t)
(assert "is string by content"  (is "x" "x")       t)
(assert "is distinct pairs"     (is (list 1) (list 1)) nil)
(assert "iso fixnum vs float"   (iso 5 5.0)        nil)
(assert "iso float eq"          (iso 1.5 1.5)      t)
(assert "iso list deep"         (iso (list 1 (list 2 3)) (list 1 (list 2 3))) t)
(assert "iso vector deep"       (iso #[1 2 3] #[1 2 3]) t)
(assert "iso string"            (iso "ab" "ab")    t)
(assert "iso unequal list"      (iso (list 1 2) (list 1 3)) nil)
; --- abs / max / min: signs, zero, float, FIXMIN→float, variadic, single arg ---
(assert "abs neg"               (abs -5)           5)
(assert "abs pos"               (abs 5)            5)
(assert "abs zero"              (abs 0)            0)
(assert "abs neg float"         (abs -5.5)         5.5)
(assert "max 2-arg a>b"         (max 7 3)          7)
(assert "max 2-arg a<b"         (max 3 7)          7)
(assert "max negatives"         (max -1 -5)        -1)
(assert "max variadic"          (max 1 2 3 4 5)    5)
(assert "max single"            (max 5)            5)
(assert "max equal"             (max 3 3)          3)
(assert "max picks float"       (max 2 2.5)        2.5)
(assert "min 2-arg"             (min 3 7)          3)
(assert "min negatives"         (min -1 -5)        -5)
(assert "min variadic"          (min 5 4 3 2 1)    1)
(assert "min single"            (min 5)            5)
(assert "min picks int"         (min 2 2.5)        2)
; --- and / or / cond / case value semantics + short-circuit + falsy-0 ---
(assert "and empty -> t"        (and)              t)
(assert "or empty -> nil"       (or)               nil)
(assert "and last truthy"       (and 1 2 3)        3)
(assert "and first falsy"       (and 1 nil 3)      nil)
(assert "and single"            (and 5)            5)
(assert "or first truthy"       (or nil 7)         7)
(assert "or zero is falsy"      (or nil 0 7)       7)
(assert "or all falsy"          (or nil nil)       nil)
(assert "and short-circuits"    (and nil 'never)   nil)
(assert "or short-circuits"     (or 1 'never)      1)
(assert "cond empty"            (cond)             nil)
(assert "cond first hit"        (cond t 1)         1)
(assert "cond second hit"       (cond nil 1 t 2)   2)
(assert "cond no hit no dflt"   (cond nil 1 nil 2) nil)
(assert "cond default"          (cond nil 1 99)    99)
(assert "case match"            (case 5 1 "a" 5 "b" "d") "b")
(assert "case default"          (case 9 1 "a" "d") "d")
(assert "case no match no dflt" (case 9 1 "a")     nil)

; ============================================================================
; 0c. Strings / vectors / sequences / conversions / predicates / errors —
;     edge cases (empty inputs, bounds, type-strictness, error recovery).
; ============================================================================
; --- strings ---
(assert "string-append n"       (string-append "ab" "cd" "ef") "abcdef")
(assert "string-append empty"   (string-append "")  "")
(assert "length string"         (length "hello")    5)
(assert "length empty string"   (length "")         0)
(assert "substr"                (substr "hello" 1 3) "el")
(assert "str of int"            (str 42)            "42")
(assert "str of float"          (str 3.5)           "3.5")
(assert "str of list"           (str (list 1 2))    "(1 2)")
(assert "string-upcase"         (string-upcase "aB") "AB")
(assert "string-downcase"       (string-downcase "aB") "ab")
(assert "string-contains? yes"  (string-contains? "hello" "ell") t)
(assert "string-index"          (string-index "hello" "l") 2)
; --- vectors: read/write, empty, out-of-bounds + negative are catchable ---
(assert "vec-len"               (vec-len (vec 3 0)) 3)
(assert "vec-len empty"         (vec-len (vec 0 0)) 0)
(assert "vec-ref init"          (vec-ref (vec 3 7) 1) 7)
(assert "vec-set! then ref"     (let v (vec 2 0) (do (vec-set! v 0 5) (vec-ref v 0))) 5)
(assert "vec-ref OOB errors"    (try (vec-ref (vec 3 0) 9) (fn (e) 'oob)) 'oob)
(assert "vec-ref neg errors"    (try (vec-ref (vec 3 0) -1) (fn (e) 'neg)) 'neg)
; --- sequence HOFs: normal + empty-input edges ---
(assert "map"                   (map (fn (x) (* x x)) (list 1 2 3)) (list 1 4 9))
(assert "map empty"             (map (fn (x) x) (list)) nil)
(assert "filter"                (filter (fn (x) (> x 1)) (list 1 2 3)) (list 2 3))
(assert "reduce"                (reduce + 0 (list 1 2 3 4)) 10)
(assert "reduce empty -> init"  (reduce + 0 (list)) 0)
(assert "reverse"               (reverse (list 1 2 3)) (list 3 2 1))
(assert "reverse empty"         (reverse (list)) nil)
(assert "take"                  (take 2 (list 1 2 3)) (list 1 2))
(assert "take past end"         (take 5 (list 1 2)) (list 1 2))
(assert "drop"                  (drop 2 (list 1 2 3)) (list 3))
(assert "range exclusive end"   (range 0 3) (list 0 1 2))
(assert "nth"                   (nth 1 (list 10 20 30)) 20)
;; generic seq protocol: map/filter/reduce/nth/seq/first/rest across collections
(assert "map vector"            (map (fn (x) (* x x)) (vector 1 2 3)) (list 1 4 9))
(assert "map string"            (map (fn (c) c) "ab") (list #\a #\b))
(assert "filter vector"         (filter (fn (x) (> x 2)) (vector 1 2 3 4)) (list 3 4))
(assert "reduce vector"         (reduce + 0 (vector 1 2 3 4)) 10)
(assert "seq vector"            (seq (vector 1 2 3)) (list 1 2 3))
(assert "seq string"            (seq "hi") (list #\h #\i))
(assert "seq list identity"     (seq (list 4 5)) (list 4 5))
(assert "first vector"          (first (vector 9 8 7)) 9)
(assert "first string"          (first "hello") #\h)
(assert "first empty"           (first (list)) nil)
(assert "rest vector"           (rest (vector 9 8 7)) (list 8 7))
(assert "rest singleton"        (rest (list 1)) nil)
(assert "nth vector"            (nth 1 (vector 10 20 30)) 20)
(assert "nth string"            (nth 1 "hello") #\e)
(assert "nth flexible order"    (nth (vector 10 20 30) 2) 30)
(assert "nth out of range"      (nth 9 (vector 1 2)) nil)
(assert "map deque"             (let (q (deque)) (push-right! q 1) (push-right! q 2) (map (fn (x) (* x 10)) q)) (list 10 20))
;; associative collections: set → members, dict → (key value) entries
(assert "seq set members"       (sort (seq (set 3 1 2))) (list 1 2 3))
(assert "map over set"          (sort (map (fn (x) (* x x)) (set 1 2 3))) (list 1 4 9))
(assert "reduce over set"       (reduce + 0 (set 1 2 3 4)) 10)
(assert "seq dict entry"        (seq (hash-map "a" 1)) (list (list "a" 1)))
(assert "seq dict count"        (length (seq (hash-map "a" 1 "b" 2))) 2)
(assert "seq hamt entry"        (seq (hamt "a" 1)) (list (list "a" 1)))
(assert "reduce over hamt"      (reduce (fn (acc kv) (+ acc (nth 1 kv))) 0 (hamt "a" 10 "b" 20)) 30)
;; conj (type-dispatched add) + into (pour a seq into a collection)
(assert "conj list prepend"     (conj (list 2 3) 1) (list 1 2 3))
(assert "conj list variadic"    (conj (list 3) 2 1) (list 1 2 3))
(assert "conj vector mutates"   (let (v (vector 1 2)) (conj v 3) v) (vector 1 2 3))
(assert "conj set"              (sort (seq (conj (set 1 2) 3))) (list 1 2 3))
(assert "conj dict entry"       (get (conj (hash-map "a" 1) (list "b" 2)) "b") 2)
(assert "conj hamt fresh"       (hamt-get (conj (hamt "a" 1) (list "b" 2)) "b") 2)
(assert "into vector from list" (into (vector) (list 1 2 3)) (vector 1 2 3))
(assert "into set dedups"       (sort (seq (into (set) (list 1 2 2 3)))) (list 1 2 3))
(assert "into list reverses"    (into (list) (vector 1 2 3)) (list 3 2 1))
(assert "into dict from entries"(get (into (hash-map) (seq (hash-map "x" 9))) "x") 9)
;; apply now works with builtins (not just lambdas)
(assert "apply builtin type-of"  (apply type-of (list 5)) 'int)
(assert "apply builtin +"        (apply + (list 1 2 3)) 6)
;; type-of
(assert "type-of int"            (type-of 5) 'int)
(assert "type-of float"          (type-of 3.0) 'float)
(assert "type-of string"         (type-of "x") 'string)
(assert "type-of keyword"        (type-of :k) 'keyword)
(assert "type-of list"           (type-of (list 1)) 'list)
(assert "type-of vector"         (type-of (vector 1)) 'vector)
;; type-of an error value reports 'error (doesn't re-raise the error)
(assert "type-of error"          (type-of (try (/ 1 0) (fn (e) e))) 'error)
;; defstruct field names must be plain symbols (keyword leaked into the JIT
;; type-hint parser otherwise); reject cleanly instead of an opaque failure.
(assert "defstruct keyword field rejects" (error? (defstruct kkbad :x)) t)
;; defstruct: constructor / accessors / predicate / type tag
(defstruct tpoint px py)
(= _tp (tpoint 3 4))
(assert "defstruct accessor x"   (tpoint-px _tp) 3)
(assert "defstruct accessor y"   (tpoint-py _tp) 4)
(assert "defstruct predicate"    (tpoint? _tp) t)
(assert "defstruct pred neg"     (tpoint? (hash-map)) nil)
(assert "defstruct type-of"      (type-of _tp) 'tpoint)
;; defmulti / defmethod: dispatch on type-of (struct), keyword, built-in type
(defstruct tcirc cr)
(defmulti tarea type-of)
(defmethod tarea 'tcirc (c) (* 3 (tcirc-cr c) (tcirc-cr c)))
(defmethod tarea 'int (n) n)
(assert "defmethod struct"       (tarea (tcirc 10)) 300)
(assert "defmethod builtin type" (tarea 7) 7)
(defmulti tgreet (fn (x) x))
(defmethod tgreet :hi (x) "hi!")
(assert "defmethod keyword disp" (tgreet :hi) "hi!")
;; iso on dict/set: structural (content) equality, order-independent
(assert "iso dict same"          (iso (hash-map "a" 1 "b" 2) (hash-map "b" 2 "a" 1)) t)
(assert "iso dict diff val"      (iso (hash-map "a" 1) (hash-map "a" 2)) nil)
(assert "iso dict diff size"     (iso (hash-map "a" 1) (hash-map "a" 1 "b" 2)) nil)
(assert "iso dict deep"          (iso (hash-map "a" (list 1 2)) (hash-map "a" (list 1 2))) t)
(assert "iso dict empty"         (iso (hash-map) (hash-map)) t)
(assert "iso set same"           (iso (set 1 2 3) (set 3 2 1)) t)
(assert "iso set diff"           (iso (set 1 2) (set 1 2 3)) nil)
(assert "iso set diff member"    (iso (set 1 2 3) (set 1 2 9)) nil)
(assert "is dict not identity"   (is (hash-map "a" 1) (hash-map "a" 1)) nil)
(defstruct isopt x y)
(assert "iso struct by content"  (iso (isopt 1 2) (isopt 1 2)) t)
(assert "iso struct diff"        (iso (isopt 1 2) (isopt 1 9)) nil)
;; audit regressions (deep-review 2026-06-05): these used to crash or swallow errors.
;; iso on two distinct CYCLIC collections must terminate (depth guard), not stack-overflow.
(assert "iso cyclic dict bails"  (let (a (hash-map) b (hash-map))
                                   (assoc! a "s" a) (assoc! b "s" b) (iso a b)) nil)
(assert "iso cyclic vec bails"   (let (a (vector) b (vector))
                                   (vec-push! a a) (vec-push! b b) (iso a b)) nil)
(assert "iso deep nested ok"     (let (build (fn (n acc) (if (is n 0) acc (build (- n 1) (list acc)))))
                                   (iso (build 400 (list)) (build 400 (list)))) t)
;; conj/into must PROPAGATE errors from in-place ops, not swallow them.
(assert "conj bad map entry err" (error? (conj (hash-map) 5)) t)
(assert "conj propagates err"    (error? (try (conj (vector) (no-such-var-xyz)) (fn (e) e))) t)
;; apply on a non-list 2nd arg must error cleanly (was a SEGV walking a fixnum as a cons).
(assert "apply non-list errors"  (error? (apply + 5)) t)
(assert "apply empty list"       (apply + (list)) 0)
(assert "append"                (append (list 1 2) (list 3 4)) (list 1 2 3 4))
(assert "sort"                  (sort (list 3 1 2)) (list 1 2 3))
; --- conversions / predicates ---
(assert "int truncates"         (int 3.9)           3)
(assert "float of int"          (iso (float 3) 3.0) t)
(assert "number? int"           (number? 5)         t)
(assert "number? float"         (number? 5.0)       t)
(assert "number? non"           (number? "x")       nil)
(assert "string? yes"           (string? "x")       t)
(assert "string? no"            (string? 5)         nil)
(assert "list? yes"             (list? (list 1))    t)
(assert "null? nil"             (null? nil)         t)
(assert "null? empty list"      (null? (list))      t)
(assert "null? non-empty"       (null? (list 1))    nil)
; --- error handling: catch, value-passthrough, error?, recovery ---
(assert "try catches div0"      (try (/ 1 0) (fn (e) 'caught)) 'caught)
(assert "try passes value"      (try 42 (fn (e) 'x)) 42)
(assert "error? on caught"      (error? (try (/ 1 0) (fn (e) e))) t)
(assert "error? on plain"       (error? 5)          nil)
(assert "try catches mod0"      (try (mod 5 0) (fn (e) 'mz)) 'mz)

; ============================================================================
; 0d. Binding / shadowing / closures / defc / rest-params — exercises
;     OP_BIND_SLOT_NAMED (named let/with/for slots) and the innermost-first
;     lookup an OP_EVAL_AST sub-form relies on.
; ============================================================================
(assert "inner let shadows"     (let x 1 (let x 2 x)) 2)
(assert "outer let restored"    (let x 1 (do (let x 2 x) x)) 1)
(assert "let shadows param"     ((fn (x) (let x 9 x)) 5) 9)
(assert "let* sequential"       (let* (a 1 b (+ a 1)) (+ a b)) 3)
(assert "with multi-binding"    (with (a 2 b 3) (* a b)) 6)
;; let parenthesized binding forms (flat + Clojure-style), parallel semantics.
(assert "let flat single"       (let (x 5) (+ x 1)) 6)
(assert "let flat multi"        (let (a 1 b 2) (+ a b)) 3)
(assert "let flat compound val" (let (m (- 9 1)) m) 8)
(assert "let flat keyword val"  (let (k :v) k) :v)
(assert "let flat kw + more"    (let (k :v n 3) (list k n)) (list :v 3))
(assert "let clojure pairs"     (let ((x 5) (y 6)) (+ x y)) 11)
(assert "let clojure single"    (let ((x 41)) (+ x 1)) 42)
(assert "let empty bindings"    (let () 42) 42)
(assert "let flat parallel"     (let x 1 (let (x 10 y x) (list x y))) (list 10 1))
;; parallel binding must hold on the COMPILED path too (value sees outer x, not
;; the sibling x being bound) — exercised by wrapping in a called fn (compiled).
(assert "let parallel compiled"  ((fn (x) (let (x 10 y x) (list x y))) 1)  (list 10 1))
(assert "let clojure compiled"   ((fn (x) (let ((x 10) (y x)) (list x y))) 1) (list 10 1))
(assert "with parallel compiled" ((fn (x) (with (x 10 y x) (list x y))) 1) (list 10 1))
(assert "let destructure kept"  (let (a b) (list 1 2) (+ a b)) 3)
(assert "let flat multi-body"   (let (x 5) (+ x 1) (* x 2)) 10)
;; deep tail recursion through a flat-let body must keep TCO (compiled, no overflow)
(def _let_loop (n) (let (m (- n 1)) (if (< n 1) :done (_let_loop m))))
(assert "let-body deep TCO"     (_let_loop 200000) :done)
(assert "mutate let slot"       (let x 10 (do (= x 20) x)) 20)
; compiled fn: a non-whitelisted builtin (reverse → OP_EVAL_AST) reads a
; let-local that shadows the param — must resolve innermost-first (7, not 0).
(def e0d-shadow (v) (let v 7 (reverse (list v v))))
(assert "compiled shadow+EVAL_AST" (e0d-shadow 0) (list 7 7))
(def e0d-adder (n) (fn (x) (+ x n)))
(assert "closure captures param" ((e0d-adder 100) 5) 105)
(defc e0d-find (n) (each x (list 1 2 3 4) (if (is x n) (return 'found))) 'no)
(assert "defc return from each hit"  (e0d-find 3) 'found)
(assert "defc return from each miss" (e0d-find 9) 'no)
(assert "rest params count"     ((fn (a b . more) (length more)) 1 2 3 4 5) 3)
(assert "rest params empty"     ((fn (a . more) (length more)) 1) 0)
;; arity errors: too few AND too many both error (too-many was silently dropped
;; before), with a clear named message identical on the AST and bytecode-VM paths.
(assert "arity too few"         (error? (try ((fn (a b) a) 1) (fn (er) er))) t)
(assert "arity too many"        (error? (try ((fn (a b) a) 1 2 3) (fn (er) er))) t)
(assert "arity too many 0-arg"  (error? (try ((fn () 0) 1) (fn (er) er))) t)
(def arity-g (x y) (+ x y))
(assert "arity msg names fn"    (try (arity-g 1 2 3)
        (fn (er) (string-contains? (error-message er) "arguments to arity-g"))) t)

; ============================================================================
; 0e. Containers — dict / set / hamt / blob / deque, with edge cases (missing
;     keys, empty, dedup, mutation, persistence). Set/dict membership is tested
;     via has?/count/get (order-independent), not printed-list order.
; ============================================================================
; --- hash-map (mutable dict) ---
(assert "dict get hit"          (get (hash-map "a" 1 "b" 2) "a") 1)
(assert "dict get miss -> nil"  (get (hash-map "a" 1) "z") nil)
(assert "dict count"            (count (hash-map "a" 1 "b" 2)) 2)
(assert "dict empty count"      (count (hash-map)) 0)
(assert "dict assoc! then get"  (let d (hash-map) (do (assoc! d "k" 9) (get d "k"))) 9)
(assert "dict assoc! overwrite" (let d (hash-map "k" 1) (do (assoc! d "k" 2) (get d "k"))) 2)
(assert "dict contains? yes"    (contains? (hash-map "a" 1) "a") t)
(assert "dict contains? no"     (contains? (hash-map "a" 1) "z") nil)
(assert "dict dissoc!"          (let d (hash-map "a" 1) (do (dissoc! d "a") (contains? d "a"))) nil)
(assert "dict keys count"       (count (keys (hash-map "a" 1 "b" 2))) 2)
(assert "dict? predicate"       (dict? (hash-map)) t)
; --- set ---
(assert "set-has? yes"          (set-has? (set 1 2 3) 2) t)
(assert "set-has? no"           (set-has? (set 1 2 3) 9) nil)
(assert "set dedup count"       (count (set 1 2 3 3 3)) 3)
(assert "set empty count"       (count (set)) 0)
(assert "set-add!"              (set-has? (set-add! (set 1) 5) 5) t)
(assert "set-del!"              (set-has? (set-del! (set 1 2) 1) 1) nil)
(assert "set-intersection count"(count (set-intersection (set 1 2 3) (set 2 3 4))) 2)
(assert "set-intersection memb" (set-has? (set-intersection (set 1 2 3) (set 2 3 4)) 2) t)
(assert "set-union count"       (count (set-union (set 1 2) (set 2 3))) 3)
(assert "set-difference count"  (count (set-difference (set 1 2 3) (set 2))) 2)
(assert "set? predicate"        (set? (set 1)) t)
; --- hamt (persistent / immutable map) ---
(assert "hamt-get hit"          (hamt-get (hamt-assoc (hamt "a" 1) "b" 2) "b") 2)
(assert "hamt-get miss"         (hamt-get (hamt "a" 1) "z") nil)
(assert "hamt-contains?"        (hamt-contains? (hamt "a" 1) "a") t)
(assert "hamt-count"            (hamt-count (hamt "a" 1 "b" 2)) 2)
(assert "hamt persistent orig"  (let h (hamt "a" 1) (do (hamt-assoc h "b" 2) (hamt-count h))) 1)
(assert "hamt-assoc new map"    (let h (hamt "a" 1) (hamt-count (hamt-assoc h "b" 2))) 2)
(assert "hamt-dissoc"           (hamt-count (hamt-dissoc (hamt "a" 1 "b" 2) "a")) 1)
; --- blob ---
(assert "blob-len"              (blob-len (string->blob "hello")) 5)
(assert "blob roundtrip"        (blob->string (string->blob "hi")) "hi")
(assert "blob-ref byte"         (blob-ref (string->blob "A") 0) 65)
(assert "blob empty len"        (blob-len (string->blob "")) 0)
(assert "blob? predicate"       (blob? (string->blob "x")) t)
; --- deque (doubly-linked) ---
(assert "deque push-left peek"  (let q (deque) (do (push-right! q 1) (push-right! q 2) (push-left! q 0) (peek-left q))) 0)
(assert "deque peek-right"      (let q (deque) (do (push-right! q 1) (push-right! q 2) (peek-right q))) 2)
(assert "deque pop-left"        (let q (deque) (do (push-right! q 1) (push-right! q 2) (pop-left! q) (peek-left q))) 2)
(assert "deque empty count"     (count (deque)) 0)
(assert "deque count after push"(let q (deque) (do (push-right! q 1) (push-right! q 2) (count q))) 2)

(assert "cons test "
        (cons 'f '(a b)) 
        '(f a b))
(= x '(a b))
(assert "(cons 'f x) -> (f a b)" 
        '(f a b) 
        (cons 'f x))
(assert "(cons 'a nil) -> (a)" 
        (cons 'a nil) 
        '(a))
(assert "(car '(a b c)) -> a" 
        (car '(a b c)) 
        'a)
(assert "(cdr '(a b c)) -> (b c)" 
        (cdr '(a b c)) 
        '(b c))
(assert "(list 'a 1 "foo" '(b))  -> (a 1 "foo" (b))" 
        (list 'a 1 "foo" '(b)) 
        '(a 1 "foo" (b)))
(assert "(cons 'a (cons 1 (cons "foo" (cons '(b) nil)))) -> (a 1 "foo" (b))" 
        (cons 'a 
              (cons 1 
                    (cons "foo" 
                          (cons 
                            '(b) nil)))) 
        '(a 1 "foo" (b)))
(= x '(a b))
(assert "(= (car x) 'z) -> z" (= (car x) 'z) 'z)
(assert "and x -> (z b)" x '(z b))
(def average (x y) 
  (/ (+ x y) 2)))
(assert "(average 2 4) -> 3" (average 2 4) 3)
(assert "((fn (x y) (/ (+ x y) 2)) 2 4) -> 3" ((fn (x y) (/ (+ x y) 2)) 2 4) 3)
(assert "(\"foo\" 0) -> #\\f" ("foo" 0) #\f)
(= s "foo")
(assert "(= (s 0) #\m) ->#\m " (= (s 0) #\m) #\m)
(assert " s -> moo" s "moo")
(assert "(let x 1 (+ x (* x 2))) -> 3" (let x 1 (+ x (* x 2))) 3)
(assert "(with (x 3 y 4)
       (sqrt (+ (expt x 2) (expt y 2)))) 
       -> 5" (with (x 3 y 4)
               (sqrt (+ (expt x 2) (expt y 2)))) 5.0)  

(assert "(if (odd 1) 'a 'b) -> a" (if (odd 1) 'a 'b) 'a)
(assert "(if (odd 2) 'a 'b) -> b" (if (odd 2) 'a 'b) 'b)
(def mylen (xs)
  (if (no xs)
      0
      (+ 1 (mylen (cdr xs)))))
(assert "mylen nil -> 0"  (mylen nil) 0 )
(assert "(mylen '(a b)) -> 2 "  (mylen '(a b)) 2)

(assert "(is 'a 'a) -> t" (is 'a 'a) t)

(assert "(is "foo" "foo") -> t" (is "foo" "foo") t)

(assert "(let x (list 'a) (is x x)) -> t" (let x (list 'a) (is x x)) t)
(assert "(is (list 'a) (list 'a)) -> nil" (is (list 'a) (list 'a)) nil)

(assert "(iso (list 'a) (list 'a)) ->t" (iso (list 'a) (list 'a)) t)

(assert "(let x 'a (in x 'a 'b 'c)) -> t" (let x 'a (in x 'a 'b 'c)) t)

; for-loop must not mutate source AST literals (regression pin)
; before the forcmd fix, the second call would see mutated start/end
; literals and return 0 instead of 5.
(def runforsum (n)
  (let s 0
    (for i 1 n (= s (+ s 1)))))
(assert "first  (runforsum 5) -> 5" (runforsum 5) 5)
(assert "second (runforsum 5) -> 5" (runforsum 5) 5)

; Bytecode VM regressions. These functions all compile (arith + if +
; user-call + self-tail). The tests exercise specific code paths.

; 1. Anonymous fn with self-recursion: self_name is NULL, so the
;    compiler cannot detect tail-self — the call becomes an OP_CALL,
;    not OP_TAIL_SELF. Verify correctness.
(assert "anon-fn arith"       ((fn (x y) (+ (* x 2) y)) 3 4) 10)

; 2. Cross-boundary call: dbl is compiled (arith), outer uses `let`
;    (not compiled, stays AST), calls compiled dbl.
(def dbl (x) (+ x x))
(assert "AST calls compiled"  (let x 7 (dbl x)) 14)

; 3. Compiled function calling AST function. Wrap dbl-call in a
;    compiled function that sums the result.
(def sumtwo (a b) (+ a b))
(assert "compiled call chain" (sumtwo (dbl 5) (dbl 6)) 22)

; 4. >6 params forces the inline-slot overflow → dict spill path in
;    both var2env and vm_invoke_values.
(def seven (a b c d e f g) (+ a (+ b (+ c (+ d (+ e (+ f g)))))))
(assert "7 params spill"      (seven 1 2 3 4 5 6 7) 28)

; 5. VM < returns t/nil singletons (not a freshly-allocated boolean).
(assert "vm < returns t"      (< 3 5) t)
(assert "vm < returns nil"    (< 5 3) nil)

; 6. VM error propagation: div-by-zero in a compiled body must return
;    an error (printed by the driver) and leave state clean so the
;    interpreter keeps going. The subsequent assert verifies that.
(def vmerr (x) (/ x 0))
(vmerr 5)
(assert "recovery after VM error" 42 42)

; 7. Phase-2 compiler — (= local val) on a param. Body should compile
;    (OP_STORE_SLOT). Verify (= ...) returns the new value AND mutates.
(def inc (n) (= n (+ n 1)))
(assert "(= param val) returns val"  (inc 5) 6)

; 8. Phase-2 compiler — `let`. Inner let should shadow outer binding.
(assert "let basic"                  (let x 3 (+ x 4))            7)
(assert "let uses caller scope"      ((fn (y) (let x 10 (+ x y))) 5) 15)
(assert "nested let shadows"         (let x 1 (let x 2 x))        2)
(assert "let multi-body"             (let x 5 (+ x 1) (+ x 10))   15)
(assert "let destructuring"          (let (a b) (list 1 2) (+ a b)) 3)

; 8b. let* — sequential bindings (list form + flat legacy form).
(assert "let* sequential"            (let* (a 1 b (* a 10)) (+ a b)) 11)
(assert "let* multi-body"            (let* (x 5) (+ x 1) (+ x 10))  15)
(assert "let* flat legacy"           (let* x 1 y 2 (+ x y))       3)

; 8c. when / unless multi-body and false paths.
(assert "when multi-body"            (when t 1 2 3)               3)
(assert "when false -> nil"          (when nil 99)                nil)
(assert "unless multi-body"          (unless nil 1 2 3)           3)
(assert "unless true -> nil"         (unless t 99)                nil)

; 8d. TCO through let / let* / with / when / unless (compiled tail calls).
;     1e6 deep — would overflow the C stack without proper trampolining.
(def tco-let (n)    (if (is n 0) 'ok (let m (- n 1) (tco-let m))))
(def tco-lets (n)   (if (is n 0) 'ok (let* (m (- n 1)) (tco-lets m))))
(def tco-with (n)   (if (is n 0) 'ok (with (m (- n 1)) (tco-with m))))
(def tco-when (n)   (if (is n 0) 'ok (when t (tco-when (- n 1)))))
(def tco-unless (n) (unless (is n 0) (tco-unless (- n 1))))
(assert "tco through let"            (tco-let 1000000)            'ok)
(assert "tco through let*"           (tco-lets 1000000)           'ok)
(assert "tco through with"           (tco-with 1000000)           'ok)
(assert "tco through when"           (tco-when 1000000)           'ok)
(assert "tco through unless"         (tco-unless 1000000)         nil)

; 8e. TCO through and / or / cond / case — now bytecode-compiled (compile_and_or
;     / compile_cond / compile_case), not builtin-only. 1e6 deep: each form used
;     to drop its lambda to AST eval and SIGSEGV at ~50k frames.
(def tco-and (n a)  (if (< n 1) a (and t (tco-and (- n 1) (+ a 1)))))
(def tco-or (n a)   (if (< n 1) a (or nil (tco-or (- n 1) (+ a 1)))))
(def tco-cond (n a) (cond (< n 1) a t (tco-cond (- n 1) (+ a 1))))
(def tco-case (n a) (case n 0 a (tco-case (- n 1) (+ a 1))))
(assert "tco through and"            (tco-and 1000000 0)          1000000)
(assert "tco through or"             (tco-or 1000000 0)           1000000)
(assert "tco through cond"           (tco-cond 1000000 0)         1000000)
(assert "tco through case"           (tco-case 1000000 0)         1000000)

; 8f. A non-whitelisted builtin in a hot body no longer forces the WHOLE lambda
;     to AST: max/min/abs have native opcodes (OP_NMAX/OP_NMIN/OP_ABS) and any
;     other builtin defers just its sub-call via OP_EVAL_AST — either way the
;     lambda stays compiled and keeps O(1)-stack TCO.
(def tco-builtin (n a)     (if (< n 1) a (tco-builtin (- n 1) (max a 1))))
(def tco-let-builtin (n a) (let b (abs a) (if (< n 1) b (tco-let-builtin (- n 1) (+ a 1)))))
(assert "tco around builtin (max)"   (tco-builtin 1000000 5)      5)
(assert "tco around let-builtin"     (tco-let-builtin 1000000 0)  1000000)
; OP_EVAL_AST + OP_BIND_SLOT_NAMED guard: a non-promoted builtin (reverse)
; reading a let-local from a compiled body — the exact shape (user vec->list)
; that broke when let-locals had NULL inline keys.
(def rev-let (xs) (let ys xs (reverse ys)))
(assert "compiled reverse of let-local"  (rev-let (list 1 2 3))   (list 3 2 1))

; 8g. OP_SLOT_IS_FIX — `(is slot K)` fuses to one superinstruction (and JITs
;     as an equality compare). A 1e6-deep `is`-based tail loop must stay correct
;     under the fusion AND the JIT shape matchers (simple_tail_loop / ackermann)
;     that now accept the fused op. Catches a fusion or JIT-offset regression.
(def is-cd (n)   (if (is n 0) 'ok (is-cd (- n 1))))        ; const base, fused is
(def is-cdn (n)  (if (is n 0) n (is-cdn (- n 1))))         ; slot base → simple_tail_loop JIT shape
(assert "is-fused tail loop (const base)"  (is-cd 1000000)   'ok)
(assert "is-fused tail loop (slot base)"   (is-cdn 1000000)  0)
; `is` immediate is a pure tagged-bit compare: only a fixnum can match.
(assert "is fixnum vs equal fixnum"        (is-cdn 0)        0)
(assert "is 5 5.0 → nil (no float coerce)" (is 5 5.0)        nil)
(assert "is 5 5   → t"                     (is 5 5)          t)
; Ackermann uses two fused `(is _ 0)` base cases — the re-derived JIT shape.
(def is-ack (m n) (if (is m 0) (+ n 1)
                      (if (is n 0) (is-ack (- m 1) 1)
                          (is-ack (- m 1) (is-ack m (- n 1))))))
(assert "is-fused ackermann (jit shape)"   (is-ack 3 6)      509)

; 8h. OP_TAIL_SELF inside a let/let*/with body. A self-tail call wrapped in a
;     binding form now emits OP_TAIL_SELF (rebind inline slots in place, jump to
;     pc=0, re-run the binding prologue) instead of OP_TAIL_CALL+LOAD_GLOBAL —
;     PROVIDED the lambda body cannot create an env-capturing closure or push a
;     try handler (body_capture_unsafe gates this; otherwise it stays TAIL_CALL).
;     These pin VALUE correctness at small N and NO-SEGV + correctness at 1e6.
;     A refcount/slot-accounting drift over the in-place re-bind would surface as
;     a wrong sum or an ASan leak/use-after-free at depth.
(def ts-let (n acc)   (let s (+ acc n) (if (is n 0) s (ts-let (- n 1) s))))
(def ts-lets (n acc)  (let* (a (+ acc n)) (if (is n 0) a (ts-lets (- n 1) a))))
(def ts-with (n acc)  (with (s (+ acc n)) (if (is n 0) s (ts-with (- n 1) s))))
(def ts-nest (n acc)  (let a 1 (let b 1 (if (is n 0) acc (ts-nest (- n 1) (+ acc a b))))))
(def ts-multi (n acc) (with (p 1 q 2 r 3) (if (is n 0) acc (ts-multi (- n 1) (+ acc p q r)))))
(assert "tail-self let (small)"      (ts-let 100 0)               5050)
(assert "tail-self let* (small)"     (ts-lets 100 0)              5050)
(assert "tail-self with (small)"     (ts-with 100 0)              5050)
(assert "tail-self nested let"       (ts-nest 5 0)                10)
(assert "tail-self multi-bind with"  (ts-multi 5 0)               30)
(assert "tail-self let (1e6)"        (ts-let 1000000 0)           500000500000)
(assert "tail-self let* (1e6)"       (ts-lets 1000000 0)          500000500000)
(assert "tail-self with (1e6)"       (ts-with 1000000 0)          500000500000)
(assert "tail-self nested let (1e6)" (ts-nest 1000000 0)          2000000)
(assert "tail-self multi-bind (1e6)" (ts-multi 1000000 0)         6000000)
; CRITICAL bail case: the let body builds a closure CAPTURING the env (via a
; fn collected through map → OP_EVAL_AST). OP_TAIL_SELF must NOT fire here —
; in-place env mutation would corrupt every collected closure. body_capture_unsafe
; forces OP_TAIL_CALL (a fresh env per call), so each closure captures its own s.
; A wrong gate would make all closures share one mutated env (all return 0).
(def ts-cap (n acc) (let s n (if (is n 0) (cons (fn () s) acc) (ts-cap (- n 1) (cons (fn () s) acc)))))
(assert "tail-self bail on capture"  (map (fn (g) (g)) (ts-cap 3 ()))   (list 0 1 2 3))
; And a let body that only EVAL_ASTs a NON-capturing builtin still computes right
; (whether it lands on TAIL_SELF or TAIL_CALL, the value must be correct at depth).
(def ts-eval (n acc) (let s (car (reverse (cons (+ acc 1) ()))) (if (is n 0) s (ts-eval (- n 1) s))))
(assert "tail-self w/ eval-ast body" (ts-eval 1000000 0)          1000001)

; 9. Phase-2 compiler — `with` (multi-binding).
(assert "with 2 bindings"            (with (a 3 b 4) (+ a b))     7)
(assert "with shadows"               (let a 1 (with (a 9) a))     9)
(assert "with multi-body"            (with (a 3 b 4) (+ a 1) (+ a b)) 7)

; 10. let + mutation: assign into let-bound slot, then read.
(assert "= into let slot"            (let c 10 (= c 20) c)        20)

; 10b. setf — exact synonym of = (symbol, place, let-slot, compiled body).
(assert "setf symbol"                (do (setf sf1 7) sf1)        7)
(assert "setf place car"             (do (setf sf2 (list 1 2)) (setf (car sf2) 9) sf2) (list 9 2))
(assert "setf into let slot"         (let c 10 (setf c 20) c)     20)
(def setf-acc (n a) (if (is n 0) a (do (setf a (+ a n)) (setf-acc (- n 1) a))))
(assert "setf compiled accumulator"  (setf-acc 100 0)             5050)

; 11. for compiled: body returns last expr of last iter; empty range
;     returns nil; sum via (= s (+ s i)).
(def lastsq (n) (for i 1 n (* i i)))
(assert "for returns last body val"  (lastsq 5)                   25)
(def forempty (n) (for i 5 1 (* n n)))
(assert "for empty range nil"        (forempty 7)                 nil)
(def fsum (n) (let s 0 (for i 1 n (= s (+ s i)))))
(assert "compiled fsum 10 -> 55"     (fsum 10)                    55)
(assert "compiled fsum 100 -> 5050"  (fsum 100)                   5050)

; 12. Phase-3: cross-function tail calls trampoline in the VM.
;     Mutual recursion between compiled functions runs in O(1) C stack.
(def even? (n) (if (< n 1) t    (odd? (- n 1))))
(def odd?  (n) (if (< n 1) nil  (even? (- n 1))))
(assert "mutual even? 1000"          (even? 1000)                 t)
(assert "mutual odd? 1001"           (odd? 1001)                  t)
(assert "mutual deep 100k"           (even? 100000)               t)

; 13. Phase-4 — list ops in VM (cons/car/cdr/list).
(def consit (a b) (cons a b))
(assert "vm cons returns pair"       (iso (consit 1 (list 2 3))
                                          (list 1 2 3))           t)
(def carit (xs) (car xs))
(def cdrit (xs) (cdr xs))
(assert "vm car"                     (carit (list 10 20 30))      10)
(assert "vm cdr iso"                 (iso (cdrit (list 10 20 30))
                                          (list 20 30))           t)
(def listit (a b c) (list a b (* c 2)))
(assert "vm list 3"                  (iso (listit 1 2 5)
                                          (list 1 2 10))          t)
(def myrev (xs acc)
  (if (no xs) acc (myrev (cdr xs) (cons (car xs) acc))))
(assert "vm tail-recursive reverse"  (iso (myrev (list 1 2 3 4 5) (list))
                                          (list 5 4 3 2 1))       t)

; 14. Phase-6: JIT tag-check + deopt. addone is JIT-eligible
;     ((fn (n) (+ n K)) shape). Calling with a fixnum hits the native
;     fast path; calling with a non-fixnum must NOT corrupt and must
;     let the next fixnum call still work (proves deopt -> vm_run -> recovery).
(def addone (n) (+ n 1))
(assert "JIT addone fix"             (addone 41)                   42)
(addone 'sym)                        ; deopt path; result discarded
(assert "JIT addone after deopt"     (addone 100)                  101)
(def idheap (x) x)
(assert "JIT identity heap string safe" (idheap "hello")            "hello")
(assert "JIT identity heap list safe"   (iso (idheap (list 1 2))
                                             (list 1 2))            t)
(def cdn (n) (if (> n 0) (cdn (- n 1)) n))
(assert "JIT loop fix to 0"          (cdn 1000)                    0)
(cdn 'sym)                           ; deopt at loop entry
(assert "JIT loop after deopt"       (cdn 500)                     0)
(def jitbuild (i n acc)
  (if (> i n) acc (jitbuild (+ i 1) n (cons i acc))))
(assert "JIT build inc cons"         (jitbuild 1 5 (list))         (list 5 4 3 2 1))
(assert "JIT build keeps acc"        (jitbuild 1 3 (list 'z))      (list 3 2 1 'z))

; 15. JIT generalized slot index — leaf op on the 2nd param (slot 1),
;     not just slot 0. Uses (+ b 1) so the body stays in the leaf-arith
;     shape but matches a non-zero slot.
(def addb (a b) (+ b 1))
(assert "JIT addb slot1 fix"         (addb 'ignored 41)            42)
(addb 0 'sym)                        ; deopt path on slot 1; result discarded
(assert "JIT addb slot1 after deopt" (addb 0 100)                  101)

; 16. JIT multiplication-by-constant leaf — (fn (n) (* n K)).
;     Tag arithmetic via (t-1)*K + 1; deopt on non-fixnum.
(def doublen (n) (* n 2))
(assert "JIT doublen fix"            (doublen 21)                  42)
(doublen 'sym)                       ; deopt; result discarded
(assert "JIT doublen after deopt"    (doublen 100)                 200)
(def triplen (n) (* n 3))
(assert "JIT triplen 0"              (triplen 0)                   0)
(assert "JIT triplen negative K"     ((fn (n) (* n -4)) 7)         -28)

; 17. JIT tail loop with one inner global call before the recurse.
;     New 26-byte shape (amd64 only for now): the (do (g K) (lp ...)) form
;     emits LOAD_FIX + CALL_GLOBAL + POP between the compare and the arith.
;     The inner fn is (+ x 1) rather than (x) x to dodge a pre-existing
;     alcove bug where (do (identity-fn ...) ...) returns nil.
(def addbump (x) (+ x 1))
(def lpcall (k) (if (> k 0) (do (addbump 99) (lpcall (- k 1))) k))
(assert "JIT loop+call to 0"         (lpcall 100)                  0)
(lpcall 'sym)                        ; deopt at loop entry; result discarded
(assert "JIT loop+call after deopt"  (lpcall 50)                   0)

; 18. JIT two-call non-tail recursion (the fib shape, amd64 only).
;     (def f (n) (if (cmp n K1) n (+ (g (op n K2)) (g (op n K3)))))
;     The new matcher generates ~190 bytes of native that does the base
;     case inline and only enters a frame for the recursive path.
;     Tag-checks each call return; non-fixnum bails through frame teardown.
(def jfib (n) (if (< n 2) n (+ (jfib (- n 1)) (jfib (- n 2)))))
(assert "JIT fib base 0"             (jfib 0)                      0)
(assert "JIT fib base 1"             (jfib 1)                      1)
(assert "JIT fib 10"                 (jfib 10)                     55)
(assert "JIT fib 20"                 (jfib 20)                     6765)
(assert "JIT fib 30"                 (jfib 30)                     832040)
(jfib 'sym)                          ; deopt at entry; result discarded
(assert "JIT fib after deopt"        (jfib 15)                     610)

; 19. Closures — fn captures the env at creation time; let-bound and
;     fn-param vars from the enclosing scope resolve correctly when
;     the closure is invoked later. Mutating closures (= on a captured
;     var) updates the captured slot, not a shadowing local.
(def make-adder (n) (fn (x) (+ x n)))
(= add5 (make-adder 5))
(= add10 (make-adder 10))
(assert "closure: add5 100"          (add5 100)                    105)
(assert "closure: add10 100"         (add10 100)                   110)
(def make-counter (dummy) (let n 0 (fn (d) (= n (+ n 1)))))
(= ca (make-counter 0))
(= cb (make-counter 0))
(ca 0) (ca 0) (ca 0)
(assert "closure: counter ca = 4"    (ca 0)                        4)
(assert "closure: counter cb = 1"    (cb 0)                        1)
(def f2 (n) (let m 10 (fn (d) (+ n m))))
(assert "closure: nested let cap"    ((f2 5) 0)                    15)

; 20. Zero-argument defs (was a pre-existing var2env bug — empty-params
;     loop entered once and errored on missing param).
(def zhello () (+ 1 2))
(assert "0-arg def returns 3"        (zhello)                      3)

; 20b. Mutating-free-var closures compile to bytecode (OP_STORE_FREE).
;      The canonical zero-arg make-counter: the inner (fn () (= n ...) n)
;      mutates a CAPTURED free var via `=`. This used to fall back to AST
;      (compile_assign failed on a non-slot target, and the empty-params
;      loop refused to compile 0-arg bodies at all). Now both compile.
(def mk-counter () (let n 0 (fn () (= n (+ n 1)) n)))
(= zc1 (mk-counter))
(= zc2 (mk-counter))
(zc1) (zc1)
(assert "0-arg closure counter zc1"  (zc1)                         3)
(assert "0-arg closure indep zc2"    (zc2)                         1)
; `=` to a global from inside a compiled fn (STORE_FREE walks to root).
(= gctr 0)
(def bump-g () (= gctr (+ gctr 1)) gctr)
(bump-g)
(assert "compiled = mutates global"  (bump-g)                      2)
(assert "global reflects mutation"   gctr                          2)
; setf alias takes the same compiled path.
(= gsf 10)
(def bump-sf () (setf gsf (+ gsf 5)) gsf)
(assert "compiled setf mutates global" (bump-sf)                   15)

; 20c. Closure↔env cycle reclamation (destroy_env self-cycle break).
;      These guard the cycle-collector: it MUST reclaim a local closure that
;      captures its frame and does not escape, but MUST NOT collect a closure
;      that was returned / stored — that would free a live env (UAF).
; (i) nested def + returned: muln is bound in make-mul's frame AND returned,
;     so the frame must stay alive (closure refcount > env's single ref).
(def make-mul (n) (do (def muln (x) (* x n)) muln))
(= m3 (make-mul 3))
(= m4 (make-mul 4))
(assert "cycle: nested-def closure m3" (m3 10)                    30)
(assert "cycle: nested-def closure m4" (m4 10)                    40)
(assert "cycle: m3 valid after m4"     (m3 5)                     15)
; (ii) stored globally, then exercised after heavy allocation churn that
;      would reuse a wrongly-freed arena slot — garbage/UAF if env was freed.
(= g-mul (make-mul 7))
(def churn (k) (if (is k 0) 0 (do (def tmp (x) (+ x 1)) (+ (tmp 1) (churn (- k 1))))))
(churn 50)
(assert "cycle: g-mul survives churn"  (g-mul 6)                  42)
; (iii) the churn closures themselves DO escape nowhere → frames reclaimed;
;       this asserts they still compute correctly (each tmp returns 2).
(assert "cycle: churn 5 = 10"          (churn 5)                  10)
; (iv) mutually-recursive LOCAL defs: both capture the frame, neither escapes
;      → cycle reclaimed after the call; must compute correctly DURING it.
(def parity (n) (do
  (def ev (k) (if (is k 0) t   (od (- k 1))))
  (def od (k) (if (is k 0) nil (ev (- k 1))))
  (ev n)))
(assert "cycle: local mutual even 10"  (parity 10)               t)
(refute "cycle: local mutual odd 7"    (parity 7)                t)
; (v) a macro defined INSIDE a function captures the frame like a closure
;     and was the same per-call-ref-leak class (invokemacro borrows fn,
;     consumes e). Exercise repeated definition+use; must stay correct.
(def usemac (k)
  (do (defmacro m1 (x) (list '+ x 1))
      (if (is k 0) 0 (+ (m1 k) (usemac (- k 1))))))
(assert "cycle: macro-in-fn usemac 4" (usemac 4)                 14)

; 20e. FFI (libffi) — guarded by (ffi?) so a no-libffi build skips the block
;      uniformly across all variants. Binds to alcove's own exported self-test
;      fixtures via the "" (process-self) library plus libc strlen, so no
;      external shared object is needed. Covers scalar calls, callbacks
;      (incl. a C loop, a double, and a closure), struct-by-value (pack/unpack,
;      arg, return), and the two main error paths.
(if (ffi?)
  (do
    (assert "ffi? true in this build"   (ffi?)                          t)
    (= ffi-add (ffi-fn "" "alc_ffi_selftest_add" "long" "long" "long"))
    (assert "ffi scalar self add"       (ffi-add 17 25)                 42)
    (= ffi-slen (ffi-fn "" "strlen" "long" "string"))
    (assert "ffi libc strlen"           (ffi-slen "hello")              5)
    (= ffi-ap2 (ffi-fn "" "alc_ffi_selftest_apply2" "long" "ptr" "long" "long"))
    (= ffi-mul-cb (ffi-callback "long" (list "long" "long") (fn (a b) (* a b))))
    (assert "ffi callback mul"          (ffi-ap2 ffi-mul-cb 6 7)        42)
    (= ffi-sm (ffi-fn "" "alc_ffi_selftest_sum_map" "long" "ptr" "long"))
    (= ffi-sq-cb (ffi-callback "long" (list "long") (fn (x) (* x x))))
    (assert "ffi callback in C loop"    (ffi-sm ffi-sq-cb 10)           285)
    (= ffi-bias 1000)
    (= ffi-bias-cb (ffi-callback "long" (list "long") (fn (x) (+ x ffi-bias))))
    (assert "ffi closure callback"      (ffi-sm ffi-bias-cb 3)          3003)
    (= ffi-apd (ffi-fn "" "alc_ffi_selftest_apply_d" "double" "ptr" "double"))
    (= ffi-dbl-cb (ffi-callback "double" (list "double") (fn (x) (* x 2.0))))
    (assert "ffi double callback"       (ffi-apd ffi-dbl-cb 20.5)       41.0)
    (= FP (ffi-struct "double" "double"))
    (assert "ffi struct pack/unpack"    (ffi-unpack FP (ffi-pack FP 7.5 8.5))
                                        (list 7.5 8.5))
    (= ffi-n2 (ffi-fn "" "alc_ffi_selftest_pt_norm2" "double" FP))
    (assert "ffi struct-by-value arg"   (ffi-n2 (ffi-pack FP 3.0 4.0))  25.0)
    (= ffi-mk (ffi-fn "" "alc_ffi_selftest_pt_make" FP "double" "double"))
    (assert "ffi struct-by-value ret"   (ffi-unpack FP (ffi-mk 5.0 6.0))
                                        (list 5.0 6.0))
    ; nested struct (struct field inside a struct)
    (= FSEG (ffi-struct FP FP))
    (= ffi-seglen (ffi-fn "" "alc_ffi_selftest_seg_len2" "double" FSEG))
    (assert "ffi nested struct arg"
            (ffi-seglen (ffi-pack FSEG (ffi-pack FP 0.0 0.0) (ffi-pack FP 3.0 4.0)))
            25.0)
    (assert "ffi nested struct unpack"
            (ffi-unpack FP (car (cdr (ffi-unpack FSEG
              (ffi-pack FSEG (ffi-pack FP 1.0 1.0) (ffi-pack FP 4.0 5.0))))))
            (list 4.0 5.0))
    (assert "ffi unknown symbol errors"
            (try (ffi-fn "" "no_such_sym_xyzzy" "long") (fn (e) 'caught)) 'caught)
    (assert "ffi unknown type errors"
            (try (ffi-fn "" "alc_ffi_selftest_add" "frob" "long") (fn (e) 'caught))
            'caught)
    ; variadic (ffi-vfn): fixed count arg + inferred variadic tail
    (= ffi-vsum (ffi-vfn "" "alc_ffi_selftest_vsum" "long" "int"))
    (assert "ffi varargs long sum"      (ffi-vsum 3 10 20 12)           42)
    (assert "ffi varargs zero tail"     (ffi-vsum 0)                    0)
    (= ffi-vsumd (ffi-vfn "" "alc_ffi_selftest_vsumd" "double" "int"))
    (assert "ffi varargs double sum"    (ffi-vsumd 3 1.5 2.5 4.0)       8.0)
    (assert "ffi varargs too few errors"
            (try (ffi-vsum) (fn (e) 'caught))                           'caught)
    nil))

; 20f. Persistent map (HAMT) — immutable map with structural sharing.
;      assoc/dissoc return new maps; the original is never mutated.
(= hm (hamt "a" 1 "b" 2 "c" 3))
(assert "hamt count"               (hamt-count hm)                       3)
(assert "hamt get present"         (hamt-get hm "b")                     2)
(assert "hamt get absent nil"      (hamt-get hm "z")                     nil)
(assert "hamt get default"         (hamt-get hm "z" 99)                  99)
(assert "hamt contains? yes"       (hamt-contains? hm "a")               t)
(refute "hamt contains? no"        (hamt-contains? hm "z")               t)
(assert "hamt? yes"                (hamt? hm)                            t)
(refute "hamt? no"                 (hamt? 5)                             t)
(assert "hamt? empty map"          (hamt? (hamt))                        t)
(assert "hamt empty count"         (hamt-count (hamt))                   0)
; immutability: assoc returns a new map; hm stays put
(= hm2 (hamt-assoc hm "d" 4))
(assert "hamt assoc new count"     (hamt-count hm2)                      4)
(assert "hamt orig count unchanged"(hamt-count hm)                       3)
(assert "hamt assoc get new"       (hamt-get hm2 "d")                    4)
(assert "hamt orig lacks new key"  (hamt-get hm "d")                     nil)
(assert "hamt overwrite value"     (hamt-get (hamt-assoc hm "a" 100) "a")  100)
(assert "hamt orig after overwrite"(hamt-get hm "a")                     1)
; dissoc
(= hm3 (hamt-dissoc hm "b"))
(assert "hamt dissoc count"        (hamt-count hm3)                      2)
(assert "hamt dissoc removed"      (hamt-get hm3 "b")                    nil)
(assert "hamt orig after dissoc"   (hamt-get hm "b")                     2)
(assert "hamt dissoc absent noop"  (hamt-count (hamt-dissoc hm "zzz"))   3)
; mixed key types (int / symbol / string)
(= hmix (hamt 1 'one 'two 2 "s" 3))
(assert "hamt int key"             (hamt-get hmix 1)                     'one)
(assert "hamt symbol key"          (hamt-get hmix 'two)                  2)
(assert "hamt string key"          (hamt-get hmix "s")                   3)
; scale: many inserts force trie depth and structural sharing
(= hbig (hamt))
(= _hi 0)
(while (< _hi 300) (do (= hbig (hamt-assoc hbig _hi (* _hi _hi))) (= _hi (+ _hi 1))))
(assert "hamt big count"           (hamt-count hbig)                     300)
(assert "hamt big lookup mid"      (hamt-get hbig 250)                   62500)
(assert "hamt big lookup absent"   (hamt-get hbig 999)                   nil)
(assert "hamt keys length"         (length (hamt-keys hm))               3)
(assert "hamt vals length"         (length (hamt-vals hm))               3)
(assert "hamt->list length (flat)" (length (hamt->list hm))              6)
(assert "hamt-get non-hamt errors" (try (hamt-get 5 "x") (fn (e) 'caught)) 'caught)
; merge: b's value wins on shared keys; a and b unchanged
(= hma (hamt "x" 1 "y" 2))
(= hmb (hamt "y" 20 "z" 30))
(= hmg (hamt-merge hma hmb))
(assert "hamt-merge count"         (hamt-count hmg)                      3)
(assert "hamt-merge b wins"        (hamt-get hmg "y")                    20)
(assert "hamt-merge keeps a-only"  (hamt-get hmg "x")                    1)
(assert "hamt-merge adds b-only"   (hamt-get hmg "z")                    30)
(assert "hamt-merge a unchanged"   (hamt-get hma "y")                    2)
(assert "hamt-merge empty rhs"     (hamt-count (hamt-merge hma (hamt)))  2)
; deep iso equality — order-independent, by content (is stays identity)
(assert "hamt iso same diff-order" (iso (hamt "a" 1 "b" 2) (hamt "b" 2 "a" 1)) t)
(refute "hamt iso diff value"      (iso (hamt "a" 1) (hamt "a" 2))       t)
(refute "hamt iso diff count"      (iso (hamt "a" 1) (hamt "a" 1 "b" 2)) t)
(assert "hamt iso empty"           (iso (hamt) (hamt))                   t)
(assert "hamt iso after assoc"     (iso (hamt-assoc (hamt "a" 1) "b" 2)
                                        (hamt "a" 1 "b" 2))              t)
(assert "hamt iso deep value"      (iso (hamt "k" (list 1 2)) (hamt "k" (list 1 2))) t)
(refute "hamt is is identity"      (is (hamt "a" 1) (hamt "a" 1))        t)

; 20g. Escape continuations (call/cc) — one-shot, upward (escape-only).
(assert "call/cc no escape"        (call/cc (fn (k) (+ 1 2)))            3)
(assert "call/cc escape value"     (call/cc (fn (k) (k 42) 999))         42)
(assert "call/cc escape skips"     (call/cc (fn (k) (+ 1 (k 100) 2)))    100)
(assert "call/cc escape 0"         (call/cc (fn (k) (k 0)))              0)
(assert "call/cc escape nil"       (call/cc (fn (k) (k nil)))            nil)
(assert "call/cc escape in tail"   (call/cc (fn (k) (k 7)))              7)
; early return from a while loop (exercises while error/escape propagation)
(assert "call/cc loop early-exit"
  (call/cc (fn (return)
    (do (= _cci 0)
        (while (< _cci 100)
          (do (if (> (* _cci _cci) 50) (return _cci)) (= _cci (+ _cci 1)))) -1)))
  8)
; escape out of recursion
(def _ccprod (xs f)
  (if (no xs) 1 (if (is (car xs) 0) (f 0) (* (car xs) (_ccprod (cdr xs) f)))))
(assert "call/cc escape recursion" (call/cc (fn (k) (_ccprod '(1 2 0 4 5) k)))  0)
(assert "call/cc product no escape"(call/cc (fn (k) (_ccprod '(1 2 3 4) k)))    24)
; escape from inside a HOF (map)
(assert "call/cc escape from map"  (call/cc (fn (k) (map (fn (x) (k x)) '(5 6 7))))  5)
; escape via a closure that captures k and is invoked deep in
(assert "call/cc closure escape"
  (call/cc (fn (k) (_ccprod '(1 0 9) (fn (v) (k 77)))))  77)
; double call/cc: invoking the OUTER k from inside the inner one
(assert "call/cc nested outer"
  (call/cc (fn (k) (+ 1 (call/cc (fn (j) (k 99))))))  99)
(assert "call/cc bad arg errors"   (try (call/cc 5) (fn (e) 'caught))    'caught)
; regression: a compiled fn tail-calling a CLOSURE must resolve the closure's
; captured free vars from its captured env (not the caller's frame).
(def _mkadd (n) (fn (x) (+ x n)))
(def _applyit (g) (g 5))
(assert "closure tail-call captures" (_applyit (_mkadd 100))             105)

; 20h. call/cc idioms — exercise the common real-world patterns.
; (a) find-first: early return from a recursive walk
(def _cc_find (pred xs)
  (call/cc (fn (return)
    (do (def go (ys) (if (no ys) nil
                       (if (pred ys) (return (car ys)) (go (cdr ys)))))
        (go xs)))))
(assert "cc find-first hit"   (_cc_find (fn (l) (> (car l) 3)) '(1 2 5 0 9))  5)
(assert "cc find-first miss"  (_cc_find (fn (l) (> (car l) 99)) '(1 2 3))     nil)
; (b) exception-like: escape with an error marker
(def _cc_sdiv (a b k) (if (is b 0) (k 'div0) (/ a b)))
(assert "cc safe-div ok"      (call/cc (fn (k) (_cc_sdiv 10 2 k)))            5)
(assert "cc safe-div bail"    (call/cc (fn (k) (_cc_sdiv 10 0 k)))           'div0)
; (c) break out of a NESTED loop, returning a structured payload
(def _cc_pair (n target)
  (call/cc (fn (found)
    (do (= _i 1)
        (while (<= _i n)
          (do (= _j 1)
              (while (<= _j n)
                (do (if (is (+ _i _j) target) (found (list _i _j))) (= _j (+ _j 1))))
              (= _i (+ _i 1)))) nil))))
(assert "cc nested-loop break" (_cc_pair 5 7)                            (list 2 5))
; (d) guard / early-return clamp
(def _cc_clamp (x lo hi)
  (call/cc (fn (ret) (do (if (< x lo) (ret lo)) (if (> x hi) (ret hi)) x))))
(assert "cc clamp mid"  (_cc_clamp 5 0 10)   5)
(assert "cc clamp low"  (_cc_clamp -3 0 10)  0)
(assert "cc clamp high" (_cc_clamp 99 0 10)  10)
; (e) accumulate but bail to 0 on a negative element
(def _cc_sumnn (xs)
  (call/cc (fn (bail)
    (do (def go (ys acc) (if (no ys) acc
          (if (< (car ys) 0) (bail 0) (go (cdr ys) (+ acc (car ys))))))
        (go xs 0)))))
(assert "cc sum nonneg ok"   (_cc_sumnn '(3 4 5))    12)
(assert "cc sum nonneg bail" (_cc_sumnn '(3 -1 5))   0)
; (f) nested call/cc: inner body can fire the inner OR the outer k
(assert "cc nested outer"  (call/cc (fn (o) (+ 1 (call/cc (fn (i) (o 100))))))  100)
(assert "cc nested inner"  (call/cc (fn (o) (+ 1 (call/cc (fn (i) (i 100))))))  101)
; (g) escape from inside map; structured payload
(assert "cc escape from map" (call/cc (fn (k) (do (map (fn (x) (if (> x 2) (k x))) '(1 2 3 4)) -1)))  3)
(assert "cc payload list"    (call/cc (fn (k) (k (list 1 2 3))))   (list 1 2 3))
(assert "cc ignored k"       (call/cc (fn (k) (* 6 7)))            42)

; 20h-defc. `defc` sugars (def name params (call/cc (fn (return) body...))) —
; re-implements the §20h idioms with `return` as the escape continuation and
; asserts identical results, proving the expansion.
(defc dc-clamp (x lo hi)
  (if (< x lo) (return lo))
  (if (> x hi) (return hi))
  x)
(assert "defc clamp mid"        (dc-clamp 5 0 10)                  5)
(assert "defc clamp low"        (dc-clamp -3 0 10)                 0)
(assert "defc clamp high"       (dc-clamp 99 0 10)                 10)
(defc dc-find (pred xs)
  (each x xs (if (pred x) (return x)))
  nil)
(assert "defc find hit"         (dc-find (fn (n) (> n 3)) (list 1 2 5 0 9))  5)
(assert "defc find miss"        (dc-find (fn (n) (> n 99)) (list 1 2 3))     nil)
(defc dc-sumnn (xs)
  (let s 0 (do (each x xs (if (< x 0) (return 0)) (= s (+ s x))) s)))
(assert "defc sum nonneg ok"    (dc-sumnn (list 3 4 5))            12)
(assert "defc sum nonneg bail"  (dc-sumnn (list 3 -1 5))           0)
(defc dc-noesc (x) (+ x 1))                          ; no escape → falls through
(assert "defc no escape"        (dc-noesc 10)                      11)
(defc dc-zero (n) (if (is n 0) (return 0)) (* n n))  ; escape with falsy 0
(assert "defc return 0 (falsy)" (dc-zero 0)                        0)
(assert "defc no-return path"   (dc-zero 4)                        16)
(defc dc-nil () (return nil))
(assert "defc return nil"       (dc-nil)                           nil)
(defc dc-rest xs (return (length xs)))               ; rest-param form like def
(assert "defc rest-param"       (dc-rest 1 2 3)                    3)

; 20i. MessagePack codec — round-trip the JSON-ish value subset.
(assert "msgpack int"        (msgpack-decode (msgpack-encode 42))         42)
(assert "msgpack neg fixint" (msgpack-decode (msgpack-encode -5))         -5)
(assert "msgpack int16"      (msgpack-decode (msgpack-encode -1000))      -1000)
(assert "msgpack uint32"     (msgpack-decode (msgpack-encode 1000000000)) 1000000000)
(assert "msgpack int64"      (msgpack-decode (msgpack-encode 5000000000)) 5000000000)
(assert "msgpack float"      (msgpack-decode (msgpack-encode 3.14))       3.14)
(assert "msgpack nil"        (msgpack-decode (msgpack-encode nil))        nil)
(assert "msgpack true"       (msgpack-decode (msgpack-encode t))          t)
(assert "msgpack fixstr"     (msgpack-decode (msgpack-encode "hello"))    "hello")
(assert "msgpack empty str"  (msgpack-decode (msgpack-encode ""))         "")
(assert "msgpack str8 path"
  (msgpack-decode (msgpack-encode "0123456789012345678901234567890123456789"))
  "0123456789012345678901234567890123456789")
(assert "msgpack char->int"  (msgpack-decode (msgpack-encode #\A))        65)
(assert "msgpack list"       (iso (msgpack-decode (msgpack-encode (list 1 2 3))) (list 1 2 3)) t)
(assert "msgpack list mixed" (iso (msgpack-decode (msgpack-encode (list 1 "a" nil t))) (list 1 "a" nil t)) t)
(assert "msgpack nested"     (iso (msgpack-decode (msgpack-encode (list 1 (list 2 3) "x"))) (list 1 (list 2 3) "x")) t)
(assert "msgpack blob"       (iso (msgpack-decode (msgpack-encode (string->blob "ab"))) (string->blob "ab")) t)
(= _mpd (msgpack-decode (msgpack-encode (hash-map "a" 1 "b" 2))))
(assert "msgpack dict get a" (get _mpd "a")                              1)
(assert "msgpack dict get b" (get _mpd "b")                              2)
(assert "msgpack decode bad" (try (msgpack-decode (string->blob "\xc1")) (fn (e) 'caught)) 'caught)
(assert "msgpack decode trailing" (try (msgpack-decode (string->blob "\x01\x02")) (fn (e) 'caught)) 'caught)
(assert "msgpack encode bad" (try (msgpack-encode (fn (x) x)) (fn (e) 'caught)) 'caught)
(assert "msgpack decode non-blob" (try (msgpack-decode 5) (fn (e) 'caught)) 'caught)

; 21. Stdlib additions: math, seq, predicates, HOFs.
(assert "mod 17 5"                   (mod 17 5)                    2)
(assert "abs -42"                    (abs -42)                     42)
(assert "max 1 5 3"                  (max 1 5 3)                   5)
(assert "min 1 5 -2"                 (min 1 5 -2)                  -2)
(assert "length list"                (length (list 1 2 3 4 5))     5)
(assert "nth 2 list"                 (nth 2 (list 10 20 30 40))    30)
(assert "reverse"                    (iso (reverse (list 1 2 3))
                                          (list 3 2 1))            t)
(assert "append two lists"           (iso (append (list 1 2) (list 3 4))
                                          (list 1 2 3 4))          t)
(assert "number? fixnum"             (number? 42)                  t)
(assert "string? \"hi\""             (string? "hi")                t)
(assert "symbol? 'a"                 (symbol? (quote a))           t)
(assert "pair? list"                 (pair? (list 1 2))            t)
(assert "fn? lambda"                 (fn? (fn (x) x))              t)
(assert "fn? builtin"                (fn? +)                       t)
(assert "fn? non-fn"                 (fn? 42)                      nil)
(assert "map square"                 (iso (map (fn (x) (* x x)) (list 1 2 3))
                                          (list 1 4 9))            t)
(assert "filter > 2"                 (iso (filter (fn (x) (> x 2)) (list 1 2 3 4))
                                          (list 3 4))              t)
(assert "reduce sum"                 (reduce (fn (a b) (+ a b)) 0 (list 1 2 3 4 5))  15)
(assert "apply 3 args"               (apply (fn (a b c) (+ a (+ b c))) (list 10 20 30))  60)

; 22. any? / all? — predicate-walks via vm_invoke_values.
;     The closure-in-recursion fix means (any? (fn (d) ...) ...)
;     inside a recursive function now works correctly.
(assert "any? has match"             (any? (fn (x) (> x 3)) (list 1 2 3 4))  t)
(assert "any? no match"              (any? (fn (x) (> x 100)) (list 1 2 3))  nil)
(assert "any? empty"                 (any? (fn (x) (> x 0)) (list))           nil)
(assert "all? all match"             (all? (fn (x) (> x 0)) (list 1 2 3))     t)
(assert "all? one fails"             (all? (fn (x) (> x 0)) (list 1 0 3))     nil)
(assert "all? empty"                 (all? (fn (x) (> x 0)) (list))           t)
; Closure-in-recursion: this used to break before the var2env-via-caller-env fix.
(def jit-sieve-fn (i n)
  (def jit-sieve-up (j acc)
    (if (> j n) acc
        (if (any? (fn (d) (is (mod j d) 0)) acc)
            (jit-sieve-up (+ j 1) acc)
            (jit-sieve-up (+ j 1) (cons j acc)))))
  (length (jit-sieve-up i (list))))
(assert "any?-in-recursion: π(100)" (jit-sieve-fn 2 100) 25)

; if is cond-style: (if c1 t1 c2 t2 ... else)
(assert "if cond-style: 1st clause"  (if t 'a 'b 'c)              'a)
(assert "if cond-style: 2nd clause"  (if nil 'a t 'b 'c)           'b)
(assert "if cond-style: fallback"    (if nil 'a nil 'b 'c)         'c)
(assert "if 2-arg true"              (if 1 'yes)                   'yes)
(assert "if 2-arg false -> nil"      (if nil 'yes)                 nil)
(def compiled-if-ladder (x)
  (if (is x 1) 'one (is x 2) 'two 'other))
(assert "compiled if cond-style: 1st clause" (compiled-if-ladder 1) 'one)
(assert "compiled if cond-style: 2nd clause" (compiled-if-ladder 2) 'two)
(assert "compiled if cond-style: fallback"   (compiled-if-ladder 3) 'other)

; Ticket 1 regression: (= (s i) c) must accept a computed index, not just a literal
(= sbuf "abcdef")
(= i 2)
(= (sbuf i) #\Z)
(assert "string-set with var index"   sbuf "abZdef")

; The 6 list builtins must reject non-list args cleanly (no segfault)
; — the assertion infra needs a value; we use the fact that all six errors
;   propagate as exp_t* which iso-compares as nil-equal-nil:
(assert "nth on non-list -> nil-ish"  (no (no (nth 0 5)))            nil)

; Ticket 5: (s i) where s is a variable bound to a string
(= sread "abcdef")
(assert "string read by var, literal idx"  (sread 2)              #\c)
(= ridx 4)
(assert "string read by var, computed idx" (sread ridx)           #\e)
(def sget (s n) (s n))
(assert "string read inside def body"      (sget "hello" 1)       #\e)

;; ---------- inline-text optimization boundary (FLAG_INLINE_TXT) ----------
;; Symbols/strings up to 7 chars store their bytes inline in the exp_t union
;; (no heap alloc); 8+ chars fall back to the heap. Both sides must behave
;; identically — these exercise the inline/heap boundary for equality,
;; length, comparison, mutation, and use as dict/set keys.
(assert "inline str 7 chars eq"        "abcdefg"                    "abcdefg")
(assert "heap str 8 chars eq"          "abcdefgh"                   "abcdefgh")
(assert "inline str length"            (length "abcdefg")           7)
(assert "heap str length"              (length "abcdefgh")          8)
(assert "inline/heap concat"           (string-append "abcdefg" "h") "abcdefgh")
(assert "inline str index mutate"      (let s "hello" (= (s 0) #\J) s) "Jello")
(assert "inline sym eq self"           (is 'abcdefg 'abcdefg)       t)
(assert "heap sym eq self"             (is 'abcdefgh 'abcdefgh)     t)
(assert "inline vs heap sym differ"    (is 'abcdefg 'abcdefgh)      nil)
(assert "inline keyword self-eval"     :short                       :short)
;; A keyword as the value/return of a COMPILED body must self-evaluate, not be
;; looked up as a variable (the compiler now mirrors evaluate()'s keyword arm).
(assert "keyword as compiled body"     ((fn () :hello))             :hello)
(assert "keyword as fn return tail"    ((fn () (+ 1 1) :done))      :done)
(assert "keyword in if branch (fn)"    ((fn (x) (if x :yes :no)) 1) :yes)
(assert "inline str as set key"        (set-has? (set "k" "kk") "k") t)
(assert "inline keyword as set key"    (set-has? (set :a :bb) :a)    t)
(assert "empty inline string length"   (length "")                  0)
(assert "empty inline string eq"       ""                           "")

;; ---------- introspection builtins (lock in compile/JIT/inline optims) ----------
;; These return real values (not printed) so regressions in the bytecode
;; compiler, JIT, or inline-text optimization fail the suite loudly.
(assert "inline? short symbol"         (inline? 'abc)               t)
(assert "inline? 7-char boundary"      (inline? 'abcdefg)           t)
(assert "inline? 8-char is heap"       (inline? 'abcdefgh)          nil)
(assert "inline? short string"         (inline? "hi")               t)
(assert "inline? tagged immediate"     (inline? 42)                 nil)
(assert "exp-flags inline bit (64)"    (exp-flags 'abc)             64)
(assert "exp-flags heap sym (0)"       (exp-flags 'abcdefgh)        0)
;; compilation regression — simple, 0-arg, and mutating-free-var closures
;; must all compile to bytecode (the OP_STORE_FREE / 0-arg-params work).
(def itest-add (x) (+ x 1))
(assert "compiled? simple fn"          (compiled? itest-add)        t)
(def itest-zero () 5)
(assert "compiled? 0-arg fn"           (compiled? itest-zero)       t)
(def itest-mk () (let n 0 (fn () (= n (+ n 1)) n)))
(assert "compiled? mutating closure"   (compiled? (itest-mk))       t)
;; rest-param fns intentionally fall back to AST — documents the boundary.
(def itest-rest xs (car xs))
(assert "compiled? rest-param is nil"  (compiled? itest-rest)       nil)
(assert "compiled? non-fn is nil"      (compiled? 42)               nil)
(assert "jit? non-fn is nil"           (jit? 42)                    nil)
;; Build-independent invariant: native code only exists for compiled bodies.
(assert "jit? implies compiled?"       (if (jit? itest-add) (compiled? itest-add) t) t)

;; ---------- JIT shape coverage (catches silent JIT regressions) ----------
;; Every body shape the JIT is supposed to recognize is exercised here, so a
;; matcher that silently stops firing (e.g. the for_loop_inc / forsum break
;; when commit 997ffbb grew the let/for binds to OP_BIND_SLOT_NAMED) fails the
;; suite instead of only showing up as a benchmark slowdown. The check is
;; build-independent: `itest-add` (a leaf `(+ x 1)`) JITs iff this is a JIT
;; build, so _jit_on gates the expectation — in a non-JIT variant every
;; (jit? f) is nil and the implication holds trivially, keeping the assert
;; count identical across all variants. assert-jits asserts the right
;; expectation for the current build; the r:* asserts below pin the results
;; (the JIT must match the VM exactly, in every build).
(= _jit_on (jit? itest-add))
(def assert-jits (label f) (assert label (if _jit_on (jit? f) (no (jit? f))) t))
;; leaf shapes
(def jc-const () 42)
(def jc-add (s) (+ s 7))
(def jc-mul (s) (* s 7))
;; self-tail counter loops — all four compares, count up (wide tagged limit,
;; exercises the materialize-limit-in-reg path) and down, plus `is`.
(def jc-lt (n) (if (< n 1000) (jc-lt (+ n 1)) n))
(def jc-le (n) (if (<= n 1000) (jc-le (+ n 1)) n))
(def jc-gt (n) (if (> n 0) (jc-gt (- n 1)) n))
(def jc-ge (n) (if (>= n 1) (jc-ge (- n 1)) n))
;; equality-base tail loop — `(is n K)` base in THEN, recurse in ELSE: the
;; swapped-polarity twin of jc-gt, JIT'd by try_jit_simple_tail_loop_eq.
(def jc-eqcd (n) (if (is n 0) n (jc-eqcd (- n 1))))
;; count-up equality variant: ADD step, non-zero target.
(def jc-equp (n) (if (is n 100) n (jc-equp (+ n 5))))
;; counter loop whose limit exceeds i16 -> generic-compare triple, JIT'd by
;; try_jit_wide_counter_loop (not the fused simple_tail_loop shape).
(def jc-wide (n) (if (< n 5000000) (jc-wide (+ n 1)) n))
;; recursion shapes
(def jc-fact (n) (if (< n 2) 1 (* n (jc-fact (- n 1)))))
(def jc-fib (n) (if (< n 2) n (+ (jc-fib (- n 1)) (jc-fib (- n 2)))))
(def jc-ack (m n) (if (is m 0) (+ n 1)
                      (if (is n 0) (jc-ack (- m 1) 1)
                          (jc-ack (- m 1) (jc-ack m (- n 1))))))
(def jc-tak (x y z) (if (no (< y x)) z
                        (jc-tak (jc-tak (- x 1) y z) (jc-tak (- y 1) z x)
                                (jc-tak (- z 1) x y))))
;; loop with one inner global call (fact-wrapper shape)
(def jc-loopcall (k) (if (> k 0) (do (jc-fact 19) (jc-loopcall (- k 1))) k))
;; for-loop accumulator (the shape that regressed — see for_loop_inc)
(def jc-forsum (n) (let s 0 (for i 1 n (= s (+ s 1)))))
;; cons-builder (listsum) + sieve + nqueens + divides? + float-accumulator
(def jc-build (i n acc) (if (> i n) acc (jc-build (+ i 1) n (cons i acc))))
(def jc-markfrom (step j n marks)
  (if (> j n) nil (do (vec-set! marks j nil) (jc-markfrom step (+ j step) n marks))))
(def jc-countprimes (i n marks acc)
  (if (> i n) acc (jc-countprimes (+ i 1) n marks (if (vec-ref marks i) (+ acc 1) acc))))
(def jc-isprime (acc i)
  (if (no acc) t (if (is (mod i (car acc)) 0) nil (jc-isprime (cdr acc) i))))
;; predicate-gated cons loop (sieve driver): counter loop that calls a global
;; predicate each step and conses i onto acc when true. JIT'd via a trampoline
;; to the C kernel jit_predicate_cons_loop.
(def jc-primes (i n acc)
  (if (> i n) acc
      (if (jc-isprime acc i)
          (jc-primes (+ i 1) n (cons i acc))
          (jc-primes (+ i 1) n acc))))
(def jc-safe (c qs offset)
  (if (no qs) t (if (is c (car qs)) nil (if (is (+ c offset) (car qs)) nil
                    (if (is (- c offset) (car qs)) nil (jc-safe c (cdr qs) (+ offset 1)))))))
(def jc-divides (a b) (is (mod a b) 0))
(def jc-facc-add (n acc) (if (< n 100000) (jc-facc-add (+ n 1) (+ acc 0.5)) acc))
(def jc-facc-sub (n acc) (if (< n 100000) (jc-facc-sub (+ n 1) (- acc 0.5)) acc))
(def jc-facc-mul (n acc) (if (< n 40000)  (jc-facc-mul (+ n 1) (* acc 2.0)) acc))
(assert-jits "jit leaf: (fn () K)"        jc-const)
(assert-jits "jit leaf: (+ s K)"          jc-add)
(assert-jits "jit leaf: (* s K)"          jc-mul)
(assert-jits "jit loop: < (wide limit)"   jc-lt)
(assert-jits "jit loop: <= (wide limit)"  jc-le)
(assert-jits "jit loop: > countdown"      jc-gt)
(assert-jits "jit loop: >= countdown"     jc-ge)
(assert-jits "jit loop: is-base countdown" jc-eqcd)
(assert-jits "jit loop: is-base count-up"  jc-equp)
(assert-jits "jit loop: wide (>i16) limit" jc-wide)
(assert-jits "jit recurse: fact"          jc-fact)
(assert-jits "jit recurse: fib"           jc-fib)
(assert-jits "jit recurse: ackermann"     jc-ack)
(assert-jits "jit recurse: tak"           jc-tak)
(assert-jits "jit loop + inner call"      jc-loopcall)
(assert-jits "jit for-loop (forsum)"      jc-forsum)
(assert-jits "jit cons-builder (listsum)" jc-build)
(assert-jits "jit sieve: mark-from"       jc-markfrom)
(assert-jits "jit sieve: count-primes"    jc-countprimes)
(assert-jits "jit sieve: is-prime-given"  jc-isprime)
(assert-jits "jit predicate-cons loop"    jc-primes)
(assert-jits "jit nqueens: safe?"         jc-safe)
(assert-jits "jit divides? (mod leaf)"    jc-divides)
(assert-jits "jit float-acc: +"           jc-facc-add)
(assert-jits "jit float-acc: -"           jc-facc-sub)
(assert-jits "jit float-acc: *"           jc-facc-mul)
;; result correctness — the JIT (when on) must match the VM byte-for-byte.
(assert "jit loop < result"            (jc-lt 0)             1000)
(assert "jit wide-limit loop result"   (jc-wide 4999990)     5000000)
(assert "jit countdown result"         (jc-gt 1000000)       0)
(assert "jit is-base countdown result" (jc-eqcd 1000000)     0)
(assert "jit is-base count-up result"  (jc-equp 0)           100)
(assert "jit fact result"              (jc-fact 10)          3628800)
(assert "jit forsum result"            (jc-forsum 100000)    100000)
(assert "jit listsum-builder length"   (length (jc-build 1 50 (list)))  50)
(assert "jit predicate-cons result"    (length (jc-primes 2 50 (list)))  15)
(assert "jit float-acc result"         (jc-facc-add 0 0.0)   50000.0)
(assert "jit float-acc is float"       (iso (jc-facc-add 0 0) 50000.0)  t)
(assert "jit float-acc 0-iter int"     (iso (jc-facc-add 200000 7) 7)   t)
;; start the counter near the limit so a known, finite count of *2.0 runs
;; (the full loop would be 2.0^40000 = inf — the limit is iterations, not exp).
(assert "jit float-acc mul (2 iters)"  (jc-facc-mul 39998 1.0)  4.0)

;; ---------- string utilities ----------
(assert "str concatenates values"      (str "a" 12 'b #\c)         "a12bc")
(assert "string-append"                (string-append "ab" "cd" "") "abcd")
(assert "substr middle"                (substr "abcdef" 1 4)       "bcd")
(assert "substr clamps bounds"         (substr "abc" -4 99)        "abc")
(assert "string-split literal"         (iso (string-split "a,b,c" ",")
                                            (list "a" "b" "c"))   t)
(assert "string-split empty sep"       (iso (string-split "abc" "")
                                            (list "a" "b" "c"))   t)
(assert "string-join"                  (string-join (list "a" "b" "c") ":") "a:b:c")
(assert "string-trim"                  (string-trim " \t hi \n")  "hi")
(assert "string-upcase"                (string-upcase "aBc9")      "ABC9")
(assert "string-downcase"              (string-downcase "aBc9")    "abc9")

;; ---------- UTF-8: strings index/measure by codepoint, not byte ----------
(assert "utf8 length 2-byte"           (length "héllo")            5)
(assert "utf8 length 3-byte CJK"       (length "你好世界")          4)
(assert "utf8 length 4-byte emoji"     (length "a😀b")             3)
(assert "utf8 length mixed"            (length "héllo世界😀")       8)
(assert "utf8 index ascii head"        (is ("héllo" 0) #\h)        t)
(assert "utf8 index 2-byte cp"         (is ("héllo" 1) #\é)        t)
(assert "utf8 index past 2-byte"       (is ("héllo" 4) #\o)        t)
(assert "utf8 index 3-byte cp"         (is ("你好世界" 2) #\世)     t)
(assert "utf8 index 4-byte cp"         (is ("a😀b" 1) #\😀)        t)
(assert "utf8 index out of range"      (error? ("héllo" 5))        t)
(assert "utf8 substr by codepoint"     (substr "héllo" 1 4)        "éll")
(assert "utf8 substr CJK"              (substr "你好世界" 1 3)      "好世")
(assert "utf8 string-index codepoint"  (string-index "héllo" "llo") 2)
(assert "utf8 split empty by cp"       (iso (string-split "a世b" "")
                                            (list "a" "世" "b"))   t)
(assert "utf8 char literal iso"        (iso #\é #\é)               t)
(assert "utf8 char->str 2-byte"        (str #\é)                   "é")
(assert "utf8 char->str 4-byte"        (str #\😀)                  "😀")
(assert "utf8 char code preserved"     (is (- #\世 #\世) 0)        t)
;; index-assign: replacing a 2-byte codepoint with a 1-byte one rebuilds
(= u8mut "héllo")
(= (u8mut 1) #\X)
(assert "utf8 index-set narrows"       u8mut                       "hXllo")
(assert "utf8 index-set keeps length"  (length u8mut)              5)
;; index-assign the other way: 1-byte -> 3-byte widens the buffer
(= u8wide "abc")
(= (u8wide 1) #\世)
(assert "utf8 index-set widens"        u8wide                      "a世c")
(assert "utf8 index-set widen length"  (length u8wide)             3)
;; persistence: non-ASCII char + string survive savedb/loaddb round-trip
(= u8char #\😀)
(= u8str  "héllo世界😀")
(persist 'u8char)
(persist 'u8str)
(savedb "/tmp/alcove-test-utf8.db")
(forget 'u8char)
(forget 'u8str)
(loaddb "/tmp/alcove-test-utf8.db")
(assert "utf8 persist 4-byte char"     (iso u8char #\😀)           t)
(assert "utf8 persist mixed string"    (iso u8str "héllo世界😀")    t)
(assert "utf8 persist string length"   (length u8str)              8)
(forget 'u8char)
(forget 'u8str)

;; ---------- file utilities and load ----------
(assert "write-string returns t"       (write-string "/tmp/alcove-test-file.txt" "one\n") t)
(assert "append-string returns t"      (append-string "/tmp/alcove-test-file.txt" "two\n") t)
(assert "file-exists? t"               (file-exists? "/tmp/alcove-test-file.txt") t)
(assert "file-exists? nil"             (file-exists? "/tmp/alcove-test-missing-file.txt") nil)
(assert "read-string"                  (read-string "/tmp/alcove-test-file.txt") "one\ntwo\n")
(assert "read-lines"                   (iso (read-lines "/tmp/alcove-test-file.txt")
                                            (list "one" "two"))    t)
(assert "write-bytes returns t"        (write-bytes "/tmp/alcove-test-file.bin"
                                                    (string->blob "abc")) t)
(assert "read-bytes after write-bytes" (blob->string (read-bytes "/tmp/alcove-test-file.bin")) "abc")
(write-string "/tmp/alcove-test-load.alc" "(= loaded-var 77)\n(def loaded-add (x) (+ x loaded-var))\n")
(assert "load returns t"               (load "/tmp/alcove-test-load.alc") t)
(assert "load defines var"             loaded-var                  77)
(assert "load defines fn"              (loaded-add 3)              80)
;; load error carries "<basename>:<line>:" — the unbound var is on line 2 of
;; the written file, so the annotated error-message must begin with that. A
;; comment + blank line precede it so the line number is non-trivial (proves
;; the form-start line is stamped after leading whitespace/comments).
(write-string "/tmp/alcove-test-loaderr.alc" "; a comment\n(unbound_xyz_var)\n")
(assert "load error has src:line"
        (string-index (error-message (load "/tmp/alcove-test-loaderr.alc"))
                      "alcove-test-loaderr.alc:2:") 0)

;; ---------- require + namespaces + :refer ----------
(write-string "/tmp/alcove-test-mod.alc"
              "(ns tmod)\n(def hi (n) (str \"hi:\" n))\n(def bye (n) (str \"bye:\" n))\n")
(assert "require returns t first time"  (require "/tmp/alcove-test-mod.alc")  t)
(assert "require returns nil if loaded" (require "/tmp/alcove-test-mod.alc")  nil)
(assert "module def is namespace-qualified" (tmod/hi 5) "hi:5")
(assert-true "module bare name not global" (error? (try (hi 5) (fn (e) e))))
;; :refer alone imports every name in the module's namespace unqualified
(require "/tmp/alcove-test-mod.alc" :refer)
(assert "refer-all imports hi"          (hi 7)              "hi:7")
(assert "refer-all imports bye"         (bye 8)             "bye:8")
;; selective :refer imports only the listed names
(write-string "/tmp/alcove-test-mod2.alc"
              "(ns tmod2)\n(def one (n) (+ n 1))\n(def two (n) (+ n 2))\n")
(require "/tmp/alcove-test-mod2.alc" :refer one)
(assert "selective refer imports listed"   (one 10)         11)
(assert-true "selective refer omits others" (error? (try (two 10) (fn (e) e))))
(assert "selective: qualified still works"  (tmod2/two 10)   12)
;; cross-dialect: require an Adder (.adr) module — it is transpiled on load, so
;; this works from both the alcove and adder binaries (bare paren forms pass
;; through the Adder front end unchanged).
(write-string "/tmp/alcove-test-adrmod.adr"
              "(ns amod)\n(def hey (n) (str \"hey:\" n))\n")
(assert "require .adr module"           (do (require "/tmp/alcove-test-adrmod.adr")
                                            (amod/hey 3))    "hey:3")
(assert "require .adr :refer"           (do (require "/tmp/alcove-test-adrmod.adr" :refer)
                                            (hey 4))         "hey:4")

;; ---------- hash sets ----------
(= s1 (set 1 2 2 "a" :kw))
(assert "set? populated"              (set? s1)                    t)
(assert "set? non-set"                (set? (hash-map "a" 1))       nil)
(assert "set count unique"            (count s1)                   4)
(assert "set-has? number"             (set-has? s1 2)              t)
(assert "set-has? missing"            (set-has? s1 3)              nil)
(set-add! s1 3)
(assert "set-add! mutates"            (set-has? s1 3)              t)
(set-del! s1 2)
(assert "set-del! mutates"            (set-has? s1 2)              nil)
(= s2 (set 3 4 :kw))
(= sunion (set-union s1 s2))
(assert "set-union count"             (count sunion)               5)
(assert "set-union contains"          (and (set-has? sunion 1)
                                           (set-has? sunion 4))     t)
(= sint (set-intersection s1 s2))
(assert "set-intersection count"      (count sint)                 2)
(assert "set-intersection elem"       (and (set-has? sint 3)
                                           (set-has? sint :kw))     t)
(= sdiff (set-difference s1 s2))
(assert "set-difference count"        (count sdiff)                2)
(assert "set-difference elem"         (and (set-has? sdiff 1)
                                           (set-has? sdiff "a"))    t)
(assert "set->list count"             (length (set->list s1))      (count s1))
(= styped (set 1 "1" 'foo "foo" 10 "10"))
(assert "set typed identity count"    (count styped)               6)
(assert "set typed identity members"  (and (set-has? styped 1)
                                           (set-has? styped "1")
                                           (set-has? styped 'foo)
                                           (set-has? styped "foo")) t)
(assert "set->list preserves string"  (string? (car (set->list (set "123")))) t)
(= smore (set 3.14 #\a nil t (string->blob "abc")))
(assert "set supports scalar types"   (and (set-has? smore 3.14)
                                           (set-has? smore #\a)
                                           (set-has? smore nil)
                                           (set-has? smore t)
                                           (set-has? smore (string->blob "abc"))) t)
(= sbig (set))
(for i 0 255 (set-add! sbig i))
(assert "set rehash count"            (count sbig)                 256)
(assert "set rehash membership"       (and (set-has? sbig 0)
                                           (set-has? sbig 255))     t)
(assert "set rehash list count"       (length (set->list sbig))    256)
(= sbig2 (set))
(for i 128 383 (set-add! sbig2 i))
(assert "set rehash union count"      (count (set-union sbig sbig2)) 384)
(assert "set rehash intersection"     (count (set-intersection sbig sbig2)) 128)
(assert "set rehash difference"       (count (set-difference sbig sbig2)) 128)
(= persisted-set (set 9 "x" :z "123" 123 3.14 #\a nil (string->blob "bb")))
(persist 'persisted-set)
(savedb "/tmp/alcove-test-set.db")
(forget 'persisted-set)
(loaddb "/tmp/alcove-test-set.db")
(assert "set persistence type"         (set? persisted-set)         t)
(assert "set persistence member"       (and (set-has? persisted-set 9)
                                            (set-has? persisted-set "x")
                                            (set-has? persisted-set :z)
                                            (set-has? persisted-set "123")
                                            (set-has? persisted-set 123)
                                            (set-has? persisted-set 3.14)
                                            (set-has? persisted-set #\a)
                                            (set-has? persisted-set nil)
                                            (set-has? persisted-set (string->blob "bb"))) t)
(forget 'persisted-set)

;; persistence: a HAMT (incl. a nested list value) survives savedb/loaddb
(= persisted-hamt (hamt "a" 1 "b" 2 3.14 'pi "nums" (list 10 20)))
(persist 'persisted-hamt)
(savedb "/tmp/alcove-test-hamt.db")
(forget 'persisted-hamt)
(loaddb "/tmp/alcove-test-hamt.db")
(assert "hamt persistence type"        (hamt? persisted-hamt)              t)
(assert "hamt persistence count"       (hamt-count persisted-hamt)         4)
(assert "hamt persistence string key"  (hamt-get persisted-hamt "a")       1)
(assert "hamt persistence float key"   (hamt-get persisted-hamt 3.14)      'pi)
(assert "hamt persistence nested val"  (iso (hamt-get persisted-hamt "nums") (list 10 20)) t)
(forget 'persisted-hamt)

;; ============================================================
;; persistence: EVERY structure type survives savedb/loaddb.
;; Scalars (number/float/string/symbol/char), blob, pair, cons-list,
;; vector (numeric + GEN + deeply nested), deque, dict, set, hamt,
;; lambda, macro. Guards the full dump/load type registration so a
;; future type without a dump/load fn (or a nested-element regression)
;; can't slip through. iso deep-compares scalars/pair/list/vector/blob;
;; dict/set/deque/hamt are compared via accessors (iso is identity-only).
;; ============================================================
(= ps-num 42)
(= ps-flt 3.5)
(= ps-str "héllo世")
(= ps-sym 'somesym)
(= ps-chr #\Z)
(= ps-blob (string->blob "bytes"))
(= ps-pair (cons 1 2))
(= ps-list (list 1 2 3))
(= ps-vec (vector 1 2 3))
(= ps-genvec (vector nil t "s" 9))
(= ps-nest (vector (set 2 3) (hash-map "k" (deque 7 8)) (hamt "z" 9) (list 1 (vector "x"))))
(= ps-deque (deque 10 20 30))
(= ps-dict (hash-map "a" 7 "b" 8))
(= ps-set (set 1 2 3))
(= ps-hamt (hamt "p" 1 "q" 2))
(= ps-lam (fn (a b) (+ a b)))
(defmacro ps-mac (x) (list 'quote x))
(persist 'ps-num) (persist 'ps-flt) (persist 'ps-str) (persist 'ps-sym)
(persist 'ps-chr) (persist 'ps-blob) (persist 'ps-pair) (persist 'ps-list)
(persist 'ps-vec) (persist 'ps-genvec) (persist 'ps-nest) (persist 'ps-deque)
(persist 'ps-dict) (persist 'ps-set) (persist 'ps-hamt) (persist 'ps-lam)
(persist 'ps-mac)
(savedb "/tmp/alcove-test-allstruct.db")
(forget 'ps-num) (forget 'ps-flt) (forget 'ps-str) (forget 'ps-sym)
(forget 'ps-chr) (forget 'ps-blob) (forget 'ps-pair) (forget 'ps-list)
(forget 'ps-vec) (forget 'ps-genvec) (forget 'ps-nest) (forget 'ps-deque)
(forget 'ps-dict) (forget 'ps-set) (forget 'ps-hamt) (forget 'ps-lam)
(loaddb "/tmp/alcove-test-allstruct.db")
(assert "persist number"     ps-num                              42)
(assert "persist float"      ps-flt                              3.5)
(assert "persist string"     ps-str                              "héllo世")
(assert "persist symbol"     ps-sym                              'somesym)
(assert "persist char"       (iso ps-chr #\Z)                    t)
(assert "persist blob"       (iso ps-blob (string->blob "bytes")) t)
(assert "persist pair"       (iso ps-pair (cons 1 2))            t)
(assert "persist cons-list"  (iso ps-list (list 1 2 3))          t)
(assert "persist vector"     (iso ps-vec (vector 1 2 3))         t)
(assert "persist GEN vector" (iso ps-genvec (vector nil t "s" 9)) t)
(assert "persist nested vec set"  (set-has? (vec-ref ps-nest 0) 3)            t)
(assert "persist nested vec dict" (count (vec-ref ps-nest 1))                 1)
(assert "persist nested vec deque"(count (get (vec-ref ps-nest 1) "k"))       2)
(assert "persist nested vec hamt" (hamt-get (vec-ref ps-nest 2) "z")          9)
(assert "persist nested vec list" (iso (vec-ref ps-nest 3) (list 1 (vector "x"))) t)
(assert "persist deque count"     (count ps-deque)                            3)
(assert "persist dict get"        (get ps-dict "a")                           7)
(assert "persist dict count"      (count ps-dict)                             2)
(assert "persist set member"      (set-has? ps-set 2)                         t)
(assert "persist set count"       (count ps-set)                              3)
(assert "persist hamt get"        (hamt-get ps-hamt "q")                      2)
(assert "persist hamt count"      (hamt-count ps-hamt)                        2)
(assert "persist lambda call"     (ps-lam 3 4)                                7)
(assert "persist macro use"       (ps-mac hello)                              'hello)
(forget 'ps-num) (forget 'ps-flt) (forget 'ps-str) (forget 'ps-sym)
(forget 'ps-chr) (forget 'ps-blob) (forget 'ps-pair) (forget 'ps-list)
(forget 'ps-vec) (forget 'ps-genvec) (forget 'ps-nest) (forget 'ps-deque)
(forget 'ps-dict) (forget 'ps-set) (forget 'ps-hamt) (forget 'ps-lam)
;; persist/unpersist/ispersistent of an unbound symbol must not crash
;; (regression: persistcmd derefed a NULL global dict → segfault).
(assert "persist unbound no-crash"     (do (persist 'ps-unbound-xyz) 1)      1)
(assert "ispersistent unbound"         (ispersistent 'ps-unbound-xyz2)       nil)
(assert "unpersist unbound no-crash"   (do (unpersist 'ps-unbound-xyz3) 1)   1)

;; "did you mean?" — unbound-variable errors carry an edit-distance suggestion
;; when a close builtin/global exists, and stay quiet when nothing is close.
;; Covers both the AST/top-level path and the compiled (VM) free-var path.
(assert "did-you-mean: hint present"
  (string-contains? (error-message (try revrse (fn (e) e))) "did you mean")  t)
(assert "did-you-mean: names the right builtin"
  (string-contains? (error-message (try revrse (fn (e) e))) "reverse")       t)
(assert "did-you-mean: quiet for unrelated name"
  (string-contains? (error-message (try zqzqxqwq (fn (e) e))) "did you mean") nil)
(assert "did-you-mean: compiled (VM) free-var path"
  (string-contains?
    (error-message (try (do (def _dym_q (x) (lenght x)) (_dym_q 1)) (fn (e) e)))
    "length") t)

;; savedb optional-path error path -- bad type causes error; execution
;; continues in file mode (the error propagates to the top level, which resumes).
(savedb 42)
(assert "after bad savedb arg: recovery" 1                         1)
(loaddb 42)
(assert "after bad loaddb arg: recovery" 1                         1)

;; inspect / disasm / source -- return nil (falsy), no crash.
;; (no x) is t when x is nil/false/NULL; these builtins return NULL.
(def _test_fn_for_inspect (x) (* x x))
(assert "inspect nil-return"          (no (inspect 42))            t)
(assert "disasm nil-return"           (no (disasm _test_fn_for_inspect)) t)
(assert "source nil-return"           (no (source _test_fn_for_inspect)) t)

;; ============================================================
;; Comprehensive regression suite — added to catch the classes
;; of bug surfaced by the multi-expert audit. Organized by area
;; so a failure points to a category, not just a number.
;; ============================================================

;; ---------- arithmetic: fixnum + float ----------
(assert "(+) is 0"                    (+)                            0)
(assert "(*) is 1"                    (*)                            1)
(assert "(+ a) is a"                  (+ 7)                          7)
(assert "(- 5) negates"               (- 5)                          -5)
(assert "(- a b c)"                   (- 10 1 2 3)                   4)
(assert "(/ a b)"                     (/ 12 3)                       4)
(assert "(/ a b c)"                   (/ 60 3 5)                     4)
(assert "mod"                         (mod 10 3)                     1)
(assert "abs neg"                     (abs -7)                       7)
(assert "abs pos"                     (abs 7)                        7)
(assert "max"                         (max 3 1 7 2 5)                7)
(assert "min"                         (min 3 1 7 2 5)                1)
(assert "max single"                  (max 9)                        9)
(assert "min single"                  (min 9)                        9)
(assert "expt int^int small"          (expt 2 10)                    1024)
(assert "expt 0^0 = 1"                (expt 0 0)                     1)
(assert "expt 1^N = 1"                (expt 1 100)                   1)
(assert "expt N^0 = 1"                (expt 99 0)                    1)
(assert "** alias"                    (** 3 4)                       81)
(assert "expt int overflow → float"   (iso (expt 2 80) (** 2 80))    t)
(assert "sqrt-int"                    (sqrt-int 100)                 10)
(assert "sqrt-int floor"              (sqrt-int 99)                  9)
(assert "sqrt-int 0"                  (sqrt-int 0)                   0)
(assert "sqrt-int negative → 0"       (sqrt-int -1)                  0)
(assert "sqrt-int large"              (sqrt-int 1000000)             1000)
(assert "mod float operands"          (mod 7.0 2.5)                  2.0)
(assert "mod int/float mixed"         (mod 7 2.5)                    2.0)
(assert "< mixed int/float"           (< 1 1.5)                      t)
(assert "> mixed int/float"           (> 2.5 2)                      t)
(assert "comparisons: float=float"    (<= 1.0 1.0)                   t)
(assert "odd t"                       (odd 3)                        t)
(assert "odd nil"                     (odd 4)                        nil)

;; ---------- type annotations (Phase 1: parsed, validated, then erased —
;; no runtime effect yet; they feed the JIT in a later phase) ----------
(def ta-f (x :int) (* x 2))
(assert "type hint: param"            (ta-f 5)                       10)
(def ta-g (a :f64 b :f64) (+ a b))
(assert "type hint: two params"       (ta-g 1.5 2.5)                 4.0)
(def ta-h (x :int) :f64 (+ x 1))
(assert "type hint: return type"      (ta-h 4)                       5)
(def ta-r (a :int . more) (+ a (count more)))
(assert "type hint: with rest param"  (ta-r 10 1 2)                  12)
(def ta-cd (n :int acc :int) (if (is n 0) acc (ta-cd (- n 1) (+ acc 1))))
(assert "type hint: deep recursion keeps TCO" (ta-cd 200000 0)       200000)
(assert "type hint: fn param"         ((fn (x :int) (* x 3)) 4)      12)
(defn ta-sq ((x :int) (* x x)))
(assert "type hint: defn explicit"    (ta-sq 6)                      36)
(defn ta-dbl (x :int (* x 2)))
(assert "type hint: defn leading-sym" (ta-dbl 8)                     16)
(def ta-novel (x) (* x x))
(assert "no hint: unchanged"          (ta-novel 7)                   49)
(assert-true "type hint: unknown keyword errors at def"
             (error? (try (def ta-bad (x :nope) x) (fn (e) e))))
(assert-true "type hint: keyword without param errors"
             (error? (try (def ta-bad2 (:int) 1) (fn (e) e))))
(assert-true "type hint: unknown return type errors"
             (error? (try (def ta-bad3 (x :int) :nope x) (fn (e) e))))

;; ---------- bitwise ----------
(assert "bit-and"                     (bit-and 12 10)                8)
(assert "bit-or"                      (bit-or  12 10)                14)
(assert "bit-xor"                     (bit-xor 12 10)                6)
(assert "& alias"                     (& 12 10)                      8)
(assert "| alias"                     (| 12 10)                      14)
(assert "^ alias"                     (^ 12 10)                      6)
(assert "~ 0 -> -1"                   (~ 0)                          -1)
(assert "~ 5"                         (~ 5)                          -6)
(assert "<< basic"                    (<< 1 8)                       256)
(assert ">> basic"                    (>> 256 4)                     16)
(assert ">> sign-preserving"          (>> -8 1)                      -4)
(assert "<< then >>"                  (>> (<< 7 4) 4)                7)
(assert "(** 2 16) via shift"         (<< 1 16)                      65536)

;; ---------- comparison chaining (cmpcmd variadic, batch A) ----------
(assert "< 0-arg vacuous"             (<)                            t)
(assert "< 1-arg vacuous"             (< 5)                          t)
(assert "< chained ok"                (< 1 2 3 4 5)                  t)
(assert "< chained break"             (< 1 2 2 4)                    nil)
(assert "< chained break late"        (< 1 2 3 2)                    nil)
(assert "> chained"                   (> 5 4 3 2 1)                  t)
(assert "<= chained equal ok"         (<= 1 2 2 3)                   t)
(assert ">= chained equal ok"         (>= 5 4 4 3)                   t)
(assert "string cmp <"                (< "abc" "abd")                t)
(assert "char cmp <"                  (< #\a #\b)                    t)
(assert "char cmp =>"                 (>= #\b #\a)                   t)
(def compiled-lt3 (a b c) (< a b c))
(assert "compiled chained < ok"       (compiled-lt3 1 2 3)           t)
(assert "compiled chained < break"    (compiled-lt3 1 3 2)           nil)
(def compiled-slt (a b) (< a b))
(assert "compiled string cmp <"       (compiled-slt "abc" "abd")     t)
(def compiled-clt (a b) (< a b))
(assert "compiled char cmp <"         (compiled-clt #\a #\b)         t)

;; ---------- equality / identity ----------
(assert "is symbol"                   (is 'a 'a)                     t)
(assert "is fixnum"                   (is 5 5)                       t)
(assert "is char"                     (is #\x #\x)                   t)
(assert "is mixed types -> nil"       (is 5 'a)                      nil)
(assert "iso list"                    (iso '(1 2) '(1 2))            t)
(assert "iso unequal list"            (iso '(1 2) '(1 3))            nil)
(assert "iso nested"                  (iso '((a) (b c)) '((a) (b c))) t)
(assert "iso strings"                 (iso "foo" "foo")              t)
(assert "in match first"              (in 'a 'a 'b 'c)               t)
(assert "in match middle"             (in 'b 'a 'b 'c)               t)
(assert "in match none"               (in 'z 'a 'b 'c)               nil)
(assert "no nil"                      (no nil)                       t)
(assert "no empty list"               (no (list))                    t)
(assert "no nonempty"                 (no (list 1))                  nil)
(assert "no non-empty string"         (no "x")                       nil)
(assert "no 0 -> t (alcove deviates from arc)" (no 0)                t)

;; ---------- if cond-style ----------
(assert "if ladder 1st"               (if t 1 t 2 t 3 99)            1)
(assert "if ladder 2nd"               (if nil 1 t 2 t 3 99)          2)
(assert "if ladder 3rd"               (if nil 1 nil 2 t 3 99)        3)
(assert "if ladder fallback"          (if nil 1 nil 2 nil 3 99)      99)
(assert "if no fallback no match"     (if nil 1 nil 2)               nil)

;; ---------- tail-call awareness (case/when/and/or now LISPCMD_TAIL) ----------
; alcove case is FLAT pairs Arc-style, not (val expr) clauses
(def evenc? (n) (case (mod n 2) 0 t nil))
(def evensum (n acc)
  (if (< n 1) acc
      (evensum (- n 1) (if (evenc? n) (+ acc n) acc))))
(assert "case+if mutual: sum evens 100"  (evensum 100 0)             2550)

(def whenchain (n)
  (when (> n 0) (whenchain (- n 1))))
(assert "when tail-rec deep"          (whenchain 1000)               nil)

(def andchain (n)
  (and (> n 0) (andchain (- n 1))))
(assert "and tail-rec to nil"         (andchain 1000)                nil)

(def orchain (n acc)
  (or (is n 0) (orchain (- n 1) (+ acc 1))))
(assert "or tail-rec returns t"       (orchain 1000 0)               t)

;; ---------- let / with shadowing + tail body ----------
(assert "let shadow inner"            (let x 10 (let x 20 x))        20)
(assert "let inner doesn't leak"      (let x 10 (let y 5 (+ x y)))   15)
(assert "with two bindings"           (with (a 3 b 4) (+ a b))       7)
(assert "with three bindings"         (with (a 1 b 2 c 3) (+ a b c)) 6)
(assert "let-in-call binding"         ((fn (x) (let y 1 (+ x y))) 5) 6)

;; ---------- list operations + non-list arg errors ----------
(assert "length empty"                (length nil)                   0)
(assert "length 3"                    (length (list 1 2 3))          3)
(assert "length list w/ nil"          (length (list nil))            1)
;; OP_LENGTH inside a compiled lambda body must mirror lengthcmd —
;; pre-fix, anything other than a pair-list silently returned 0.
(def lenof (x) (length x))
(assert "length string in compiled body"  (lenof "abc")              3)
(assert "length list in compiled body"    (lenof (list 1 2 3 4))     4)
(assert "length nil in compiled body"     (lenof nil)                0)
(assert "length vector in compiled body"  (lenof #[10 20 30])        3)
(assert "nth 0"                       (nth 0 (list 'a 'b 'c))        'a)
(assert "nth 2"                       (nth 2 (list 'a 'b 'c))        'c)
(assert "nth out-of-range -> nil"     (nth 99 (list 'a 'b 'c))       nil)
(assert "reverse empty -> nil"        (reverse nil)                  nil)
(assert "reverse 3"                   (iso (reverse (list 1 2 3))
                                          (list 3 2 1))              t)
(assert "append nil nil"              (append nil nil)               nil)
(assert "append empty cons"           (iso (append nil (list 1))
                                          (list 1))                  t)
(assert "append two non-empty"        (iso (append (list 1) (list 2 3))
                                          (list 1 2 3))              t)
(assert "append three"                (iso (append (list 1) (list 2) (list 3))
                                          (list 1 2 3))              t)
;; Non-list args: must error cleanly (not segfault) — these are the
;; exact regressions caught in the audit. Use iserror via no.
(def caught (e) (no (no e)))   ; truthy iff e is non-nil/non-false
(assert "nth on int → error obj"      (caught (nth 0 5))             t)
(assert "map on int → error obj"      (caught (map prn 5))           t)
(assert "filter on int → error obj"   (caught (filter odd 5))        t)
(assert "reduce on int → error obj"   (caught (reduce + 0 5))        t)
(assert "any? on int → error obj"     (caught (any? odd 5))          t)
(assert "all? on int → error obj"     (caught (all? odd 5))          t)
(assert "append on int → error obj"   (caught (append (list 1) 99))  t)
(assert "reverse on int → error obj"  (caught (reverse 7))           t)

;; ---------- higher-order ----------
(def double (x) (* x 2))
(assert "map basic"                   (iso (map double (list 1 2 3))
                                          (list 2 4 6))              t)
(assert "map empty"                   (map double nil)               nil)
(assert "filter odd"                  (iso (filter odd (list 1 2 3 4 5))
                                          (list 1 3 5))              t)
(assert "filter all-pass"             (iso (filter (fn (x) t) (list 1 2))
                                          (list 1 2))                t)
(assert "filter all-fail"             (filter (fn (x) nil) (list 1 2)) nil)
(assert "reduce sum"                  (reduce + 0 (list 1 2 3 4 5))  15)
(assert "reduce empty"                (reduce + 99 nil)              99)
(assert "reduce non-arith"            (reduce (fn (a x) (cons x a))
                                              nil (list 1 2 3))
                                      '(3 2 1))
(assert "any? has match"              (any? odd (list 2 4 5 6))      t)
(assert "any? no match"               (any? odd (list 2 4 6))        nil)
(assert "any? empty -> nil"           (any? odd nil)                 nil)
(assert "all? all match"              (all? odd (list 1 3 5))        t)
(assert "all? one fails"              (all? odd (list 1 3 4))        nil)
(assert "all? empty -> t"             (all? odd nil)                 t)

;; ---------- vectors ----------
(= v (vec 5 0))
(assert "vec len"                     (vec-len v)                    5)
(assert "vec init"                    (vec-ref v 0)                  0)
(vec-set! v 2 'x)
(assert "vec-set! / vec-ref"          (vec-ref v 2)                  'x)
(assert "vec-set! doesn't touch others" (vec-ref v 1)                0)
(assert "vec n=0 ok"                  (vec-len (vec 0 nil))          0)
;; Audit C3: huge n must error, not segfault.
(assert "vec n too large -> error"    (caught (vec (** 2 50) 0))     t)
(def compiled-mkvec (n) (vec n 0))
(assert "compiled vec n too large -> error"
                                      (caught (compiled-mkvec (** 2 50))) t)

;; ---------- predicates ----------
(assert "number? int"                 (number? 5)                    t)
(assert "number? float"               (number? 1.5)                  t)
(assert "number? string"              (number? "5")                  nil)
(assert "string? str"                 (string? "x")                  t)
(assert "string? symbol"              (string? 'x)                   nil)
(assert "symbol? sym"                 (symbol? 'x)                   t)
(assert "symbol? str"                 (symbol? "x")                  nil)
(assert "pair? pair"                  (pair? (list 1))               t)
(assert "pair? nil"                   (pair? nil)                    nil)
(assert "fn? lambda"                  (fn? (fn (x) x))               t)
(assert "fn? builtin"                 (fn? +)                        t)
(assert "fn? not"                     (fn? 5)                        nil)

;; ---------- strings ----------
(assert "string read literal idx"     ("abcdef" 0)                   #\a)
(assert "string read idx 5"           ("abcdef" 5)                   #\f)
(= sread2 "qwerty")
(assert "string read by var"          (sread2 3)                     #\r)
(= ridx2 4)
(assert "string read by computed idx" (sread2 ridx2)                 #\t)
(= sw "hello")
(= (sw 0) #\J)
(assert "string-set literal idx"      sw                             "Jello")
(= si 4)
(= (sw si) #\Y)
(assert "string-set computed idx"     sw                             "JellY")
;; Out-of-range write should error, not corrupt
(= sx "abc")
(assert "string-set OOB -> error"     (caught (= (sx 99) #\Z))       t)

;; ---------- bytecode arity (batch A) ----------
(def need3 (a b c) (+ a b c))
(assert "correct arity"               (need3 1 2 3)                  6)
(assert "too few args -> error"       (caught (need3 1 2))           t)
(assert "too many args -> error"      (caught (need3 1 2 3 4))       t)
(def tail-arity-target (a b) b)
(def tail-arity-few (x) (tail-arity-target x))
(tail-arity-few 9)
(assert "tail call wrong arity recovers" 42 42)
(def self-tail-few (a b) (if (< a 1) b (self-tail-few 0)))
(self-tail-few 1 42)
(assert "self-tail wrong arity recovers" 42 42)

;; ---------- recursion: golden values ----------
(def recfib (n) (if (< n 2) n (+ (recfib (- n 1)) (recfib (- n 2)))))
(assert "recfib 10"                   (recfib 10)                    55)
(assert "recfib 20"                   (recfib 20)                    6765)

(def recfact (n) (if (< n 2) 1 (* n (recfact (- n 1)))))
(assert "recfact 5"                   (recfact 5)                    120)
(assert "recfact 10"                  (recfact 10)                   3628800)
(assert "recfact 12"                  (recfact 12)                   479001600)

(def recack (m n)
  (if (is m 0) (+ n 1)
      (if (is n 0) (recack (- m 1) 1)
          (recack (- m 1) (recack m (- n 1))))))
(assert "ack(2,3) = 9"                (recack 2 3)                   9)
(assert "ack(3,3) = 61"               (recack 3 3)                   61)
(assert "ack(3,5) = 253"              (recack 3 5)                   253)

(def rectak (x y z)
  (if (no (< y x)) z
      (rectak (rectak (- x 1) y z)
              (rectak (- y 1) z x)
              (rectak (- z 1) x y))))
(assert "tak(8 4 0) = 1"              (rectak 8 4 0)                 1)
(assert "tak(6 3 1) = 3"              (rectak 6 3 1)                 3)

;; ---------- JIT same-callee guard (batch B): a fib-shape that calls
;; a different fn must NOT be silently rewritten as iterative-fib. ----------
(def helperA (n) (- n 1))
(def myfib2 (n)
  (if (< n 2) n
      (+ (helperA (- n 1)) (helperA (- n 2)))))
;; helperA(9)+helperA(8) = 8+7 = 15 — NOT fib(10)=55
; helperA(n-1)+helperA(n-2) = (n-2)+(n-3); 10 -> 8+7=15, 5 -> 3+2=5
(assert "JIT shape match w/ other callee 10" (myfib2 10)             15)
(assert "JIT shape match w/ other callee 5"  (myfib2 5)              5)

;; ---------- forget vs unpersist (batch D) ----------
(= zforget 99)
(assert "z bound"                     zforget                        99)
(forget 'zforget)
(assert "forget unbinds"              (caught zforget)               t)
(= zkeep 7)
(persist 'zkeep)
(assert "ispersistent t"              (ispersistent 'zkeep)          t)
(unpersist 'zkeep)
(assert "unpersist clears flag"       (ispersistent 'zkeep)          nil)
(assert "unpersist doesn't unbind"    zkeep                          7)
(forget 'zkeep)  ; cleanup

;; ---------- = on different place forms ----------
(= xs1 (list 1 2 3))
(= (car xs1) 'A)
(assert "= (car x) replaces head"     (iso xs1 '(A 2 3))             t)
(= xs2 (list 1 2 3))
(= (cdr xs2) (list 99))
(assert "= (cdr x) replaces tail"     (iso xs2 '(1 99))              t)

;; ---------- macros ----------
;; param is `c` not `cond`: `cond` is a builtin special form, and lookup
;; resolves reserved symbols before env, so a `cond` param can't shadow it.
(defmacro my-when (c body) `(if ,c ,body nil))
(assert "macro my-when t"             (my-when t 42)                 42)
(assert "macro my-when nil"           (my-when nil 42)               nil)

;; ---------- eval / apply ----------
(assert "eval quoted"                 (eval '(+ 2 3))                5)
(assert "apply +"                     (apply + (list 1 2 3 4))       10)
(assert "apply list"                  (iso (apply list (list 1 2 3))
                                          (list 1 2 3))              t)

;; ---------- mutation across env scopes ----------
(def noleak-local (x) (= noleak-y x))
(assert "function-local assignment returns value" (noleak-local 10)   10)

(setq setq-top 1)
(assert "setq top-level creates binding" setq-top                  1)
(def setq-create (x) (setq setq-created x))
(assert "setq in fn returns value"     (setq-create 10)            10)
(assert "setq in fn creates top-level" setq-created                10)
(def setq-update (x) (setq setq-top x))
(setq-update 20)
(assert "setq updates existing top-level" setq-top                 20)
(= setq-shadow 1)
(assert "setq updates local shadow" (let setq-shadow 2
                                      (do (setq setq-shadow 3)
                                          setq-shadow))             3)
(assert "setq local shadow preserves top-level" setq-shadow         1)
(def setq-param (x) (do (setq x 11) x))
(assert "setq updates function param"  (setq-param 5)              11)
(setq setq-a 1 setq-b 2)
(assert "setq multiple pairs"          (+ setq-a setq-b)           3)
(forget 'setq-top)
(forget 'setq-created)
(forget 'setq-shadow)
(forget 'setq-a)
(forget 'setq-b)

(def counter-mk ()
  (= cnt 0)
  (def counter-inc () (= cnt (+ cnt 1)) cnt))
(counter-mk)
(counter-inc)
(counter-inc)
(counter-inc)
(assert "top-level counter via def"   cnt                            3)

;; ---------- doc / help (don't crash, return nil) ----------
(assert "doc returns nil"             (doc cons)                     nil)
(assert "doc on quoted"               (doc 'reverse)                 nil)
(assert "doc on string"               (doc "vec")                    nil)
(assert "doc on unknown"              (doc never-existed)            nil)

;; ---------- savedb/loaddb path round-trip ----------
(= rt 1234)
(persist 'rt)
(savedb "/tmp/alcove-test-roundtrip.db")
(forget 'rt)
(assert "after forget rt is gone"     (caught rt)                    t)
(loaddb "/tmp/alcove-test-roundtrip.db")
(assert "loaddb restores rt"          rt                             1234)
(forget 'rt)

;; ---------- persistence marks top-level bindings, not local shadows ----------
(= persist_scope 42)
(let persist_scope 99 (persist 'persist_scope))
(assert "persist in local scope marks top-level" (ispersistent 'persist_scope) t)
(savedb "/tmp/alcove-test-persist-scope.db")
(forget 'persist_scope)
(assert "after forget persist_scope is gone" (caught persist_scope)   t)
(loaddb "/tmp/alcove-test-persist-scope.db")
(assert "local shadow was not saved"   persist_scope                  42)
(let persist_scope 99 (unpersist 'persist_scope))
(assert "unpersist in local scope clears top-level" (ispersistent 'persist_scope) nil)
(forget 'persist_scope)

;; ---------- recursion depth (env arena spans many frames) ----------
(def countdownr (n) (if (< n 1) 'done (countdownr (- n 1))))
(assert "countdown 1k tail-rec"       (countdownr 1000)              'done)
(assert "countdown 100k tail-rec"     (countdownr 100000)            'done)

;; ---------- mutual recursion (cross-fn TAIL_CALL) ----------
(def evenq (n) (if (< n 1) t   (oddq  (- n 1))))
(def oddq  (n) (if (< n 1) nil (evenq (- n 1))))
(assert "evenq 10000"                 (evenq 10000)                  t)
(assert "oddq 10001"                  (oddq 10001)                   t)

;; ---------- character ops ----------
(assert "char literal"                (is #\A #\A)                   t)
(assert "char from string"            (is ("foo" 0) #\f)             t)

;; ---------- 0-arg / single-arg edge cases on variadic builtins ----------
(assert "(list) is nil"               (list)                         nil)
(assert "(and) is t"                  (and)                          t)
(assert "(or) is nil"                 (or)                           nil)
(assert "(do)"                        (do)                           nil)

;; ---------- in-place string mutation persists across calls ----------
(= mutbuf "hello")
(def upcase-first (s) (= (s 0) #\H) s)
(upcase-first mutbuf)
(assert "mutation persists in buf"    mutbuf                         "Hello")

;; ---------- big random fixnum (close to int61 boundary) doesn't wrap ----------
(assert "1<<59 fits"                  (<< 1 59)                      576460752303423488)

;; sanity: still here at end?
(assert "end-of-suite sentinel"       'reached                       'reached)

;; Ticket 6: (s i) inside compiled def bodies — both literal-string
;; head, var-headed string lookup, and let-wrapped variants.
(= sread6 "abcdef")
(def t6_sget1 (n) (sread6 n))
(assert "ticket6: var-string in def body"   (t6_sget1 2)             #\c)
(def t6_sget2 (s n) (s n))
(assert "ticket6: passed-string in def"     (t6_sget2 "hello" 1)     #\e)
(def t6_sget3 (n) (let _ 1 (sread6 n)))
(assert "ticket6: var-string in let body"   (t6_sget3 4)             #\e)
(def t6_lit (n) ("abcdef" n))
(assert "ticket6: literal string in def"    (t6_lit 3)               #\d)
(def t6_mix (n)
  (let a (sread6 n)
    (let b (sread6 (+ n 1)) a)))
(assert "ticket6: mixed reads in def"       (t6_mix 0)               #\a)

;; Ticket 7: nested for with multi-form outer body must iterate all
;; outer values, not just one. Root cause was prcmd returning NULL
;; (interpreted by forcmd as "missing param"), and forcmd was over-
;; strict about NULL bodies.
(= acc7 0)
(for y 0 2
  (for x 0 1 (= acc7 (+ acc7 1)))
  (= acc7 (+ acc7 100)))
(assert "ticket7: nested for, multi-form outer body" acc7 (+ (* 3 2) (* 3 100)))
;; Side effects in the outer body fire on EVERY iteration:
(= log7 (list))
(for i 1 3
  (= log7 (cons (list 'in i) log7))
  (for j 1 2
    (= log7 (cons (list 'inner i j) log7)))
  (= log7 (cons (list 'out i) log7)))
(assert "ticket7: outer body forms after nested for run" (length log7) 12)
;; for that returns NIL_EXP (via prn) then iterates again
(= n7 0)
(for k 1 5 (prn "") (= n7 (+ n7 1)))
(assert "ticket7: for after a NIL-returning builtin" n7 5)

;; Ticket 8: comments inside a list (def body, do body, etc.) must NOT
;; drop preceding forms. Root cause was that `;` had no reader handler;
;; it fell into the "unknown TERMMACRO" error path and the list-builder
;; bailed out mid-build.
(= s8a 0)
(do (= s8a (+ s8a 1)) ; comment
    (= s8a (+ s8a 10))
    (= s8a (+ s8a 100)))
(assert "ticket8: do with mid-list comment" s8a 111)
(= s8b 0)
(def f8 ()
  (= s8b (+ s8b 1))
  ; comment between body forms
  (= s8b (+ s8b 10))
  (= s8b (+ s8b 100)))
(f8)
(assert "ticket8: def body with comment" s8b 111)
(= s8c 0)
(def f8c ()
  ; leading comment
  (= s8c (+ s8c 1)))
(f8c)
(assert "ticket8: leading comment in def body" s8c 1)
(= s8d 0)
(def f8d ()
  (let _ 1
    ; comment inside let body
    (= s8d (+ s8d 1))))
(f8d)
(assert "ticket8: comment inside let inside def" s8d 1)

;; arkanoid-shaped repro — the original reproducible failure
(def step8 ()
  (pr "")
  ; like a render header
  (pr "")
  (for i 1 3 (pr "")))
(step8)
(assert "ticket8: arkanoid-shaped step" 'ok 'ok)

;; alcove-001: two distinct bugs. (A) OP_BIND_SLOT didn't initialise
;; inline_keys[idx], so lookup()/updatebang()'s strcmp walked stale
;; arena pointers — SIGSEGV on let/with/for. (B) defcmd/fncmd body
;; validator rejected non-pair first forms, silently producing
;; unbound names for (def g () 42), (def g (x) x), (fn () 42).

;; Bug B — body validator must accept any expression as the first
;; body form: literal, symbol, nil, or pair. Pre-fix these all
;; failed silently (binding never created, call → "unbound name").
(def alc001b-lit () 42)
(assert "alcove-001 B: def with literal body"
        (alc001b-lit)                       42)
(def alc001b-nil () nil)
(assert "alcove-001 B: def with nil body"
        (alc001b-nil)                       nil)
(def alc001b-sym (x) x)
(assert "alcove-001 B: def with bare-symbol body"
        (alc001b-sym 7)                     7)
(assert "alcove-001 B: anon fn with literal body"
        ((fn () 99))                        99)

;; Bug A — OP_BIND_SLOT (let/with/for) must leave inline_keys in a
;; lookup-safe state. Repro: deliberately populate the env arena
;; with a high-water-mark of param strings via a multi-arg fn call,
;; then exercise nested let/with/for. The bug fires when lookup()
;; walks inline_keys past a slot left uninitialised by OP_BIND_SLOT.
;; Pre-fix: random crash depending on arena residue. Post-fix: NULL
;; sentinel skipped cleanly by the symbolic walk.
(def alc001a-pollute (a b c d e f) (+ a b c d e f))
(alc001a-pollute 1 2 3 4 5 6) ; pollutes arena slot's inline_keys[0..5]
(def alc001a-let () (let x 1 (let y 2 (let z 3 (+ x y z)))))
(assert "alcove-001 A: nested let after pollution"
        (alc001a-let)                       6)
(def alc001a-with () (with (p 10 q 20 r 30) (+ p q r)))
(assert "alcove-001 A: with after pollution"
        (alc001a-with)                      60)
(def alc001a-for () (let s 0 (for i 1 5 (= s (+ s i))) s))
(assert "alcove-001 A: for-body after pollution"
        (alc001a-for)                       15)
;; Combined stress: function with params (puts real keys in arena)
;; immediately followed by let-body that walks inline_keys for a
;; symbol that lives in the OUTER env. Pre-fix: strcmp walks
;; stale pointers from the prior tenant on every iteration.
(def alc001a-outer (m)
  (let n 100 (+ m n)))
(assert "alcove-001 A: outer-symbol lookup through let body"
        (alc001a-outer 7)                   107)

;; alcove-002: TAIL_AWARE special forms (if/do/when/and/or/case) must
;; manage `in_tail_position` so a user-fn call inside a sub-expression
;; can't return a tail-call marker that the form's truthiness check
;; mis-reads as a real value. Plus two pre-existing nits in whencmd:
;; the `(when t)` no-body case crashed on `cur->next` deref, and the
;; function unconditionally returned NIL_EXP instead of the last body
;; form's value.

;; (or) and (and) with zero args.
(assert "alcove-002: (or)  -> nil"               (or)               nil)
(assert "alcove-002: (and) -> t"                 (and)              t)

;; (when test) with no body — must NOT crash, returns nil per docstring.
(assert "alcove-002: (when t)   no body -> nil"  (when t)           nil)
(assert "alcove-002: (when nil) no body -> nil"  (when nil)         nil)

;; (when test body...) — returns the last body form's value. Pre-fix
;; this always returned nil regardless of body.
(assert "alcove-002: (when t 42) -> 42"          (when t 42)        42)
(assert "alcove-002: (when t 1 2 3) -> 3"        (when t 1 2 3)     3)
(assert "alcove-002: (when t (+ 1 2)) -> 3"      (when t (+ 1 2))   3)
(assert "alcove-002: (when nil 42) -> nil"       (when nil 42)      nil)

;; Tail-marker leak through earlier (and)/(or) args. The hazard: an
;; earlier arg evaluates a user-fn-call in TAIL position; the trampoline
;; returns a tail marker (pair with FLAG_TAILREC); the short-circuit
;; check treats the pair as truthy/non-empty and either fires the body
;; (and) early-stops, or (or) early-returns the marker itself. Reproduce
;; via a TAIL_AWARE form wrapping (and)/(or) so in_tail_position is set.
(def alc002-helper (n) n)  ; trivial user fn; gets compiled
(def alc002-and-leak ()
  ;; (and (alc002-helper nil) 7) — first arg is a user-call returning
  ;; nil. Pre-fix, in tail position the call returns a marker that
  ;; istrue() reads as true, so `and` continues, returns 7 (wrong).
  (when t (and (alc002-helper nil) 7)))
(assert "alcove-002: tail-leak through (and) earlier arg"
        (alc002-and-leak)                                nil)
(def alc002-or-leak ()
  ;; (or (alc002-helper nil) 7) — first arg returns nil; (or) should
  ;; fall through to 7. Pre-fix in tail position, the marker is treated
  ;; as truthy and (or) returns the marker instead of 7.
  (when t (or (alc002-helper nil) 7)))
(assert "alcove-002: tail-leak through (or) earlier arg"
        (alc002-or-leak)                                 7)

;; ---------- tensor bulk ops on vec ----------
;; Helper: vec → list so iso compares element-by-element. `for` only
;; counts up, so iterate forward and reverse at the end.
(def vec->list (v)
  (let xs (list)
    (do
      (for i 0 (- (vec-len v) 1)
        (= xs (cons (vec-ref v i) xs)))
      (reverse xs))))

;; vec-dot — sum of products, integer elements (exact).
(= vd-a (vec 4 0)) (vec-set! vd-a 0 1) (vec-set! vd-a 1 2) (vec-set! vd-a 2 3) (vec-set! vd-a 3 4)
(= vd-b (vec 4 0)) (vec-set! vd-b 0 5) (vec-set! vd-b 1 6) (vec-set! vd-b 2 7) (vec-set! vd-b 3 8)
(assert "vec-dot: integer elements"
        (vec-dot vd-a vd-b)                              70.0)         ; 5+12+21+32

;; vec-dot: float elements (exact sum 8.5)
(= vd-c (vec 4 0.0)) (vec-set! vd-c 0 1.0) (vec-set! vd-c 1 2.0) (vec-set! vd-c 2 3.0) (vec-set! vd-c 3 4.0)
(= vd-d (vec 4 0.0)) (vec-set! vd-d 0 0.5) (vec-set! vd-d 1 1.5) (vec-set! vd-d 2 -1.0) (vec-set! vd-d 3 2.0)
(assert "vec-dot: float elements, exact sum"
        (vec-dot vd-c vd-d)                              8.5)

;; vec-dot: zero-length is 0
(assert "vec-dot: empty vec is 0"
        (vec-dot (vec 0 0) (vec 0 0))                    0.0)

;; vec-dot: orthogonal vecs
(= e1 (vec 3 0)) (vec-set! e1 0 1)
(= e2 (vec 3 0)) (vec-set! e2 1 1)
(assert "vec-dot: orthogonal vecs"
        (vec-dot e1 e2)                                  0.0)

;; vec-axpy! — y += a*x, exact integer math (a=3, x=[1,2,3,4], y=[10,10,10,10])
(= ax-y (vec 4 0)) (for i 0 3 (vec-set! ax-y i 10))
(= ax-x (vec 4 0)) (for i 0 3 (vec-set! ax-x i (+ i 1)))
(vec-axpy! ax-y 3 ax-x)
(assert "vec-axpy!: integer scale + integer vecs"
        (vec->list ax-y)                                 (list 13.0 16.0 19.0 22.0))

;; vec-axpy! with a=0 leaves y unchanged in value (though slots are replaced)
(= ax-y2 (vec 3 7))
(= ax-x2 (vec 3 99))
(vec-axpy! ax-y2 0 ax-x2)
(assert "vec-axpy!: a=0 preserves y"
        (vec->list ax-y2)                                (list 7.0 7.0 7.0))

;; vec-axpy! with negative a (gradient descent direction)
(= ax-y3 (vec 3 0)) (vec-set! ax-y3 0 10) (vec-set! ax-y3 1 20) (vec-set! ax-y3 2 30)
(= ax-x3 (vec 3 0)) (vec-set! ax-x3 0 1) (vec-set! ax-x3 1 2) (vec-set! ax-x3 2 3)
(vec-axpy! ax-y3 -2 ax-x3)
(assert "vec-axpy!: negative scalar"
        (vec->list ax-y3)                                (list 8.0 16.0 24.0))

;; vec-axpy! returns y
(= ax-y4 (vec 2 1)) (= ax-x4 (vec 2 1))
(assert "vec-axpy!: returns y"
        (iso (vec-axpy! ax-y4 1 ax-x4) ax-y4)            t)

;; vec-scale!
(= sc-v (vec 4 0)) (vec-set! sc-v 0 1) (vec-set! sc-v 1 2) (vec-set! sc-v 2 3) (vec-set! sc-v 3 4)
(vec-scale! sc-v 5)
(assert "vec-scale!: integer scale"
        (vec->list sc-v)                                 (list 5.0 10.0 15.0 20.0))

(= sc-v2 (vec 3 0)) (vec-set! sc-v2 0 2.0) (vec-set! sc-v2 1 4.0) (vec-set! sc-v2 2 8.0)
(vec-scale! sc-v2 0.5)
(assert "vec-scale!: halving"
        (vec->list sc-v2)                                (list 1.0 2.0 4.0))

;; vec-add!
(= ad-y (vec 4 0)) (for i 0 3 (vec-set! ad-y i (+ i 1)))    ; 1 2 3 4
(= ad-x (vec 4 0)) (for i 0 3 (vec-set! ad-x i (* i 10)))   ; 0 10 20 30
(vec-add! ad-y ad-x)
(assert "vec-add!: element-wise sum"
        (vec->list ad-y)                                 (list 1.0 12.0 23.0 34.0))

;; vec-fill!
(= fl-v (vec 5 99))
(vec-fill! fl-v -1.5)
(assert "vec-fill!: float fill"
        (vec->list fl-v)                                 (list -1.5 -1.5 -1.5 -1.5 -1.5))

;; vec-relu!
(= rl-v (vec 5 0)) (vec-set! rl-v 0 -3) (vec-set! rl-v 1 0) (vec-set! rl-v 2 4)
(vec-set! rl-v 3 -0.5) (vec-set! rl-v 4 2.5)
(vec-relu! rl-v)
(assert "vec-relu!: zeros negatives, preserves non-negatives"
        (vec->list rl-v)                                 (list 0.0 0 4 0.0 2.5))

;; vec-relu! on all-negative
(= rl-v2 (vec 3 0)) (vec-set! rl-v2 0 -1) (vec-set! rl-v2 1 -2) (vec-set! rl-v2 2 -3)
(vec-relu! rl-v2)
(assert "vec-relu!: all-negative → all-zero"
        (vec->list rl-v2)                                (list 0.0 0.0 0.0))

;; vec-argmax — basic and ties (first-best wins)
(= am-v (vec 5 0)) (vec-set! am-v 0 1) (vec-set! am-v 1 -3) (vec-set! am-v 2 9)
(vec-set! am-v 3 7) (vec-set! am-v 4 2)
(assert "vec-argmax: basic"
        (vec-argmax am-v)                                2)

(= am-v2 (vec 4 0)) (vec-set! am-v2 0 5) (vec-set! am-v2 1 5) (vec-set! am-v2 2 5) (vec-set! am-v2 3 5)
(assert "vec-argmax: ties favor lowest index"
        (vec-argmax am-v2)                               0)

;; vec-max
(= mx-v (vec 5 0)) (vec-set! mx-v 0 1.0) (vec-set! mx-v 1 -3.0) (vec-set! mx-v 2 9.0)
(vec-set! mx-v 3 7.0) (vec-set! mx-v 4 2.0)
(assert "vec-max: float elements"
        (vec-max mx-v)                                   9.0)

;; vec-max with mixed int/float
(= mx-v2 (vec 3 0)) (vec-set! mx-v2 0 1) (vec-set! mx-v2 1 2.5) (vec-set! mx-v2 2 2)
(assert "vec-max: mixed int/float picks the float"
        (vec-max mx-v2)                                  2.5)

;; vec-copy!
(= cp-dst (vec 4 0))
(= cp-src (vec 4 0)) (vec-set! cp-src 0 10) (vec-set! cp-src 1 20) (vec-set! cp-src 2 30) (vec-set! cp-src 3 40)
(vec-copy! cp-dst cp-src)
(assert "vec-copy!: contents match source"
        (vec->list cp-dst)                               (list 10 20 30 40))

;; vec-copy! doesn't alias — mutating src after copy doesn't change dst
(vec-set! cp-src 0 999)
(assert "vec-copy!: no aliasing"
        (vec-ref cp-dst 0)                               10)

;; combined: MSE-style gradient pattern
;; d = (probs - one_hot(target)) in one walk.
;; Using exact-representable binary fractions (0.25, 0.5, 0.25) so iso's
;; bit-exact float compare passes; the math is the same in concept.
(= grad-probs (vec 3 0))
(vec-set! grad-probs 0 0.25) (vec-set! grad-probs 1 0.5) (vec-set! grad-probs 2 0.25)
(= grad-d (vec 3 0))
(vec-copy! grad-d grad-probs)
(vec-set! grad-d 1 (- (vec-ref grad-d 1) 1.0))    ; target=1
(assert "tensor combo: softmax-CE gradient"
        (vec->list grad-d)                               (list 0.25 -0.5 0.25))

;; matrix-vec multiply via per-row vec-dot (the forward-pass pattern):
;; W is 3x2 (3 outputs, 2 inputs); each row a separate vec.
;; result[k] = dot(W[k], x)
(= W-row0 (vec 2 0)) (vec-set! W-row0 0 1) (vec-set! W-row0 1 2)
(= W-row1 (vec 2 0)) (vec-set! W-row1 0 3) (vec-set! W-row1 1 4)
(= W-row2 (vec 2 0)) (vec-set! W-row2 0 5) (vec-set! W-row2 1 6)
(= mv-x (vec 2 0)) (vec-set! mv-x 0 10) (vec-set! mv-x 1 20)
(= mv-out (vec 3 0))
(vec-set! mv-out 0 (vec-dot W-row0 mv-x))
(vec-set! mv-out 1 (vec-dot W-row1 mv-x))
(vec-set! mv-out 2 (vec-dot W-row2 mv-x))
(assert "tensor combo: 3x2 matvec via per-row vec-dot"
        (vec->list mv-out)                               (list 50.0 110.0 170.0))

;; column-sum-as-axpy: y = sum_k W[k] * c[k]   (the backprop pattern for d-hidden)
(= cs-y (vec 2 0.0))
(= cs-c (vec 3 0)) (vec-set! cs-c 0 1) (vec-set! cs-c 1 0) (vec-set! cs-c 2 -1)
(vec-axpy! cs-y (vec-ref cs-c 0) W-row0)   ; y += 1 * [1,2] = [1,2]
(vec-axpy! cs-y (vec-ref cs-c 1) W-row1)   ; y += 0 * [3,4] = [1,2]
(vec-axpy! cs-y (vec-ref cs-c 2) W-row2)   ; y -= [5,6]    = [-4,-4]
(assert "tensor combo: column-weighted sum via axpy"
        (vec->list cs-y)                                 (list -4.0 -4.0))

;; ---------- deque ops on vec ----------
;; push/pop at the back
(= dq (vec 0 nil))
(vec-push! dq 1) (vec-push! dq 2) (vec-push! dq 3)
(assert "vec-push!: length after 3 pushes"  (vec-len dq) 3)
(assert "vec-push!: contents"               (vec->list dq) (list 1 2 3))
(assert "vec-pop!: returns last"            (vec-pop! dq) 3)
(assert "vec-pop!: length decreases"        (vec-len dq) 2)
(assert "vec-pop!: contents after pop"      (vec->list dq) (list 1 2))

;; unshift/shift at the front
(vec-unshift! dq 0)
(assert "vec-unshift!: prepends"            (vec->list dq) (list 0 1 2))
(assert "vec-shift!: returns first"         (vec-shift! dq) 0)
(assert "vec-shift!: contents after shift"  (vec->list dq) (list 1 2))

;; round-trip: push back, shift front, until empty
(= dq2 (vec 0 nil))
(vec-push! dq2 10) (vec-push! dq2 20) (vec-push! dq2 30)
(assert "vec-shift! queue: first out"       (vec-shift! dq2) 10)
(assert "vec-shift! queue: second out"      (vec-shift! dq2) 20)
(assert "vec-shift! queue: third out"       (vec-shift! dq2) 30)
(assert "vec-shift! queue: empty after"     (vec-len dq2) 0)
(vec-pop! never-bound-for-pop)
(assert "vec-pop!: recovers after arg error" 42 42)
(vec-shift! never-bound-for-shift)
(assert "vec-shift!: recovers after arg error" 42 42)
(= vec-err (vector 1 'x 3))
(vec-dot vec-err vec-err)
(assert "vec-dot: recovers after non-numeric error" 42 42)
(vec-relu! vec-err)
(assert "vec-relu!: recovers after non-numeric error" 42 42)
(vec-argmax vec-err)
(assert "vec-argmax: recovers after non-numeric error" 42 42)
(vec-max vec-err)
(assert "vec-max: recovers after non-numeric error" 42 42)

;; ---------- numeric / NN tensor ops ----------
(= tm-a (vec 3 2.0)) (= tm-b (vec 3 3.0))
(assert "vec-mul!: Hadamard"      (do (vec-mul! tm-a tm-b) (vec->list tm-a))  (list 6.0 6.0 6.0))
(= ts-a (vec 3 5.0)) (= ts-b (vec 3 2.0))
(assert "vec-sub!: elementwise"   (do (vec-sub! ts-a ts-b) (vec->list ts-a))  (list 3.0 3.0 3.0))
(assert "vec-mul!: returns target" (do (= m1 (vec 2 4.0)) (is (vec-mul! m1 (vec 2 1.0)) m1)) t)
(assert "vec-sum: float"          (vec-sum (vec 4 2.5))                        10.0)
(assert "vec-sum: empty is 0"     (vec-sum (vec 0 0))                          0.0)
(= mn-v (vec 3 0)) (vec-set! mn-v 0 3.0) (vec-set! mn-v 1 -1.0) (vec-set! mn-v 2 2.0)
(assert "vec-min: smallest"       (vec-min mn-v)                               -1.0)
(assert "vec-argmin: index of min" (vec-argmin mn-v)                           1)
(= mn2 (vec 4 0)) (vec-set! mn2 0 5) (vec-set! mn2 1 5) (vec-set! mn2 2 5) (vec-set! mn2 3 5)
(assert "vec-argmin: ties favor lowest index" (vec-argmin mn2)                 0)
;; activations at known points
(assert "vec-tanh!(0) = 0"        (do (= t0 (vec 1 0.0)) (vec-tanh! t0) (vec-ref t0 0))      0.0)
(assert "vec-sigmoid!(0) = 0.5"   (do (= s0 (vec 1 0.0)) (vec-sigmoid! s0) (vec-ref s0 0))   0.5)
(assert "vec-exp!(0) = 1"         (do (= e0 (vec 1 0.0)) (vec-exp! e0) (vec-ref e0 0))       1.0)
;; softmax: normalizes to a probability distribution (sums to 1) and is monotone
(= sm (vec 3 0)) (vec-set! sm 0 1.0) (vec-set! sm 1 2.0) (vec-set! sm 2 3.0)
(vec-softmax! sm)
(assert-true "vec-softmax!: sums to ~1" (< (abs (- (vec-sum sm) 1.0)) 0.0000001))
(assert-true "vec-softmax!: order preserved" (< (vec-ref sm 0) (vec-ref sm 2)))
(assert-true "vec-softmax!: stable on large inputs (no overflow)"
             (do (= big (vec 2 0)) (vec-set! big 0 1000.0) (vec-set! big 1 1001.0)
                 (vec-softmax! big) (< (abs (- (vec-sum big) 1.0)) 0.0000001)))
;; int vectors promote to float for in-place float ops
(assert "vec-mul!: promotes int vec" (do (= iv (vec 3 2)) (vec-mul! iv (vec 3 3)) (vec-ref iv 0)) 6.0)
(vec-mul! 'not-a-vec 'x)
(assert "vec-mul!: recovers after type error" 42 42)
(vec-sum 'not-a-vec)
(assert "vec-sum: recovers after type error" 42 42)

;; ---------- matrix ops ----------
;; A = [[1 2 3],[4 5 6]] (2x3, row-major flat), x = [1 1 1] -> y = [6 15]
(= mvA (vec 6 0)) (= mvi 0)
(while (< mvi 6) (do (vec-set! mvA mvi (float (+ mvi 1))) (= mvi (+ mvi 1))))
(= mvY (mat-vec mvA (vec 3 1.0)))
(assert "mat-vec: y[0]" (vec-ref mvY 0) 6.0)
(assert "mat-vec: y[1]" (vec-ref mvY 1) 15.0)
(assert "mat-vec: result length = m" (vec-len mvY) 2)
;; A=[[1 2],[3 4]] · B=[[5 6],[7 8]] (k=2) = [[19 22],[43 50]] flat [19 22 43 50]
(= mmA (vec 4 0)) (vec-set! mmA 0 1.0)(vec-set! mmA 1 2.0)(vec-set! mmA 2 3.0)(vec-set! mmA 3 4.0)
(= mmB (vec 4 0)) (vec-set! mmB 0 5.0)(vec-set! mmB 1 6.0)(vec-set! mmB 2 7.0)(vec-set! mmB 3 8.0)
(= mmC (mat-mul mmA mmB 2))
(assert "mat-mul: C[0,0]" (vec-ref mmC 0) 19.0)
(assert "mat-mul: C[0,1]" (vec-ref mmC 1) 22.0)
(assert "mat-mul: C[1,0]" (vec-ref mmC 2) 43.0)
(assert "mat-mul: C[1,1]" (vec-ref mmC 3) 50.0)
;; A · I = A
(= mmI (vec 4 0)) (vec-set! mmI 0 1.0) (vec-set! mmI 3 1.0)
(= mmAI (mat-mul mmA mmI 2))
(assert "mat-mul: A·I preserves A[0]" (vec-ref mmAI 0) 1.0)
(assert "mat-mul: A·I preserves A[3]" (vec-ref mmAI 3) 4.0)
;; non-square: A 2x3 · B 3x1 (k=3) -> 2x1
(= nsA (vec 6 0)) (= nsi 0)
(while (< nsi 6) (do (vec-set! nsA nsi (float (+ nsi 1))) (= nsi (+ nsi 1))))
(= nsB (vec 3 1.0))
(= nsC (mat-mul nsA nsB 3))
(assert "mat-mul: non-square shape (2x1)" (vec-len nsC) 2)
(assert "mat-mul: non-square C[0]" (vec-ref nsC 0) 6.0)   ; 1+2+3
(assert "mat-mul: non-square C[1]" (vec-ref nsC 1) 15.0)  ; 4+5+6
;; int vectors promote to float
(assert "mat-mul: int vecs promote" (vec-ref (mat-mul (vec 4 2) (vec 4 1) 2) 0) 4.0)
(mat-vec (vec 5 1.0) (vec 3 1.0))
(assert "mat-vec: recovers after bad dims" 42 42)
(mat-mul (vec 6 1.0) (vec 6 1.0) 4)
(assert "mat-mul: recovers after bad k" 42 42)
;; self-aliasing (same vector as both operands) — the SIMD ivdep loops must
;; stay correct when y==x. (audit M-6)
(= sa (vec 2 0)) (vec-set! sa 0 2.0) (vec-set! sa 1 3.0)
(assert "vec-mul!: self-alias (v*v)" (do (vec-mul! sa sa) (vec->list sa)) (list 4.0 9.0))
(= sb (vec 3 7.0))
(assert "vec-sub!: self-alias (v-v)=0" (do (vec-sub! sb sb) (vec->list sb)) (list 0.0 0.0 0.0))
;; A·A: [[1 2],[3 4]]² = [[7 10],[15 22]]
(= saA (vec 4 0)) (vec-set! saA 0 1.0)(vec-set! saA 1 2.0)(vec-set! saA 2 3.0)(vec-set! saA 3 4.0)
(= saAA (mat-mul saA saA 2))
(assert "mat-mul: self-alias A·A [0]" (vec-ref saAA 0) 7.0)
(assert "mat-mul: self-alias A·A [3]" (vec-ref saAA 3) 22.0)

(vec-len 'not-a-vec)
(assert "vec-len: recovers after type error" 42 42)
(sqrt-int 'not-a-number)
(assert "sqrt-int: recovers after type error" 42 42)

;; many pushes — exercise the growth path (cap doubles, slide-left, etc.)
(= dq4 (vec 0 nil))
(for i 0 99 (vec-push! dq4 i))
(assert "vec-push!: 100 pushes length"      (vec-len dq4) 100)
(assert "vec-push!: first cell"             (vec-ref dq4 0) 0)
(assert "vec-push!: last cell"              (vec-ref dq4 99) 99)

;; alternating push/shift — exercises slide-left after start moves
(= dq5 (vec 0 nil))
(for i 0 49 (do (vec-push! dq5 i) (vec-shift! dq5) (vec-push! dq5 (+ i 1000))))
(assert "vec-push!/shift! alternation"      (vec-len dq5) 50)

;; deque on typed vecs — push i64 into i64 vec, push f64 into f64 vec
(= dqi (vec 0 0))   ; GEN initially (fill nil-ish if 0 is fix)
(vec-push! dqi 1) (vec-push! dqi 2)
(assert "vec-push! on fixnum-init vec"      (vec-ref dqi 1) 2)

;; ---------- container type predicates ----------
;; vec?
(assert "vec?: empty vec"           (vec? (vec 0 0))           t)
(assert "vec?: populated vec"       (vec? (vec 3 0))           t)
(assert "vec?: literal vec"         (vec? #[1 2 3])            t)
(assert "vec?: nil"                 (vec? nil)                 nil)
(assert "vec?: list (cons-pair)"    (vec? (list 1 2))          nil)
(assert "vec?: string"              (vec? "x")                 nil)
(assert "vec?: number"              (vec? 5)                   nil)
(assert "vec?: blob"                (vec? (make-blob 1))       nil)
(assert "vec?: hash-map"            (vec? (hash-map))          nil)
(assert "vec?: deque"               (vec? (deque))             nil)

;; blob?
(assert "blob?: empty blob"         (blob? (make-blob 0))      t)
(assert "blob?: populated blob"     (blob? (make-blob 5))      t)
(assert "blob?: from string"        (blob? (string->blob "x")) t)
(assert "blob?: nil"                (blob? nil)                nil)
(assert "blob?: string (not blob)"  (blob? "abc")              nil)
(assert "blob?: vec"                (blob? (vec 1 0))          nil)
(assert "blob?: list"               (blob? (list 1))           nil)

;; ---- reader literals: #b"..." (blob) and #{...} (set) round-trip the printer.
;; The REPL prints a printable blob as #b"..." and a set as #{...}; these forms
;; must read back to the same value (see reader's dispatch-macro handler).
(assert "blob literal: type"        (blob? #b"test")                       t)
(assert "blob literal: value"       (iso #b"test" (string->blob "test"))   t)
(assert "blob literal: escaped \""  (blob->string #b"a\"b")                "a\"b")
(assert "blob literal: backslash"   (blob->string #b"a\\b")                "a\\b")
(assert "set literal: type"         (set? #{1 2 3})                        t)
(assert "set literal: members"      (and (set-has? #{1 2 3} 1)
                                         (set-has? #{1 2 3} 2)
                                         (set-has? #{1 2 3} 3))            t)
(assert "set literal: non-member"   (set-has? #{1 2 3} 9)                  nil)
(assert "set literal: empty"        (set? #{})                             t)
(assert "set literal: mixed"        (set-has? #{1 "a" :k} :k)              t)
(assert "vector literal: #[]"       (vec? #[1 2 3])                        t)

;; RESP keyspace from Lisp — values are stored as existing exp_t containers
;; normalized to Redis-safe blobs/list/hash payloads.
(redis-flush)
(assert "redis-set string -> blob"
        (do (redis-set "alcove:test:string" "abc")
            (blob->string (redis-get "alcove:test:string")))
        "abc")
(assert "redis-set number -> blob"
        (do (redis-set "alcove:test:number" 42)
            (blob->string (redis-get "alcove:test:number")))
        "42")
(assert "redis-set deque type"
        (do (redis-set "alcove:test:list" (deque "a" (string->blob "b") 3))
            (redis-type "alcove:test:list"))
        "list")
(assert "redis-set hash-map type"
        (do (redis-set "alcove:test:hash" (hash-map "a" "b" "n" 9))
            (redis-type "alcove:test:hash"))
        "hash")
(assert "redis-val hash-map container"
        (dict? (redis-val "alcove:test:hash"))
        t)
(assert "redis-set vector type"
        (do (redis-set "alcove:test:vec" (vector 1 2 3))
            (redis-type "alcove:test:vec"))
        "vector")
(assert "redis-val vector container"
        (vec? (redis-val "alcove:test:vec"))
        t)
(assert "redis-val vector works with vec-dot"
        (vec-dot (redis-val "alcove:test:vec") (vector 1 1 1))
        6.0)
(assert "redis-del removes key"
        (redis-del "alcove:test:string")
        1)
(assert "redis-del missing"
        (redis-del "alcove:test:string")
        0)
(redis-flush)

;; --- (with-db n ...) — dynamic keyspace database selection ---
;; The body (and anything it calls) targets db n for its dynamic extent;
;; the previous db is restored afterward, even on error. db 0 is the shared
;; keyspace; 1..15 are separate. The selector is thread-local.
(redis-flush)
(redis-set "wd:k" "zero")
(with-db 1 (redis-flush) (redis-set "wd:k" "one"))
(assert "with-db: db0 unaffected"      (blob->string (redis-val "wd:k"))            "zero")
(assert "with-db: db1 isolated value"  (blob->string (with-db 1 (redis-val "wd:k"))) "one")
(assert "with-db: empty db is nil"     (with-db 5 (redis-val "wd:k"))               nil)
(assert "with-db: returns body value"  (with-db 1 (blob->string (redis-val "wd:k"))) "one")
;; nesting restores the outer db on exit
(assert "with-db: nesting restores"
        (with-db 1 (with-db 2 (redis-set "wd:k" "two")) (blob->string (redis-val "wd:k")))
        "one")
;; an error inside with-db still restores the previous db
(assert "with-db: error then error?"   (error? (with-db 1 (car 5) (no-such-binding-xyz))) t)
(assert "with-db: db restored after err" (blob->string (redis-val "wd:k"))            "zero")
;; counts are per-db
(assert "with-db: db1 count"           (with-db 1 (redis-count))                    1)
;; out-of-range index errors
(assert "with-db: range error"         (error? (with-db 99 (redis-count)))          t)
(redis-flush)
(with-db 1 (redis-flush))
(with-db 2 (redis-flush))

;; dict?
(assert "dict?: empty hash-map"     (dict? (hash-map))         t)
(assert "dict?: populated hash-map" (dict? (hash-map "k" 1))   t)
(assert "dict?: nil"                (dict? nil)                nil)
(assert "dict?: list"               (dict? (list 1 2))         nil)
(assert "dict?: vec"                (dict? (vec 1 0))          nil)
(assert "dict?: blob"               (dict? (make-blob 1))      nil)
(assert "dict?: deque"              (dict? (deque))            nil)

;; deque?
(assert "deque?: empty deque"       (deque? (deque))           t)
(assert "deque?: populated deque"   (deque? (deque 1 2 3))     t)
(assert "deque?: nil"               (deque? nil)               nil)
(assert "deque?: list (cons)"       (deque? (list 1 2))        nil)
(assert "deque?: vec"               (deque? (vec 1 0))         nil)
(assert "deque?: hash-map"          (deque? (hash-map))        nil)
(assert "deque?: number"            (deque? 0)                 nil)

;; no-arg behavior — every predicate accepts 0 args and returns nil
;; (matches the existing numberpcmd / pairpcmd convention).
(assert "vec?: no args"             (vec?)                     nil)
(assert "blob?: no args"            (blob?)                    nil)
(assert "dict?: no args"            (dict?)                    nil)
(assert "deque?: no args"           (deque?)                   nil)


;; ============================================================
;; Benchmark algorithms — correctness asserts on the same inputs
;; the perf suite (benchmark/*.alc) uses. The bodies are verbatim
;; from those files (with renamed top-level functions where the
;; benchmarks collide on common names like `safe?` / `try-cols`).
;; ============================================================

;; ---------- fib ----------
;; benchmark/fib.alc — runs (fib 33).
(def bm-fib (n)
  (if (< n 2)
      n
      (+ (bm-fib (- n 1)) (bm-fib (- n 2)))))
(assert "bench fib 33"              (bm-fib 33)                3524578)

;; ---------- fact ----------
;; benchmark/fact.alc — runs (fact 19) in a tight loop. 19! is the
;; largest factorial that fits in a 61-bit fixnum.
(def bm-fact (n)
  (if (< n 2) 1 (* n (bm-fact (- n 1)))))
(assert "bench fact 19"             (bm-fact 19)               121645100408832000)

;; ---------- countdown ----------
;; benchmark/countdown.alc — calls (countdown 1000) repeatedly; returns
;; n once n <= 0.
(def bm-countdown (n)
  (if (> n 0) (bm-countdown (- n 1)) n))
(assert "bench countdown 1000"      (bm-countdown 1000)        0)

;; ---------- ackermann ----------
;; benchmark/ackermann.alc — runs (ack 3 9) = 4093 with a fresh stack.
;; In test.alc the heavy prior state pushes us close to the default 8 MB
;; C stack, so we test (ack 3 7) = 1021 instead — same recursion shape,
;; fits in the stack budget. The benchmark itself still runs ack 3 9.
(def bm-ack (m n)
  (if (is m 0) (+ n 1)
      (if (is n 0) (bm-ack (- m 1) 1)
          (bm-ack (- m 1) (bm-ack m (- n 1))))))
(assert "bench ackermann 3 7"       (bm-ack 3 7)               1021)

;; ---------- forsum ----------
;; benchmark/forsum.alc — increments s by 1 in a for-loop n times.
(def bm-forsum (n)
  (let s 0
    (for i 1 n (= s (+ s 1)))))
(assert "bench forsum 1000000"      (bm-forsum 1000000)        1000000)

;; ---------- listsum ----------
;; benchmark/listsum.alc — sum of 1..N built into a cons list, reduced.
(def bm-build (i n acc) (if (> i n) acc (bm-build (+ i 1) n (cons i acc))))
(assert "bench listsum 1..100000"
        (reduce (fn (a b) (+ a b)) 0 (bm-build 1 100000 (list)))
        5000050000)

;; ---------- nqueens (cons-list version) ----------
;; benchmark/nqueens.alc — counts solutions on an N×N board.
(def nq-safe? (c qs offset)
  (if (no qs) t
      (if (is c (car qs)) nil
          (if (is (+ c offset) (car qs)) nil
              (if (is (- c offset) (car qs)) nil
                  (nq-safe? c (cdr qs) (+ offset 1)))))))
(def nq-try-cols (n c qs row-acc)
  (if (> c n) row-acc
      (nq-try-cols n (+ c 1) qs
        (if (nq-safe? c qs 1)
            (+ row-acc (nq-solve n (cons c qs)))
            row-acc))))
(def nq-solve (n qs)
  (if (is (length qs) n) 1
      (nq-try-cols n 1 qs 0)))
(assert "bench nqueens 10"          (nq-solve 10 (list))       724)

;; ---------- nqueens-vec ----------
;; benchmark/nqueens-vec.alc — same algorithm via a fixed-size vec.
;; With the typed-vec refactor (vec 10 0) → VEC_KIND_I64 and stays
;; that way because every vec-set! stores a fixnum.
(def nqv-safe? (col qs row offset)
  (if (>= offset row) t
      (if (is col (vec-ref qs offset)) nil
          (if (is (- col (- row offset)) (vec-ref qs offset)) nil
              (if (is (+ col (- row offset)) (vec-ref qs offset)) nil
                  (nqv-safe? col qs row (+ offset 1)))))))
(def nqv-try-cols (n row col qs acc)
  (if (>= col n) acc
      (if (nqv-safe? col qs row 0)
          (do (vec-set! qs row col)
              (nqv-try-cols n row (+ col 1) qs (+ acc (nqv-solve n (+ row 1) qs))))
          (nqv-try-cols n row (+ col 1) qs acc))))
(def nqv-solve (n row qs)
  (if (>= row n) 1
      (nqv-try-cols n row 0 qs 0)))
(assert "bench nqueens-vec 10"      (nqv-solve 10 0 (vec 10 0)) 724)

;; ---------- sieve (trial-division on cons list) ----------
;; benchmark/sieve.alc — counts primes up to 5000 via cons-list filter.
(def sv-is-prime-given (acc i)
  (if (no acc) t
      (if (is (mod i (car acc)) 0) nil
          (sv-is-prime-given (cdr acc) i))))
(def sv-primes-up-to (i n acc)
  (if (> i n) acc
      (if (sv-is-prime-given acc i)
          (sv-primes-up-to (+ i 1) n (cons i acc))
          (sv-primes-up-to (+ i 1) n acc))))
(assert "bench sieve up to 5000"
        (length (sv-primes-up-to 2 5000 (list)))            669)

;; ---------- sieve-fast (mark-composites on vec) ----------
;; benchmark/sieve-fast.alc — counts primes up to 100000 via marker
;; vec. Hits the JIT shape try_jit_mark_from + try_jit_count_primes
;; (the kind-check guards added in the typed-vec refactor must let
;; this through, since marks is VEC_KIND_GEN — fill = `t` heap exp_t).
(def sf-mark-composites (i n marks)
  (if (> (* i i) n) nil
      (do (if (vec-ref marks i)
              (sf-mark-from i (* i i) n marks)
              nil)
          (sf-mark-composites (+ i 1) n marks))))
(def sf-mark-from (step j n marks)
  (if (> j n) nil
      (do (vec-set! marks j nil)
          (sf-mark-from step (+ j step) n marks))))
(def sf-count-primes (i n marks acc)
  (if (> i n) acc
      (sf-count-primes (+ i 1) n marks
                       (if (vec-ref marks i) (+ acc 1) acc))))
(= sf-n 100000)
(= sf-marks (vec (+ sf-n 1) t))
(sf-mark-composites 2 sf-n sf-marks)
(assert "bench sieve-fast up to 100000"
        (sf-count-primes 2 sf-n sf-marks 0)                 9592)

;; ---------- tak ----------
;; benchmark/tak.alc — Knuth's tak(24, 16, 8) = 9. Heavy recursion.
(def bm-tak (x y z)
  (if (no (< y x))
      z
      (bm-tak (bm-tak (- x 1) y z)
              (bm-tak (- y 1) z x)
              (bm-tak (- z 1) x y))))
(assert "bench tak 24 16 8"         (bm-tak 24 16 8)           9)

;; ---------- float-accumulator self-tail loop (amd64 JIT shape) ----------
;; Integer counter + UNBOXED float accumulator kept in xmm0 across the loop;
;; matched by try_jit_float_acc_loop (jit_amd64.h). The limit is > i16 so the
;; counter compare is the generic LOAD_SLOT/LOAD_CONST/LT triple (the JIT'd
;; shape). Results must be byte-identical to the bytecode VM; in particular the
;; ZERO-iteration case must return the SEED UNCHANGED (an int seed stays an int,
;; a float seed stays a float — never a freshly boxed float). `iso` is
;; type-strict, so it distinguishes 50000 (int) from 50000.0 (float).
(def bm-faccadd (n acc) (if (< n 100000) (bm-faccadd (+ n 1) (+ acc 0.5)) acc))
(def bm-faccsub (n acc) (if (< n 100000) (bm-faccsub (+ n 1) (- acc 0.5)) acc))
(def bm-faccmul (n acc) (if (< n     64) (bm-faccmul (+ n 1) (* acc 2.0)) acc))
;; +0.5 * 100000 = 50000.0, exactly representable
(assert "facc add (float seed)"   (bm-faccadd 0 0.0)            50000.0)
;; int seed coerces to double from iteration 1 → same float result
(assert "facc add (int seed)"     (bm-faccadd 0 0)              50000.0)
(assert "facc add result is float"(iso (bm-faccadd 0 0) 50000.0) t)
(assert "facc add result not int" (iso (bm-faccadd 0 0) 50000)  nil)
(assert "facc sub"                (bm-faccsub 0 0.0)            -50000.0)
;; 2.0^64 — exact in double
(assert "facc mul"                (bm-faccmul 0 1.0)            (** 2.0 64))
;; zero-iteration passthrough: int seed must stay an INT (type-strict)
(assert "facc 0-iter int seed"    (iso (bm-faccadd 200000 7) 7)   t)
(assert "facc 0-iter int not flt" (iso (bm-faccadd 200000 7) 7.0) nil)
;; zero-iteration passthrough: float seed must stay the SAME float
(assert "facc 0-iter float seed"  (iso (bm-faccadd 200000 7.5) 7.5) t)
;; negative accumulator survives
(assert "facc negative seed"      (bm-faccadd 0 -25000.0)       25000.0)

;; ================================================================
;; Extended coverage — builtins not tested above
;; ================================================================

;; ---------- while ----------
(= wh-n 0)
(while (< wh-n 5) (= wh-n (+ wh-n 1)))
(assert "while counts to 5"            wh-n                           5)
(= wh-x 10)
(while nil (= wh-x 0))               ;; body never runs
(assert "while nil-cond never runs"    wh-x                           10)
(= wh-last 0)
(while (< wh-last 3) (= wh-last (+ wh-last 1)))
(assert "while final value"            wh-last                        3)

;; ---------- repeat ----------
(= rep-n 0)
(repeat 4 (= rep-n (+ rep-n 1)))
(assert "repeat 4 increments"          rep-n                          4)
(repeat 0 (= rep-n 99))              ;; zero iterations
(assert "repeat 0 is no-op"           rep-n                           4)

;; ---------- each ----------
(= each-sum 0)
(each x (list 10 20 30) (= each-sum (+ each-sum x)))
(assert "each list sum"               each-sum                        60)
(= each-acc (list))
(each x (list 1 2 3) (= each-acc (cons x each-acc)))
(assert "each list collect"           (length each-acc)               3)
(= each-empty 0)
(each x nil (= each-empty 99))      ;; empty list
(assert "each nil runs once"         each-empty                       99)

;; ---------- case ----------
(assert "case match first"            (case 1 1 "one" 2 "two")        "one")
(assert "case match second"           (case 2 1 "one" 2 "two")        "two")
(assert "case default"                (case 9 1 "one" "other")        "other")
(assert "case no match no default"    (case 9 1 "one" 2 "two")        nil)
(assert "case string key"             (case "b" "a" 1 "b" 2 "c" 3)   2)
(def classify (n)
  (case (mod n 3)
    0 "div3"
    1 "rem1"
    "rem2"))
(assert "case in fn: div3"            (classify 9)                    "div3")
(assert "case in fn: rem1"            (classify 7)                    "rem1")
(assert "case in fn: rem2"            (classify 8)                    "rem2")

;; ---------- bit-not / ~ ----------
(assert "bit-not 0 = -1"             (bit-not 0)                     -1)
(assert "bit-not -1 = 0"             (bit-not -1)                    0)
(assert "bit-not 1 = -2"             (bit-not 1)                     -2)
(assert "~ alias same as bit-not"    (~ 42)                          (bit-not 42))
(assert "bit-not inverts all bits"   (bit-not (bit-not 1234))         1234)
(assert "double-not identity"        (~ (~ -5))                      -5)

;; ---------- random ----------
(= rnd (random 100))
(assert "random in [0,100)"          (and (>= rnd 0) (< rnd 100))    t)
(assert "random 0 → 0"               (random 0)                      0)
(assert "random returns fixnum"      (number? (random 1000))         t)
(assert "random no-arg is fixnum"    (number? (random))              t)

;; ---------- macroexpand-1 ----------
(defmacro mx-double (x) (list '* 2 x))
(defmacro mx-swap (a b) (list 'list b a))
(= mx-res (macroexpand-1 '(mx-double 7)))
(assert "macroexpand-1 head"         (car mx-res)                    '*)
(assert "macroexpand-1 arg1"         (car (cdr mx-res))              2)
(assert "macroexpand-1 arg2"         (car (cdr (cdr mx-res)))        7)
(assert "macroexpand-1 non-macro"    (iso (macroexpand-1 '(+ 1 2))   '(+ 1 2)) t)
(assert "macroexpand-1 gives form"   (pair? (macroexpand-1 '(mx-swap a b))) t)

;; ---------- println (alias for prn) ----------
;; println returns nil, just verify it doesn't crash
(assert "println returns nil"        (no (println))                  t)

;; ---------- hash-map operations ----------
(= hm (hash-map "x" 10 "y" 20 "z" 30))
(assert "hash-map get x"             (get hm "x")                    10)
(assert "hash-map get y"             (get hm "y")                    20)
(assert "hash-map get missing nil"   (get hm "w")                    nil)
(assert "hash-map get with default"  (get hm "w" 99)                 99)
(assert "hash-map contains? true"    (contains? hm "x")              t)
(assert "hash-map contains? false"   (contains? hm "w")              nil)
(assert "hash-map keys count"        (length (keys hm))              3)
(assert "hash-map vals count"        (length (vals hm))              3)
(assert "hash-map empty"             (length (keys (hash-map)))       0)

;; assoc! adds a key
(assoc! hm "w" 40)
(assert "assoc! adds key"            (get hm "w")                    40)
(assert "assoc! grows map"           (length (keys hm))              4)

;; assoc! updates existing key
(assoc! hm "x" 100)
(assert "assoc! updates existing"    (get hm "x")                    100)
(assert "assoc! size unchanged"      (length (keys hm))              4)

;; dissoc! removes a key
(dissoc! hm "y")
(assert "dissoc! removes key"        (get hm "y" "gone")             "gone")
(assert "dissoc! shrinks map"        (length (keys hm))              3)

;; keys and vals are aligned
(= hm2 (hash-map "k" 7))
(= ks2 (keys hm2))
(= vs2 (vals hm2))
(assert "keys/vals aligned"
        (is (get hm2 (car ks2)) (car vs2))                           t)

;; ---------- hash-set alias ----------
(= hs (hash-set 1 2 3 2 1))
(assert "hash-set alias for set"     (set? hs)                       t)
(assert "hash-set deduplicates"      (count hs)                      3)
(assert "hash-set has member"        (set-has? hs 2)                 t)

;; ---------- blob-len and blob-ref ----------
(= bl (string->blob "Hello"))
(assert "blob-len of Hello"          (blob-len bl)                   5)
(assert "blob-ref 0 is H"            (blob-ref bl 0)                 72)    ;; 'H' = 72
(assert "blob-ref 4 is o"            (blob-ref bl 4)                 111)   ;; 'o' = 111
(assert "blob-len empty blob"        (blob-len (make-blob 0))        0)
(assert "blob-len make-blob 3"       (blob-len (make-blob 3))        3)

;; blob round-trip
(= bl2 (string->blob "world"))
(assert "blob->string roundtrip"     (blob->string bl2)              "world")
;; blob<->string conversion guards: blob->string must yield a valid,
;; NUL-free UTF-8 string or fail (string->blob is total — bytes are bytes).
(assert "blob->string utf8 roundtrip" (blob->string (string->blob "héllo世界😀"))
                                                                     "héllo世界😀")
(assert "blob->string empty"          (blob->string (make-blob 0))   "")
(assert "blob->string fails on NUL"   (error? (blob->string (make-blob 2))) t)
(assert "blob->string fails bad lead" (error? (blob->string (string->blob "\xff"))) t)
(assert "blob->string fails bad cont" (error? (blob->string (string->blob "\xc3\x28"))) t)

;; ---------- deque push/pop/peek operations ----------
(= dq (deque))
(push-right! dq 10)
(push-right! dq 20)
(push-right! dq 30)
(assert "deque count after 3 push"   (count dq)                      3)
(assert "peek-right last pushed"     (peek-right dq)                 30)
(assert "peek-left first pushed"     (peek-left dq)                  10)

(= prv (pop-right! dq))
(assert "pop-right returns last"     prv                             30)
(assert "deque count after pop-r"    (count dq)                      2)

(push-left! dq 5)
(assert "deque count after push-l"   (count dq)                      3)
(assert "peek-left after push-left"  (peek-left dq)                  5)

(= plv (pop-left! dq))
(assert "pop-left returns first"     plv                             5)
(assert "deque count after pop-l"    (count dq)                      2)

;; deque from constructor with initial elements
(= dq2 (deque 1 2 3))
(assert "deque constructor count"    (count dq2)                     3)
(assert "deque peek-left = 1"        (peek-left dq2)                 1)
(assert "deque peek-right = 3"       (peek-right dq2)                3)

;; deque? predicate
(assert "deque? deque is t"          (deque? (deque))                t)
(assert "deque? list is nil"         (deque? (list 1 2))             nil)
(assert "deque? nil is nil"          (deque? nil)                    nil)

;; ---------- apply with builtins and edge cases ----------
(assert "apply + empty"              (apply + (list))               0)
(assert "apply + list"               (apply + (list 1 2 3 4))       10)
(assert "apply * list"               (apply * (list 2 3 4))         24)
(assert "apply max"                  (apply max (list 3 1 4 1 5))   5)
(assert "apply min"                  (apply min (list 3 1 4 1 5))   1)
(assert "apply str"                  (apply str (list "a" "b" "c")) "abc")
(assert "apply list"                 (iso (apply list (list 1 2 3)) (list 1 2 3)) t)

;; ---------- map edge cases ----------
(assert "map empty list"             (iso (map (fn (x) x) nil) nil)  t)
(assert "map identity"               (iso (map (fn (x) x) (list 1 2 3)) (list 1 2 3)) t)
(assert "map square"                 (iso (map (fn (x) (* x x)) (list 2 3)) (list 4 9)) t)

;; ---------- filter edge cases ----------
(assert "filter all-pass"            (length (filter odd (list 1 3 5))) 3)
(assert "filter all-fail"            (iso (filter even (list 1 3 5)) nil) t)
(assert "filter empty"               (iso (filter odd nil) nil)         t)
(assert "filter one-pass"            (iso (filter (fn (x) (> x 3)) (list 1 2 3 4 5)) (list 4 5)) t)

;; ---------- reduce edge cases ----------
(assert "reduce sum"                 (reduce + 0 (list 1 2 3 4 5))   15)
(assert "reduce with string"         (reduce string-append "" (list "a" "b" "c")) "abc")
(assert "reduce empty list"          (reduce + 0 nil)                0)
(assert "reduce single element"      (reduce + 0 (list 7))           7)

;; ---------- setq multi-binding ----------
(setq sq-a 1 sq-b 2 sq-c 3)
(assert "setq multi a"               sq-a                            1)
(assert "setq multi b"               sq-b                            2)
(assert "setq multi c"               sq-c                            3)

;; ---------- do evaluates all exprs, returns last ----------
(= do-side 0)
(= do-ret (do (= do-side 1) (= do-side 2) 42))
(assert "do side effects ran"        do-side                         2)
(assert "do returns last"            do-ret                          42)

;; ---------- let/with scoping edge cases ----------
(assert "let inner shadows outer"
        (let x 99 (let x 1 x))                                      1)
(assert "let outer visible after inner"
        (let x 5 (let y 10 (+ x y)))                                15)
(assert "with multiple bindings"
        (with (a 3 b 4) (+ (* a a) (* b b)))                        25)

;; ---------- string edge cases ----------
(assert "string-append empty"        (string-append)                 "")
(assert "string-append single"       (string-append "hi")            "hi")
(assert "string-append multiple"     (string-append "a" "b" "c")     "abc")
(assert "substr full"                (substr "hello" 0 5)            "hello")
(assert "substr from middle"         (substr "hello" 1 4)            "ell")
(assert "substr empty range"         (substr "hello" 2 2)            "")
(assert "string-join empty list"     (string-join (list) ",")        "")
(assert "string-join one element"    (string-join (list "a") ",")    "a")
(assert "string-split returns list"  (pair? (string-split "a,b" ",")) t)
(assert "string-split count"         (length (string-split "a,b,c" ",")) 3)
(assert "str of number"              (str 42)                        "42")
(assert "str of float"               (str 1.5)                       "1.5")
(assert "str of nil"                 (str nil)                       "nil")

;; ---------- number edge cases ----------
(assert "integer division truncates" (/ 7 2)                         3)
(assert "float division"             (/ 7.0 2)                       3.5)
(assert "mod positive"               (mod 10 3)                      1)
(assert "mod negative dividend"      (mod -7 3)                      -1)
(assert "abs of zero"                (abs 0)                         0)
(assert "expt 0 0 = 1"              (expt 0 0)                      1)
(assert "expt 2 10 = 1024"          (expt 2 10)                     1024)
(assert "sqrt of 0"                  (sqrt 0)                        0.0)
(assert "max two args"               (max 3 5)                       5)
(assert "max three args"             (max 1 5 3)                     5)
(assert "min two args"               (min 3 5)                       3)
(assert "min three args"             (min 4 1 3)                     1)

;; ---------- boolean / logic edge cases ----------
(assert "and short-circuits"         (and t t t)                     t)
(assert "and returns first false"    (and t nil t)                   nil)
(assert "and empty"                  (and)                           t)
(assert "or returns first true"      (or nil nil 42)                 42)
(assert "or all false"               (or nil nil nil)                nil)
(assert "or empty"                   (or)                            nil)
(assert "not of t"                   (not t)                         nil)
(assert "not of nil"                 (not nil)                       t)
(assert "not of 0 is t"              (not 0)                         t)    ;; 0 is FALSY in Alcove

;; ---------- pair/list edge cases ----------
(assert "cons builds pair"           (pair? (cons 1 2))              t)
(assert "list builds cons chain"     (pair? (list 1 2 3))            t)
(assert "length of nil"              (length nil)                    0)
(assert "length of pair list"        (length (list 1 2 3 4))         4)
(assert "nth 0 list"                 (nth 0 (list 10 20 30))         10)
(assert "nth 2 list"                 (nth 2 (list 10 20 30))         30)
(assert "nth out-of-range nil"       (nth 5 (list 1 2 3))            nil)
(assert "reverse nil"                (iso (reverse nil) nil)         t)
(assert "reverse one"                (iso (reverse (list 1)) (list 1)) t)
(assert "append nil nil"             (iso (append nil nil) nil)      t)

;; ---------- char edge cases ----------
(assert "char? char"                 (char? #\a)                     t)
(assert "char? int"                  (char? 65)                      nil)
(assert "char=char"                  (is #\a #\a)                    t)
(assert "char<>char"                 (is #\a #\b)                    nil)

;; ---------- equality ----------
(assert "is same fixnum"             (is 42 42)                      t)
(assert "is same string ptr"         (is "hi" "hi")                  t)    ;; Alcove interns string literals
(assert "iso equal strings"          (iso "hi" "hi")                 t)
(assert "iso equal lists"            (iso (list 1 2) (list 1 2))     t)
(assert "iso nil nil"                (iso nil nil)                   t)
(assert "isnt"                       (isnt 1 2)                      t)
(assert "isnt same"                  (isnt 1 1)                      nil)

;; ---------- type predicates (comprehensive) ----------
(assert "number? fixnum t"           (number? 42)                    t)
(assert "number? float t"            (number? 3.14)                  t)
(assert "number? string nil"         (number? "42")                  nil)
(assert "number? nil nil"            (number? nil)                   nil)
(assert "string? string t"           (string? "hi")                  t)
(assert "string? fixnum nil"         (string? 42)                    nil)
(assert "pair? pair t"               (pair? (cons 1 2))              t)
(assert "pair? nil nil"              (pair? nil)                     nil)
(assert "fn? lambda t"               (fn? (fn (x) x))               t)
(assert "fn? builtin t"              (fn? car)                       t)
(assert "fn? nil nil"                (fn? nil)                       nil)
(assert "nil? nil t"                 (nil? nil)                      t)
(assert "nil? 0 nil"                 (nil? 0)                        nil)
(assert "zero? 0 t"                  (zero? 0)                       t)
(assert "zero? 1 nil"                (zero? 1)                       nil)
(assert "yes nil t"                  (yes nil)                       nil)
(assert "yes 0 t"                    (yes 0)                         t)
(assert "no nil t"                   (no nil)                        t)
(assert "no 0 is t"                  (no 0)                          t)    ;; 0 is FALSY in Alcove
(assert "in member"                  (in 2 1 2 3)                    t)
(assert "in not-member"              (in 5 1 2 3)                    nil)

;; ---------- bitwise ops (comprehensive) ----------
(assert "bit-and 12 10"              (bit-and 12 10)                 8)
(assert "bit-or  12 10"              (bit-or 12 10)                  14)
(assert "bit-xor 12 10"              (bit-xor 12 10)                 6)
(assert "bit-not 5"                  (bit-not 5)                     -6)
(assert "bit-not -1"                 (bit-not -1)                    0)
(assert "<< 1 4 = 16"                (<< 1 4)                        16)
(assert ">> 16 2 = 4"                (>> 16 2)                       4)
(assert ">> neg / sign-ext"          (>> -8 1)                       -4)

;; ---------- vec comprehensive ----------
(= tv (vec 5 0))
(for i 0 4 (vec-set! tv i (* i i)))
(assert "vec-set!/ref loop"          (vec-ref tv 4)                  16)
(assert "vec-ref tv 0"               (vec-ref tv 0)                  0)
(assert "vec-ref tv 2"               (vec-ref tv 2)                  4)
(assert "vec-len 5"                  (vec-len tv)                    5)

;; vec window via push/pop
(= tv2 (vec 3 0))
(vec-set! tv2 0 10) (vec-set! tv2 1 20) (vec-set! tv2 2 30)
(vec-push! tv2 40)
(assert "vec-push grows"             (vec-len tv2)                   4)
(assert "vec-push end value"         (vec-ref tv2 3)                 40)
(= pv (vec-pop! tv2))
(assert "vec-pop returns last"       pv                              40)
(assert "vec-pop shrinks"            (vec-len tv2)                   3)

;; ---------- error recovery after each type of error ----------
(/ 1 0)
(assert "recovery after div-by-zero" 1                               1)
(nth 0 42)
(assert "recovery after nth-non-list" 1                              1)
(vec-ref (vec 3 0) 99)
(assert "recovery after vec-ref OOB" 1                               1)
(car 42)
(assert "recovery after car-non-pair" 1                              1)

;; ================================================================
;; Bug-fix regression tests
;; ================================================================

;; Bug 1: char.h chr2hex — '9', 'F', 'f' were missing
;; All \xNN escapes involving those digits now parse correctly.
(assert "hex escape \\x09 = tab"     (is "\x09" "\x09")               t)
(assert "hex escape \\x0f = \\x0F"  (iso "\x0f" "\x0F")               t)
(assert "hex escape \\x39 = 9"      (blob-ref (string->blob "\x39") 0) 57)
(assert "hex escape \\x19"          (blob-len (string->blob "\x19"))   1)
(assert "hex escape \\xff"          (blob-len (string->blob "\xff"))   1)

;; Bug 2: dump_str treated fwrite(…,0) == 0 as error
;; Anonymous lambda persistence (indirect test via savedb/loaddb).
(def _anon_persist (fn (x) (* x x)))
(savedb "/tmp/alcove-bugfix-dump.db")
(loaddb "/tmp/alcove-bugfix-dump.db")
(assert "savedb/loaddb after fix"    1                                 1)

;; Bug 3: (-)  and  (/)  with no args silently returned 0
(assert "(-) is error"               (no (- ))                         nil) ;; (- ) is error → truthy → no=nil? no: error is truthy, no(truthy)=nil
;; Better: recovery pattern — (- ) fires error, execution continues
(- )
(assert "(-) recovery"              1                                  1)
(/ )
(assert "(/) recovery"              1                                  1)

;; Bug 4: (- FIXMIN) and (abs FIXMIN) wrapped to negative
;; FIXMIN = -(2^60) = -1152921504606846976
(= fixmin -1152921504606846976)
(assert "abs FIXMIN promoted float"  (> (abs fixmin) 0)               t)
(assert "negate FIXMIN promoted float" (> (- fixmin) 0)               t)
(assert "abs positive preserved"     (abs 42)                          42)
(assert "abs float unchanged"        (abs -2.5)                        2.5)
(assert "(- 5) still works"          (- 5)                             -5)
(assert "(- -5) still works"         (- -5)                            5)

;; Bug 5: pair_add_node had duplicate EXP_PAIR check — EXP_TREE unreachable
;; Indirect: parser builds trees from nested expressions; verify deep nesting
(assert "deeply nested parse ok"
        (+ (+ (+ 1 2) (+ 3 4)) (+ (+ 5 6) (+ 7 8)))                  36)

;; Bug 6: vecunshiftcmd use-after-free on write failure
;; Can't easily trigger the failure path, but verify the happy path still works
(= _ushift_v (vec 3 0))
(vec-set! _ushift_v 0 10)
(vec-set! _ushift_v 1 20)
(vec-set! _ushift_v 2 30)
(vec-unshift! _ushift_v 5)
(assert "vec-unshift! still works"   (vec-ref _ushift_v 0)             5)
(assert "vec-unshift! length"        (vec-len _ushift_v)               4)

;; Bug 7: load_pair always returned e even on sub-read failure
;; Can't trigger without corrupt db; verify normal load still works
(assert "load_pair happy path"       (car '(1 2 3))                    1)
(assert "nested pairs parse ok"      (car (cdr '(a b c)))              'b)

;; Bug 12: load handlers leaked placeholder exp_t on read failure
;; Indirect test: verify a full savedb/loaddb round-trip with all types
(= _saved_str "hello")
(= _saved_num 42)
(= _saved_float 3.14)
(persist '_saved_str) (persist '_saved_num) (persist '_saved_float)
(savedb "/tmp/alcove-bug12-test.db")
(forget '_saved_str) (forget '_saved_num) (forget '_saved_float)
(loaddb "/tmp/alcove-bug12-test.db")
(assert "load string roundtrip"      _saved_str                       "hello")
(assert "load number roundtrip"      _saved_num                       42)
(assert "load float roundtrip"       (iso _saved_float 3.14)          t)

;; Bug 13: sqrt-int signed overflow near INT64_MAX
;; Largest fixnum is 2^60 - 1 = 1152921504606846975; sqrt ≈ 1073741824
(assert "sqrt-int large fixnum"      (sqrt-int 1152921504606846975)   1073741823)
(assert "sqrt-int perfect square"    (sqrt-int 1073741824)            32768)
(assert "sqrt-int near max correct"  (* (sqrt-int 1152921504606846975)
                                        (sqrt-int 1152921504606846975))
                                     1152921502459363329)

;; Bug 14: unrefexp nref underflow guard — no direct test (crash on double-free),
;; but verify normal unrefexp paths still work after the guard was added
(assert "normal refcount still works" (+ 1 2)                         3)
(= _tmp_str "guard test") (= _tmp_str nil)  ;; exercise unrefexp on a heap obj
(assert "string unrefexp ok"          1                               1)

;; ===================================================================
;; Smoke tests for the language-improvements feature set. One assert
;; per builtin family — enough to catch a regression that silently
;; drops or breaks a feature, without duplicating exhaustive coverage.
;; ===================================================================

;; --- math group (all return floats) ---
(assert "round"                       (iso (round 2.6) 3.0)            t)
(assert "floor"                       (iso (floor 2.9) 2.0)            t)
(assert "ceil"                        (iso (ceil 2.1) 3.0)             t)
(assert "truncate toward zero"        (iso (truncate -2.7) -2.0)       t)
(assert "log 1 = 0"                   (iso (log 1.0) 0.0)              t)
(assert "sin 0 = 0"                   (iso (sin 0.0) 0.0)              t)
(assert "cos 0 = 1"                   (iso (cos 0.0) 1.0)              t)
(assert "float coerces int"           (iso (float 5) 5.0)              t)
(assert "int truncates float"         (int 3.9)                        3)

;; --- fmt: default + printf specs + injection guard ---
(assert "fmt default + float spec"    (fmt "{} + {} = {:.1f}" 1 2 3.0) "1 + 2 = 3.0")
(assert "fmt hex spec"                (fmt "{:x}" 255)                 "ff")
(assert "fmt zero-pad width"          (fmt "{:05d}" 42)                "00042")
(assert "fmt rejects '*' (no UB)"     (fmt "{:*d}" 5)                  "{:*d}")
(assert "fmt rejects embedded %"      (fmt "{:d%d}" 5)                 "{:d%d}")

;; --- quasiquote / unquote / unquote-splicing ---
(assert "quasiquote unquote"          (iso `(1 ,(+ 1 1) 3) (list 1 2 3))         t)
(= _qsplice (list 2 3))
(assert "quasiquote splice"           (iso `(1 ,@_qsplice 4) (list 1 2 3 4))     t)

;; --- list utilities ---
(assert "sort default"                (iso (sort (list 3 1 2)) (list 1 2 3))     t)
(assert "sort-by key-fn"              (iso (sort-by (fn (x) (- 0 x)) (list 1 2 3))
                                           (list 3 2 1))                          t)
(assert "take n"                      (iso (take 2 (list 1 2 3 4)) (list 1 2))   t)
(assert "drop n"                      (iso (drop 2 (list 1 2 3 4)) (list 3 4))   t)
(assert "range start end"             (iso (range 0 4) (list 0 1 2 3))           t)
(assert "range with step"             (iso (range 0 6 2) (list 0 2 4))           t)
(assert "zip stops at shorter"        (iso (zip (list 1 2) (list 3 4))
                                           (list (list 1 3) (list 2 4)))          t)
(assert "flatten nested"              (iso (flatten (list 1 (list 2 (list 3))))
                                           (list 1 2 3))                          t)
(assert "list? proper list"           (list? (list 1 2))               t)
(assert "null? nil"                   (null? nil)                      t)

;; --- gensym / with-gensyms ---
(assert "gensym is a symbol"          (symbol? (gensym))               t)
(assert "with-gensyms binds symbols"  (with-gensyms (a b) (symbol? a)) t)
(assert "with-gensyms names distinct" (with-gensyms (a b) (is a b))    nil)

;; --- string utilities ---
(assert "string-contains? hit"        (string-contains? "hello world" "world")   t)
(assert "string-contains? miss"       (string-contains? "abc" "xyz")             nil)
(assert "string-index"                (string-index "hello" "ll")     2)
(assert "string-replace all"          (string-replace "a-b-c" "-" "+") "a+b+c")

;; --- error handling: error? / error-message / try ---
(assert "error? on error value"       (error? (/ 1 0))                 t)
(assert "error? on non-error"         (error? 5)                       nil)
(assert "error-message is a string"   (string? (error-message (/ 1 0))) t)
(assert "try passes value through"    (try (+ 1 2) (fn (e) 99))        3)
(assert "try catches + runs handler"  (try (/ 1 0) (fn (e) 'caught))   'caught)

;; --- rest params: bare-symbol and dotted ---
(def restfn-all args args)
(assert "rest: bare-symbol collects"  (iso (restfn-all 1 2 3) (list 1 2 3))      t)
(def restfn-dot (a . more) more)
(assert "rest: dotted after fixed"    (iso (restfn-dot 1 2 3) (list 2 3))        t)
(assert "rest: anon fn bare-symbol"   (iso ((fn xs xs) 7 8) (list 7 8))          t)

;; ====================================================================
;; Regression tests for the memory-safety + type-dispatch audit.
;; Each block guards a specific bug fixed after the vec-push! OOB.
;; ====================================================================

;; --- vec-push! growth at small-cap / full boundaries (heap OOB) ---
;; A full vector at start==0 must REALLOC, not take the no-op slide path.
(= _vp (vec 3 0))
(vec-push! _vp 9) (vec-push! _vp 8) (vec-push! _vp 7)
(assert "vec-push! small-cap grows (len)"   (vec-len _vp)        6)
(assert "vec-push! small-cap value @3"      (vec-ref _vp 3)      9)
(assert "vec-push! small-cap value last"    (vec-ref _vp 5)      7)
(assert "vec-ref oob returns error"         (error? (vec-ref _vp 99)) t)
(= _vp1 (vec 1 0)) (vec-push! _vp1 1)
(assert "vec-push! cap1 boundary"           (vec-len _vp1)       2)
(= _vp2 (vec 2 0)) (vec-push! _vp2 1) (vec-push! _vp2 2)
(assert "vec-push! cap2 boundary"           (vec-len _vp2)       4)
;; many pushes (exercise repeated growth)
(= _vpm (vec 1 0)) (for i 1 50 (vec-push! _vpm i))
(assert "vec-push! many: length"            (vec-len _vpm)       51)
(assert "vec-push! many: last value"        (vec-ref _vpm 50)    50)
;; shift then push: exercises the slide-left branch (start>0)
(= _vs (vec 1 5)) (vec-push! _vs 6) (vec-push! _vs 7)
(vec-shift! _vs) (vec-shift! _vs)              ; start now > 0
(vec-push! _vs 8) (vec-push! _vs 9)
(assert "vec-push! after shifts"            (vec-ref _vs (- (vec-len _vs) 1)) 9)

;; --- vec-unshift! growth at front boundary ---
(= _vu (vec 2 0)) (for i 1 30 (vec-unshift! _vu i))
(assert "vec-unshift! grows (len)"          (vec-len _vu)        32)
(assert "vec-unshift! front value"          (vec-ref _vu 0)      30)

;; --- substr bounds: start > len must not OOB (clamp), no crash ---
(assert "substr start>len -> empty"         (substr "ab" 5 9)    "")
(assert "substr start==len boundary"        (substr "abc" 3 5)   "")
(assert "substr empty-range"                (substr "abc" 4 4)   "")
(assert "substr negative start clamps"      (substr "abc" -5 2)  "ab")
(assert "substr normal interior"            (substr "hello" 1 3) "el")
(assert "substr end>len clamps"             (substr "ab" 1 99)   "b")

;; --- cons must keep a falsey-but-non-nil cdr (nil-conflation) ---
(assert "cons keeps 0 cdr"                  (cdr (cons 1 0))     0)
(assert "cons keeps empty-str cdr"          (cdr (cons 1 ""))    "")
(assert "cons nil cdr -> proper list"       (iso (cons 1 nil) (list 1))   t)
(assert "cons list cdr -> prepend"          (iso (cons 1 (list 2 3)) (list 1 2 3)) t)
(assert "cons improper pair car"            (car (cons 4 5))     4)

;; --- iso recurses into vectors (documented contract) ---
(assert "iso equal vectors"                 (iso (vector 1 2 3) (vector 1 2 3))   t)
(assert "iso vectors differ"                (iso (vector 1 2 3) (vector 1 2 4))   nil)
(assert "iso vectors length differ"         (iso (vector 1 2) (vector 1 2 3))     nil)
(assert "iso nested vectors"                (iso (vector (vector 1) (vector 2))
                                                 (vector (vector 1) (vector 2)))  t)
(assert "iso vector inside list"            (iso (list (vector 1 2)) (list (vector 1 2))) t)
(assert "is (identity) on vectors is nil"   (is (vector 1 2) (vector 1 2))        nil)

;; --- truthiness of function values (istrue completeness) ---
(assert "lambda is truthy"                  (if (fn (x) x) 'y 'n) 'y)
(assert "builtin is truthy"                 (if car 'y 'n)        'y)
(assert "no of a lambda is nil"             (no (fn (x) x))       nil)

;; --- str/fmt of containers: structural + deterministic (not #<addr>) ---
(assert "str of vector"                     (str (vector 1 2 3))  "#[1 2 3]")
(assert "str of deque"                      (str (deque 1 2 3))   "(1 2 3)")
(assert "str of improper pair"              (str (cons 1 2))      "(1 . 2)")
(assert "str of nested vector"              (str (vector (list 2 3))) "#[(2 3)]")
;; deterministic: two calls produce the identical string
(assert "str of vector is deterministic"    (iso (str (vector 9 8)) (str (vector 9 8))) t)

;; --- dict / deque round-trip through savedb (EXP_DICT / EXP_LIST) ---
(= _rt_dict (hash-map "a" 1 "b" 2 :kw 3))
(= _rt_deque (deque 10 20 30))
(= _rt_nested (hash-map "q" (deque 1 2) "v" (vector 5 6)))
(persist '_rt_dict) (persist '_rt_deque) (persist '_rt_nested)
(savedb "/tmp/alcove-dictdeque-test.db")
(forget '_rt_dict) (forget '_rt_deque) (forget '_rt_nested)
(loaddb "/tmp/alcove-dictdeque-test.db")
(assert "dict roundtrip value a"            (get _rt_dict "a")        1)
(assert "dict roundtrip keyword key"        (get _rt_dict :kw)        3)
(assert "dict roundtrip count"              (count _rt_dict)          3)
;; iso doesn't do deep deque equality (doc only claims pairs/strings/vectors),
;; so compare deque contents via their deterministic str form.
(assert "deque roundtrip contents"          (str _rt_deque)           "(10 20 30)")
(assert "deque roundtrip count"             (count _rt_deque)         3)
(assert "nested dict->deque roundtrip"      (str (get _rt_nested "q")) "(1 2)")
(assert "nested dict->vec roundtrip"        (iso (get _rt_nested "v") (vector 5 6)) t)
;; vec-of-dicts (the old catastrophic case) now persists instead of aborting
(= _rt_vd (vector (hash-map "x" 9)))
(persist '_rt_vd)
(savedb "/tmp/alcove-vecdict-test.db")
(forget '_rt_vd)
(loaddb "/tmp/alcove-vecdict-test.db")
(assert "vec-of-dict roundtrips"            (get (vec-ref _rt_vd 0) "x") 9)

;; --- savedb: a still-non-dumpable nested element must NOT lose other vars ---
;; A builtin (EXP_INTERNAL) has no dump fn. A vector holding one is skipped
;; with a warning; dump_vec returning NULL mid-record used to instead
;; truncate the whole file and drop every persisted variable on reload.
(= _sd_good 777)
(= _sd_bad (vector car))                     ; vec holding a builtin = not dumpable
(persist '_sd_good) (persist '_sd_bad)
(savedb "/tmp/alcove-dumploss-test.db")      ; skips _sd_bad (warns on stderr)
(forget '_sd_good)
(loaddb "/tmp/alcove-dumploss-test.db")
(assert "savedb keeps good var despite bad nested" _sd_good 777)

;; --- try: a real lambda handler actually runs on error ---
(assert "try handler computes from error"
        (string-contains? (try (/ 1 0) (fn (e) (str "E:" (error-message e)))) "E:")
        t)
(assert "try finally runs, returns body"    (try (+ 2 3) (fn (e) -1) 0)   5)
(assert "try finally runs, returns handler" (try (/ 1 0) (fn (e) 42) 0)   42)
(assert "try nil handler propagates error"  (error? (try (/ 1 0) nil))    t)

;; --- try in TAIL position: handler-stack VM path (decouples handler lifetime
;;     from the C stack so deep try-per-level recursion doesn't blow it). ---
;; side-effect counter (proves finally runs the right number of times).
(= _tc 0)
(def _tc_reset () (= _tc 0))
(def _tc_bump  () (= _tc (+ _tc 1)))
(def _tc_count () _tc)
;; call/cc escape passing THROUGH a try must NOT be caught by the handler — it
;; belongs to the matching call/cc frame. (Was wrongly caught → returned 99.)
(assert "call/cc escapes through try"  (call/cc (fn (k) (try (k 42) (fn (e) 99))))  42)
;; ...but a try with no escape in the body still returns the body value.
(assert "try body no escape value"     (call/cc (fn (k) (try 7 (fn (e) 99))))       7)
;; finally still runs when an escape passes through (Scheme-style unwind).
(_tc_reset)
(assert "call/cc escape runs finally"
        (do (call/cc (fn (k) (try (k 5) (fn (e) 99) (_tc_bump)))) (_tc_count)) 1)

;; Deep try-per-level recursion: the try wraps each recursive call. Each level
;; pushes a handler; they accumulate on the heap (O(n)), NOT the C stack — so no
;; segfault. (Pre-fix: SEGV around depth 50000.)
(def _try_deep (n a) (try (if (< n 1) a (_try_deep (- n 1) (+ a 1))) (fn (e) -1)))
(assert "deep try-per-level 1e6"       (_try_deep 1000000 0)   1000000)

;; An error thrown at the base is caught by the INNERMOST handler; its value
;; propagates up through every (now-normal) outer try.
(def _try_catch (n) (try (if (< n 1) (/ 1 0) (_try_catch (- n 1))) (fn (e) n)))
(assert "deep try catch innermost"     (_try_catch 5)      0)
(assert "deep try catch innermost big" (_try_catch 100000) 0)

;; The innermost handler sees its OWN level's bindings (env snapshot), even
;; though OP_TAIL_SELF reuses the env in place across the recursion.
(def _try_lvl (n) (try (if (< n 1) (/ 1 0) (_try_lvl (- n 1))) (fn (e) n) nil))
(assert "tail-try handler sees own n"  (_try_lvl 3)        0)

;; finally runs exactly once per try on every path: normal, caught, re-raised.
(_tc_reset)
(def _try_finc (n) (try (if (< n 1) 0 (_try_finc (- n 1))) (fn (e) -1) (_tc_bump)))
(assert "tail-try finally runs n times" (do (_try_finc 4) (_tc_count)) 5)
(_tc_reset)
;; caught path: base raises, caught at base, value flows up; finally at all levels.
(def _try_fin2 (n) (try (if (< n 1) (/ 1 0) (_try_fin2 (- n 1))) (fn (e) 0) (_tc_bump)))
(assert "tail-try finally on caught"    (do (_try_fin2 4) (_tc_count)) 5)
;; re-raise: nil handler at every level re-propagates; finally still runs each.
(_tc_reset)
(def _try_reraise (n) (try (if (< n 1) (/ 1 0) (_try_reraise (- n 1))) nil (_tc_bump)))
(assert "tail-try reraise propagates"   (error? (_try_reraise 3)) t)
(assert "tail-try reraise ran finally"  (_tc_count) 4)
;; a handler that itself errors is caught by the NEXT-OUT handler.
(def _try_hraise (n)
  (if (is n 0)
      (try (/ 1 0) (fn (e) (/ 1 0)))            ; innermost: handler re-errors
      (try (_try_hraise (- n 1)) (fn (e) 'outer-caught))))
(assert "tail-try handler-error caught next-out" (_try_hraise 2) 'outer-caught)

;; --- higher-order builtins: a NULL list arg = empty list, not an error ---
;; (cdr <1-elem>) yields C NULL (not NIL_EXP); filter/map/reduce/any?/all?/
;; sort-by used to reject it as "(... pred list)" missing-param and error,
;; which broke any recursion that fed a filtered/mapped tail back in.
(assert "filter on (cdr 1-elem) = empty"  (filter (fn (x) (> x 3)) (cdr (list 6)))   nil)
(assert "map on (cdr 1-elem) = empty"     (map (fn (x) x) (cdr (list 6)))            nil)
(assert "reduce on (cdr 1-elem) = init"   (reduce (fn (a x) (+ a x)) 7 (cdr (list 6))) 7)
(assert "any? on (cdr 1-elem) = nil"      (any? (fn (x) (> x 3)) (cdr (list 6)))     nil)
(assert "all? on (cdr 1-elem) = t"        (all? (fn (x) (> x 3)) (cdr (list 6)))     t)
(assert "sort-by on (cdr 1-elem) = empty" (sort-by (fn (x) x) (cdr (list 6)))        nil)
;; the actual TODO repro: filter inside a recursive fn (vanished mid-recursion)
(def rec-filt (xs)
  (if (no xs) (list)
      (cons (car xs) (rec-filt (filter (fn (x) (> x 3)) (cdr xs))))))
(assert "filter inside recursion"         (iso (rec-filt (list 5 1 6 2 7)) (list 5 6 7)) t)
;; arity is still enforced — a genuinely missing list arg errors
(assert "filter missing list errors"      (error? (filter (fn (x) x)))               t)
(assert "reduce missing list errors"      (error? (reduce (fn (a x) a) 0))           t)

;; --- (do (call) other) / recursion after a call (TODO bugs 1 + 3) ---
(def hb-id (x) x)
(assert "do: value after identity call"   (do (hb-id 1) 42)                          42)
(def hb-g (x) x)
(def hb-rec (i) (if (> i 3) i (do (hb-g 5) (hb-rec (+ i 1)))))
(assert "do: call then tail recurse"      (hb-rec 1)                                 4)
(def hb-rec2 (i)
  (if (> i 3) i (do (any? (fn (d) (is d 0)) (list 1)) (hb-rec2 (+ i 1)))))
(assert "do: any? then tail recurse"      (hb-rec2 1)                                4)

;; --- closures compile to bytecode; free vars stay correct (no_gcache) ---
;; Read-only-free closures now compile (LOAD_GLOBAL does a fresh lookup
;; against the captured env each time, never a stale gcache hit). Closures
;; that MUTATE a free var can't slot-resolve it and fall back to AST.
(def cl-adder (n) (fn (x) (+ x n)))
(= cl-add5 (cl-adder 5))
(= cl-add9 (cl-adder 9))
(assert "closure: captures n=5"          (cl-add5 7)                  12)
(assert "closure: captures n=9"          (cl-add9 7)                  16)
(assert "closure: instances independent" (cl-add5 100)                105)
;; a read closure must see a free var mutated AFTER it was captured
(def cl-late () (let n 1 (let f (fn () n) (do (= n 99) f))))
(assert "closure: free var post-capture mutation" ((cl-late))         99)
;; two closures sharing one captured cell: a (compiled) reader sees writes
;; made through a sibling (AST) mutator — proves no_gcache re-resolution
(def cl-cell () (let n 10 (list (fn () n) (fn (v) (= n v)))))
(= cl-pair (cl-cell))
(= cl-get (car cl-pair))
(= cl-set (car (cdr cl-pair)))
(assert "closure: shared cell initial"   (cl-get)                     10)
(cl-set 77)
(assert "closure: shared cell after set" (cl-get)                     77)
;; nested closures
(def cl-mk3 (a) (fn (b) (fn (c2) (+ a b c2))))
(assert "closure: triple-nested"         (((cl-mk3 1) 2) 3)           6)
;; mutating closure (make_counter) — independent, monotonic
(def cl-counter () (let k 0 (fn () (do (= k (+ k 1)) k))))
(= cl-c1 (cl-counter))
(= cl-c2 (cl-counter))
(assert "closure: counter c1 step1"      (cl-c1)                      1)
(assert "closure: counter c1 step2"      (cl-c1)                      2)
(assert "closure: counter c2 independent" (cl-c2)                     1)
(assert "closure: counter c1 unaffected" (cl-c1)                      3)

;; --- reserved-name bindings are rejected (fail-fast, not silent shadow) ---
;; lookup() resolves reserved symbols before the lexical env, so binding a
;; variable named after a builtin used to silently shadow it. Now it errors.
(assert "fn reserved param errors"     (error? (fn (count) count))            t)
(assert "fn reserved param message"
        (string-contains? (error-message (fn (list) 1)) "reserved")           t)
(assert "let reserved var errors"      (error? (let list 5 list))             t)
(assert "let* reserved var errors"     (error? (let* (map 1) map))            t)
(assert "with reserved var errors"     (error? (with (count 1) count))        t)
(assert "for reserved var errors"      (error? (for time 1 3 time))           t)
(assert "destructuring reserved errors" (error? (fn ((str x)) x))             t)
;; non-reserved names still bind fine
(assert "non-reserved fn param ok"     ((fn (cnt) (+ cnt 1)) 41)              42)
(assert "non-reserved let ok"          (let lst 5 (+ lst 1))                  6)
(assert "non-reserved with ok"         (with (a 2 b 3) (+ a b))               5)
(assert "non-reserved for ok"          (let s 0 (for i 1 4 (= s (+ s i))) s)  10)

;; --- default / optional parameters: (def f (x (y 10)) ...) ---
;; A pair param whose 2nd element is NOT a symbol is a default; (a b) with
;; symbol elements stays destructuring. Defaults eval in the new frame, so
;; they can reference earlier params. Functions with defaults run as AST.
(def dp-add (x (y 10)) (+ x y))
(assert "default used when omitted"    (dp-add 1)                    11)
(assert "default overridden by arg"    (dp-add 1 2)                  3)
(def dp-chain (a (b (+ a 1)) (c 0)) (list a b c))
(assert "default refs earlier param"   (dp-chain 5)                  (list 5 6 0))
(assert "defaults partially supplied"  (dp-chain 5 100)              (list 5 100 0))
(assert "all args supplied"            (dp-chain 5 100 200)          (list 5 100 200))
(assert "anon fn default"              ((fn (x (y 5)) (* x y)) 3)    15)
(assert "default string value"         ((fn ((s "hi")) s))           "hi")
;; destructuring still works alongside defaults (2nd element is a symbol)
(assert "destructuring still works"    ((fn ((a b)) (+ a b)) (list 3 4)) 7)
;; a default param forces AST compilation (pair param), and a reserved
;; name as the default's bind-name is still rejected.
(assert "default param fn not compiled" (compiled? (fn (x (y 1)) (+ x y))) nil)
(assert "reserved default-name errors" (error? (fn (a (list 5)) a))   t)

;; --- docstrings: (def f (args) "doc" body...) ---
;; A leading string FOLLOWED by more forms is documentation; a lone string
;; body stays the return value. (docstring name) returns it (or nil).
(def ds-greet (who) "Greets WHO." (str "hi " who))
(assert "docstring stored"             (docstring (quote ds-greet))  "Greets WHO.")
(assert "docstring body intact"        (ds-greet "x")                "hi x")
(def ds-lone () "i-am-the-return")
(assert "lone string is body not doc"  (ds-lone)                     "i-am-the-return")
(assert "lone string has no docstring" (docstring (quote ds-lone))   nil)
(assert "docstring of undocumented"    (docstring (quote ds-lone))   nil)
(def ds-def (x (y 2)) "doc + defaults" (+ x y))
(assert "docstring with defaults"      (docstring (quote ds-def))    "doc + defaults")
(assert "doc+default body works"       (ds-def 5)                    7)
(assert "docstring of unknown is nil"  (docstring (quote no-such-fn-xyz)) nil)

;; --- multi-arity functions: (defn name (params body...) ...) ---
;; Each clause is a (param-list . body); a call dispatches on argument count.
;; A clause may be variadic via . rest (catches any arity >= its fixed count).
;; Reuses invoke/var2env per clause, so recursion across clauses and compiled
;; callers work; no matching clause raises a catchable error.
(defn dfn-area ((r) (* r r)) ((w h) (* w h)))
(assert "defn dispatch arity 1"        (dfn-area 5)                  25)
(assert "defn dispatch arity 2"        (dfn-area 4 6)                24)
(defn dfn-v ((x) (list 'one x)) ((x . more) (list 'many x more)))
(assert "defn fixed clause wins"       (dfn-v 1)                     (list 'one 1))
(assert "defn variadic clause"         (dfn-v 1 2 3)                 (list 'many 1 (list 2 3)))
(defn dfn-cnt ((n) (dfn-cnt n 0))
              ((n acc) (if (is n 0) acc (dfn-cnt (- n 1) (+ acc 1)))))
(assert "defn recursion across clauses" (dfn-cnt 5)                  5)
(assert "defn no matching clause errors" (try (dfn-area 1 2 3) (fn (e) 'caught)) 'caught)
(def dfn-call (n) (dfn-area n))   ;; compiled body dispatches into a defn
(assert "defn called from compiled fn" (dfn-call 7)                  49)
(defn dfn-empty (() 'zero) ((x) x))
(assert "defn empty-params clause"     (dfn-empty)                   'zero)
(assert "defn is callable/truthy"      (if dfn-area t nil)           t)
;; Leading-symbol clause form (what Adder's `r:` / `w h:` block produces):
;; a clause's leading symbols are the params, the first non-symbol begins the
;; body. Equivalent to the explicit ((r) ...) form; both are accepted.
(defn dfn-ls (r (* r r)) (w h (* w h)))
(assert "defn leading-symbol arity 1"  (dfn-ls 5)                    25)
(assert "defn leading-symbol arity 2"  (dfn-ls 4 6)                  24)
(defn dfn-mix ((r) (* r 2)) (w h (+ w h)))   ;; explicit + leading-symbol mixed
(assert "defn mixed clause forms 1"    (dfn-mix 5)                   10)
(assert "defn mixed clause forms 2"    (dfn-mix 3 4)                 7)

;; --- assigning to a reserved name is rejected too (=/setf/setq) ---
;; Same footgun on the write side: (= count 5) could never take effect
;; (lookup resolves the builtin first), so it now fails fast.
(assert "= reserved errors"            (error? (= count 5))                   t)
(assert "= reserved message"
        (string-contains? (error-message (= list 5)) "reserved")              t)
(assert "setf reserved errors"         (error? (setf map 5))                  t)
(assert "setq reserved errors"         (error? (setq time 5))                 t)
;; bare non-reserved + place forms + string keys all still assign fine
(assert "= non-reserved ok"            (do (= rnz 5) rnz)                     5)
(assert "= string place ok"            (let s "hello" (= (s 0) #\J) s)        "Jello")
(assert "= cons place ok"              (let x (list 1 2) (= (car x) 'z) x)    (list 'z 2))
(assert "= string-key ok"              (do (= "carwash" 7) carwash)           7)

;; ====================================================================
;; Callable indexing — (container i) reads element i for every indexable
;; type (string->char, vector->element, blob->byte), exercised in operator
;; position: literal head, via a var, compiled-body, and tail position; plus
;; float-index truncation and out-of-range errors. All four call sites
;; (AST literal head, AST var head, vm_invoke_values, OP_TAIL_CALL) share
;; one isindexable/index_get helper — these lock that contract down.
;; ====================================================================
(assert "string literal index"        ("toto" 1)                            #\o)
(= _ci_s "toto")
(assert "string via var"              (_ci_s 3)                              #\o)
(= _ci_v #[10 3 4 5 6])
(assert "vector via var"              (_ci_v 2)                              4)
(assert "vector literal head"         (#[7 8 9] 0)                           7)
(= _ci_b (string->blob "toto"))
(assert "blob byte t"                 (_ci_b 0)                              116)
(assert "blob byte o"                 (_ci_b 1)                              111)
(assert "blob literal head"           ((string->blob "Hi") 1)                105)
(def _ci_get (c i) (c i))   ;; compiled body; the (c i) tail call also covers OP_TAIL_CALL
(assert "compiled index: string"      (_ci_get "abc" 2)                      #\c)
(assert "compiled index: vector"      (_ci_get _ci_v 4)                      6)
(assert "compiled index: blob"        (_ci_get _ci_b 3)                      111)
(assert "index float truncates"       (_ci_v 2.9)                            4)
(assert "vector index out-of-range"   (try (_ci_v 99) (fn (e) 'caught))      'caught)
(assert "blob index out-of-range"     (try (_ci_b 99) (fn (e) 'caught))      'caught)
(assert "string index out-of-range"   (try ("ab" 9) (fn (e) 'caught))        'caught)
(assert "index negative errors"       (try (_ci_v -1) (fn (e) 'caught))      'caught)
;; Keyed containers are callable too (Clojure-style): dict/hamt -> value (nil
;; if absent), set -> the member (nil if absent). Same four call sites as the
;; indexable case (shared container_apply), so cover var/compiled heads.
(= _ci_d (hash-map "a" 1 "b" 2))
(assert "dict callable hit"           (_ci_d "a")                            1)
(assert "dict callable miss -> nil"   (_ci_d "z")                            nil)
(= _ci_h (hamt "x" 10 "y" 20))
(assert "hamt callable hit"           (_ci_h "y")                            20)
(assert "hamt callable miss -> nil"   (_ci_h "z")                            nil)
(= _ci_set (set 1 2 3))
(assert "set callable member"         (_ci_set 2)                            2)
(assert "set callable non-member nil" (_ci_set 9)                            nil)
(assert "hamt literal head"           ((hamt "k" 99) "k")                    99)
(def _ci_lookup (m k) (m k))   ;; compiled + tail position over keyed containers
(assert "compiled keyed: dict"        (_ci_lookup _ci_d "b")                 2)
(assert "compiled keyed: hamt"        (_ci_lookup _ci_h "x")                 10)
(assert "compiled keyed: set"         (_ci_lookup _ci_set 3)                 3)
;; eq / eq? are aliases of is (identity). Same semantics, different spelling.
(assert "eq same fixnum"              (eq 3 3)                               t)
(assert "eq different fixnum"         (eq 3 4)                               nil)
(assert "eq? alias works"             (eq? 'a 'a)                            t)
(assert "eq matches is"               (eq (eq 5 5) (is 5 5))                 t)
(assert "eq same string content"      (eq "hi" "hi")                         t)

;; ====================================================================
;; Truthiness matrix — one assert-true/assert-false per value KIND, so a
;; refactor of istrue (or anything feeding the `if`/and/or/while truthiness
;; path) is caught per-type instead of only where a value happens to be
;; iso-compared. Falsy set: nil, zero (int+float), empty string, char(!),
;; and every EMPTY container. Truthy set: t, nonzero numbers, non-empty
;; string, symbol, non-empty containers, and callables.
;; ====================================================================
(assert-false "falsy: nil"             nil)
(assert-false "falsy: 0"               0)
(assert-false "falsy: 0.0"             0.0)
(assert-false "falsy: empty string"    "")
(assert-false "falsy: char (by design)" #\a)
(assert-false "falsy: empty list"      (list))
(assert-false "falsy: empty vector"    (vec 0 nil))
(assert-false "falsy: empty hamt"      (hamt))
(assert-false "falsy: empty set"       (set))
(assert-false "falsy: empty dict"      (hash-map))
(assert-false "falsy: empty blob"      (string->blob ""))
(assert-true  "truthy: t"              t)
(assert-true  "truthy: 1"              1)
(assert-true  "truthy: -1"             -1)
(assert-true  "truthy: 1.5"            1.5)
(assert-true  "truthy: non-empty str"  "a")
(assert-true  "truthy: symbol"         'foo)
(assert-true  "truthy: non-empty list" (list 1))
(assert-true  "truthy: non-empty vec"  (vec 3 0))
(assert-true  "truthy: non-empty hamt" (hamt "a" 1))
(assert-true  "truthy: non-empty set"  (set 1))
(assert-true  "truthy: non-empty dict" (hash-map "a" 1))
(assert-true  "truthy: non-empty blob" (string->blob "a"))
(assert-true  "truthy: lambda"         (fn (x) x))
(assert-true  "truthy: builtin"        car)
;; assert-true/assert-false self-check (harness sanity, like assert/refute above)
(assert-true  "assert-true detects truthy" t)
(assert-false "assert-false detects falsy" nil)

;; ====================================================================
;; proposals.md tactical builtins: format / band / now-ms + string buffers
;; ====================================================================
(assert "format scalar"        (format 42)                 "42")
(assert "format list"          (format (list 1 2 3))       "(1 2 3)")
(assert "format = str alias"   (format "hi")               "hi")
(assert "band = bit-and"       (band 12 10)                8)
(assert-true "now-ms is a number"  (number? (now-ms)))
(assert-true "now-ms is monotonic non-decreasing"
             (do (= _t0 (now-ms)) (sleep-ms 2) (>= (now-ms) _t0)))
;; string buffers (codepoint-indexed; ASCII buffer == byte buffer for FFI)
(assert "string-buf default space" (string-buf 4)          "    ")
(assert "string-buf init char"     (string-buf 3 #\*)      "***")
(assert "string-buf zero len"      (string-buf 0)          "")
(assert "string-set! in place"
        (do (= _s (string-buf 4)) (string-set! _s 0 #\H) (string-set! _s 1 #\i) _s)
        "Hi  ")
(assert "string-set! returns s"
        (do (= _s (string-buf 2)) (string-set! _s 0 #\Z))
        "Z ")
(assert "string-fill!"             (string-fill! (string-buf 5) #\x)  "xxxxx")
(assert "string-copy! at offset"
        (do (= _d (string-buf 8)) (string-copy! _d 2 "Hi") _d)
        "  Hi    ")
(assert "string-copy! clamps at dst end"
        (do (= _d (string-buf 3)) (string-copy! _d 1 "ABCDE") _d)
        " AB")
(assert "string-copy! self-alias safe"
        (do (= _d "abcd") (string-copy! _d 0 _d) _d)
        "abcd")
(assert "string-set! utf8 width change"
        (do (= _s (string-buf 3)) (string-set! _s 1 #\é) _s)
        " é ")
(assert "string-set! utf8 keeps codepoint length"
        (do (= _s (string-buf 3)) (string-set! _s 1 #\é) (length _s))
        3)

;; ====================================================================
;; module system: (ns name) auto-qualifies top-level def/defn/defmacro to
;; name/<sym>; qualified references resolve; (ns) clears. (require itself is
;; filesystem-driven and exercised outside the suite.)
;; ====================================================================
(ns nstest)
(def nsfn (x) (* x 2))                       ; binds nstest/nsfn
(defn nsmulti ((x) x) ((x y) (+ x y)))       ; binds nstest/nsmulti
(defmacro nsmac (x) (list '+ x 1))           ; binds nstest/nsmac
(def nscount (n acc) (if (is n 0) acc (nstest/nscount (- n 1) (+ acc 1))))
(ns)                                          ; clear — later defs un-namespaced
(assert "ns auto-prefix def"            (nstest/nsfn 21)       42)
(assert "ns auto-prefix defn multi"     (nstest/nsmulti 3 4)   7)
(assert "ns auto-prefix defmacro"       (nstest/nsmac 9)       10)
(assert "ns qualified self-call + TCO"  (nstest/nscount 100000 0) 100000)
(assert-true "ns bare name unbound after clear" (error? (try nsfn (fn (e) e))))
(assert "ns cleared: plain def not prefixed" (do (def nsplain () 5) (nsplain)) 5)
(assert-true "ns explicit slash not double-qualified"
             (do (ns nstest) (def nstest/already () 1) (ns)
                 (no (error? (try (nstest/already) (fn (e) e))))))

;; ====================================================================
;; Machine-readable summary — `make test` greps this line and requires
;; "0 failed". Built with str so the digits are plain (no ANSI codes).
;; The process also exits 1 if any test failed (0 otherwise), so a runner
;; can rely on the exit code — and a crash mid-suite never looks like a
;; pass, since the (exit 0) below is only reached when every test ran.
;; ====================================================================
(prn (str "TEST RESULT: " _test_pass " passed, " _test_fail " failed"))
(exit (if (> _test_fail 0) 1 0))
