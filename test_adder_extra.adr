# ====================================================================
# Adder-syntax-specific tests — the ONLY hand-maintained part of test.adr.
#
# Everything else in the generated test.adr comes from transpiling test.alc
# (the shared engine suite) so adder runs the exact same corpus as alcove.
# These tests can't live in test.alc because they exercise the adder FRONT
# END itself — indentation/colon bodies, `return`, `each` — which the Lisp
# reader has no equivalent for. gen_test_adr.py splices this block in just
# before the TEST RESULT summary so the assertions are counted.
#
# assert / _test_pass / _test_fail are already defined by the transpiled
# preamble that precedes this block.
# ====================================================================

assert "with colon-body pythagorean" (with (x 3 y 4) (sqrt (+ (expt x 2) (expt y 2)))):
  5.0

# defc plus inline colon-body — the body nests correctly whether
# parenthesized or not (regression for the colon-leak bug).
defc adr-clamp (x lo hi):
  if (< x lo): (return lo)
  if (> x hi): return hi
  x
assert "defc inline clamp hi" (adr-clamp 99 0 10) 10
assert "defc inline clamp lo" (adr-clamp -3 0 10) 0
assert "defc inline clamp mid" (adr-clamp 5 0 10) 5
defc adr-find (pred xs):
  each x xs: (if (pred x) (return x))
  nil
assert "defc inline find hit" (adr-find (fn (n) (> n 3)) (list 1 2 5 0 9)) 5
assert "defc inline find miss" (adr-find (fn (n) (> n 9)) (list 1 2 3)) nil

# if / elif / else -> Arc-style flat cond. elif/else must align with the `if`
# they extend (same indent column); each is appended to the same if node.
def adr-grade (n):
  if (>= n 90):
    'A
  elif (>= n 80):
    'B
  elif (>= n 70):
    'C
  else:
    'F
assert "if/elif/else first arm" (adr-grade 95) 'A
assert "if/elif/else 2nd arm"   (adr-grade 85) 'B
assert "if/elif/else 3rd arm"   (adr-grade 72) 'C
assert "if/elif/else else arm"  (adr-grade 50) 'F

# def name():  — Python-style zero-param def with NO space before the empty
# parens. The empty-call sugar must not turn `name()` into `(name)` in the
# def-name position (regression for "missing name or name not a lambda").
def no-space-zero():
  42
assert "def name(): zero params" (no-space-zero) 42

# def with params, no space, still defines correctly.
def no-space-params(a b):
  + a b
assert "def name(a b): params"   (no-space-params 3 4) 7

# the make-counter shape end to end: a no-space def whose closure tail calls a
# user macro — exercises both the def-name sugar and compile-time macroexpansion.
defmacro adr-pp (n) `(= ,n (+ ,n 1))
def adr-make-counter():
  with (n 0):
    fn():               # fn() — keyword glued to its OWN empty param list
      adr-pp n
setf adr-c (adr-make-counter)
assert "no-space def + fn() + macro closure #1" (adr-c) 1
assert "no-space def + fn() + macro closure #2" (adr-c) 2

# fn () with a space still reads the same.
def adr-mk2 ():
  with (n 0):
    fn ():
      adr-pp n
setf adr-c2 (adr-mk2)
assert "spaced fn () closure" (adr-c2) 1

# a real no-arg CALL (not after a binder) is still (name).
def adr-ret7 (): 7
assert "no-arg call after binder vs call" (adr-ret7) 7

# infix assignment: `lhs = rhs` -> (= lhs rhs), Python-style, alongside the
# prefix `= place val`. A multi-token RHS wraps: `a = + b c` -> (= a (+ b c)).
= adr-iv 5
adr-iv = (* adr-iv 10)
assert "infix = reassign"        adr-iv 50
adr-iv = + 1 2
assert "infix = multi-token rhs" adr-iv 3
= adr-sv "test"
adr-sv = "toto"
assert "infix = on a string var" adr-sv "toto"
# prefix `= place val` (= as the FIRST form) is unchanged
= adr-iv 7
assert "prefix = still works"    adr-iv 7

# ====================================================================
# Call sugar (spec §6): `name(args)` reads as (name args) for ANY arity, not
# only the no-arg case. The binder exception still makes `def/fn/macro f(x):`
# a PARAMETER LIST, so headers are unaffected. (Glued parens on a binding-list
# form like let((..)) are NOT supported — use the spaced `let (..)`.)
# ====================================================================
def adr-add2 (a b): (+ a b)
def adr-z (): 99
# call WITH arguments via glued parens (the form HEAD could not express)
assert "call sugar: args"            adr-add2(3 4) 7
# nested call sugar
assert "call sugar: nested"          adr-add2(adr-add2(1 2) 3) 6
# no-arg call via glued parens: name() -> (name)
assert "call sugar: no-arg ()"       adr-z() 99
# builtins reached through the sugar
assert "call sugar: builtin list"    list(1 2 3) (list 1 2 3)
assert "call sugar: builtin car"     car(list(10 20)) 10
# function-like special forms through the sugar
assert "call sugar: and"             and(t t) t
assert "call sugar: or"              or(nil 5) 5
# infix = with a call-sugar RHS: adr-iv = adr-add2(8 9) -> (= adr-iv (adr-add2 8 9))
adr-iv = adr-add2(8 9)
assert "infix = with call-sugar rhs" adr-iv 17
# binder exception: glued params stay a param list, name then callable via sugar
defmacro adr-m2 (x) `(+ ,x 1)
assert "defmacro glued header + call" adr-m2(41) 42
macro adr-when2 (c body): `(if ,c ,body nil)
assert "macro glued header + call"   adr-when2(t 7) 7
setf adr-sqr (fn(x) (* x x))         # fn self-binder: fn(x) is a param list
assert "fn(x) self-binder param"     adr-sqr(7) 49
# idiomatic spaced let still works (regression guard)
assert "spaced let binding-list"     (let ((x 10) (y 20)) (+ x y)) 30

# Chained call sugar (currying): f(a)(b) -> ((f a) b). Each '(' that follows a
# ')' with NO whitespace re-heads the call; a space/newline breaks the chain.
def adr-adder (a): [_ + a]
assert "chained f(a)(b) curries"     adr-adder(10)(5) 15
def adr-add3 (a): (fn (b) (fn (c) (+ a (+ b c))))
assert "chained triple f(a)(b)(c)"   adr-add3(1)(2)(3) 6
def adr-mkinc (): [_ + 1]
assert "chained empty-first f()(x)"  adr-mkinc()(41) 42
# adjacency: a SPACE before '(' must NOT chain — it stays a separate form
assert "spaced f(a) (b) not chained" (iso (quote adr-adder(10) (5)) (quote (adr-adder 10))) t
# plain (single) call sugar still reads as one call, not a chain
assert "single call sugar unchanged" (iso (quote adr-add2(3 4)) (quote (adr-add2 3 4))) t

# ====================================================================
# Arc-lambda `[body...]` -> (fn (_) (body...)), implicit param `_`. The
# transpiler must group a bare `[...]` as ONE form; otherwise the loose
# `[`/`]` tokens make the infix-`=` rule wrap the RHS in extra parens and
# `adr-sq = [* _ _]` becomes a zero-arg call of the lambda.
# ====================================================================
adr-sq = [* _ _]
assert "arc-lambda infix bind"       (adr-sq 7) 49
assert "arc-lambda no extra parens"  ([+ _ 10] 5) 15
assert "arc-lambda as map arg"       (map [+ _ 1] (list 1 2 3)) (list 2 3 4)
assert "arc-lambda multi-form body"  ([do (+ _ 1) (* _ 2)] 4) 8

# ====================================================================
# `;` is the *Alcove* line-comment char and must be stripped by the adder
# transpiler too. Before the fix it leaked into the s-expr, where it started
# a comment that ate the closing paren — leaving the form unterminated, so
# the reader hit EOF and SILENTLY DROPPED the whole line (no eval, no bind,
# no output). Now a trailing `;` is a comment, matching `#`.
# ====================================================================
adr-semi = (+ 40 2) ; trailing semicolon is a comment, value still binds
assert "trailing ; is a comment"     adr-semi 42
adr-semi2 = (+ 1 1) ; (+ 99 99) <- this text is commented out, not evaluated
assert "; truncates rest of line"    adr-semi2 2
# a `#\;` char literal is NOT a comment — the value byte survives
assert "#\\; char literal survives"  #\; #\;

# ====================================================================
# Comprehension reader sugar: #l[/#g[ (sequence-shaped) and #s{/#d{
# (collection-shaped) desugar to (lfor…)/(gfor…)/(sfor…)/(dfor…). The
# adder front end (adr.h) lowers each to the same s-expr alcove's reader
# produces, so a bare [..] (arc-lambda) / {..} (hash-map) inside the body
# isn't misread.
# ====================================================================
assert "adder sugar #l[ with filter"    #l[x (range 0 10) (odd x) (* x x)] (list 1 9 25 49 81)
assert "adder sugar #l[ no filter"      #l[x (range 0 5) (* x 10)] (list 0 10 20 30 40)
assert "adder sugar #s{ dedup count"    (count #s{x (list 1 2 2 3 3 3) t (* x x)}) 3
assert "adder sugar #d{ entry"          (get #d{w (list "ada" "bob") w (length w)} "ada") 3
assert "adder sugar #g[ collects"       (collect! #g[x (range 0 10) (odd x) (* x x)]) (list 1 9 25 49 81)
assert "adder sugar #g[ no filter"      (collect! #g[x (range 0 4) (+ x 100)]) (list 100 101 102 103)

# ====================================================================
# defclass block form (Adder-idiomatic): a `defclass Name:` opens a block
# whose indented lines are clauses. `:extends Parent` inherits; a
# `:method name (self):` line with a trailing colon opens a nested body
# block (a single-line `:method name (self) body` also works). This is the
# spelling the generated corpus (transpiled from test.alc s-exprs) does not
# exercise directly.
# ====================================================================
defclass Beast:
  species String
  legs Int
  :method noise (self):
    (str (Beast-species self) " has " (Beast-legs self) " legs")

defclass Wolf:
  :extends Beast
  pack String
  :method noise (self) "awooo"

assert "block: inherited getter"        (Beast-species (Wolf "canis" 4 "alpha")) "canis"
assert "block: own getter"              (Wolf-pack (Wolf "canis" 4 "alpha")) "alpha"
assert "block: is-a? parent"            (is-a? (Wolf "c" 4 "p") Beast) t
assert "block: parent method on parent" (noise (Beast "cat" 4)) "cat has 4 legs"
assert "block: child overrides method"  (noise (Wolf "c" 4 "p")) "awooo"

# ====================================================================
# Adder-only DOT SYNTAX (attribute access). A '.' BETWEEN identifier chars in
# ONE token is attribute sugar. Three desugarings, all context-sensitive at the
# transpile layer:
#   read    a.owner      -> (a "owner")            a.b.c -> ((a "b") "c")
#   write   a.owner = v   -> (assoc! a "owner" v)   (assignment-statement LHS)
#   method  a.speak(x y)  -> (speak a x y)          (dotted token glued to '(')
# The LAST dotted segment before '(' is the generic-function name; the rest is
# the receiver read-chain. Receivers are dynamic (instances are callable dicts);
# assoc! writes are schema-validated by the class validator. A standalone `.`
# (dotted pair), floats (1.5, 100.0m) and keywords (:k) are UNTOUCHED, and the
# Alcove reader is unchanged — this sugar is Adder-only.
# ====================================================================
defclass DotOwner:
  name String

defclass DotBox:
  owner DotOwner
  size Int
  :method dot-describe (self): (str (DotBox-size self) "-box")
  :method dot-grow (self a b): (+ (DotBox-size self) (+ a b))

defclass DotCub:
  :extends DotBox

= dot-o (DotOwner "Ada")
= dot-box (DotBox dot-o 5)
= dot-cub (DotCub dot-o 7)

# read: a.field -> (a "field")
assert "dot read: field"                dot-box.size 5
# read: chained a.b.c -> ((a "b") "c") over a class-typed field
assert "dot read: chained"              dot-box.owner.name "Ada"
# read: an unknown field on an instance reads unvalidated -> nil
assert "dot read: unknown -> nil"       dot-box.ghost nil
# read: a dotted token NOT glued to '(' is a field read even for a method name
# (methods live in the generic table, not the instance dict) -> nil
assert "dot read: method name as field" dot-box.dot-describe nil
# method call via dot with 0 extra args: a.m() -> (m a)
assert "dot method: 0 args"             dot-box.dot-describe() "5-box"
# method call via dot with 2 extra args: a.m(x y) -> (m a x y)
assert "dot method: 2 args"             dot-box.dot-grow(3 4) 12
# inherited method via dot on a subclass instance
assert "dot method: inherited"          dot-cub.dot-describe() "7-box"

# write: a.field = v -> (assoc! a "field" v); a good value lands
dot-box.size = 9
assert "dot write: good lands"          dot-box.size 9
# write: a schema-invalid value errors and leaves the field unchanged
def dot-bad-write (): dot-box.size = "bad"
assert "dot write: bad errors"          (error? (try (dot-bad-write) (fn (e) e))) t
assert "dot write: bad leaves unchanged" dot-box.size 9
# write: an unknown field errors (schema-validated)
def dot-unknown-write (): dot-box.extra = 1
assert "dot write: unknown errors"      (error? (try (dot-unknown-write) (fn (e) e))) t

# dot on a PLAIN hash-map is dynamic key access (read + write, no schema)
= dot-map {"k" 1, "j" 2}
assert "dot map: read key"              dot-map.k 1
dot-map.k = 5
assert "dot map: write key"             dot-map.k 5

# float / decimal literals are digit-adjacent dots -> UNTOUCHED
assert "dot: float literal add"         (+ 1.5 2.5) 4.0
assert "dot: decimal literal add"       (+ 100.0m 0.5m) 100.5m
# a standalone `.` (dotted-pair spelling) is not attribute sugar
assert "dot: standalone dot untouched"  (length (quote (1 . 2))) 3

# ====================================================================
# defclass PHASE 7 in Adder block form: compound field schemas
# ((optional TE) / (list-of TE) / (or TE...)), trailing field defaults
# (call-time evaluated), (super name args...) in :method bodies, and the
# (instance? T) predicate-maker.
# ====================================================================
defclass AdrCritter:
  name String
  nick (optional String) nil
  scores (list-of Int) (list)
  :method yell (self): (str (AdrCritter-name self) "!")

defclass AdrHero:
  :extends AdrCritter
  :method yell (self): (str "** " (super yell self) " **")

assert "block: default fills"           (AdrCritter-nick (AdrCritter "Rex")) nil
assert "block: compound optional value" (AdrCritter-nick (AdrCritter "Rex" "R")) "R"
assert "block: compound rejects"        (error? (try (AdrCritter "Rex" 42) (fn (e) e))) t
assert "block: super parent-suffix"     (yell (AdrHero "Ada")) "** Ada! **"
assert "block: instance? filter"        (length (filter (instance? AdrCritter) (list (AdrHero "h") 1 (AdrCritter "c")))) 2
assert "block: instance? predicate"     ((instance? AdrHero) (AdrCritter "c")) nil
